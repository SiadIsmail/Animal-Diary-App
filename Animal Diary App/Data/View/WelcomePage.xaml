<?xml version="1.0" encoding="utf-8" ?>
<!--
    WelcomePage.xaml
    ─────────────────────────────────────────────────────────
    First screen shown when Pets.Count == 0.
    One exit: "Add my first pet" → navigates to CreatePetPage.
    After CreatePetPage saves, pop both from nav stack → MainPage.

    No bindings required on this page.
    OnAddPetClicked in code-behind handles navigation.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.WelcomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#DCEBF5">

    <Grid RowDefinitions="*,Auto">

        <!-- Background — same hintergrund_blau as all other pages -->
        <Image Source="hintergrund_blau.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               InputTransparent="True"
               Grid.RowSpan="2"/>

        <!-- ══════════════════════════════════
             MAIN CONTENT — vertically centered
        ══════════════════════════════════ -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Fill"
                             Padding="32,0">

            <!-- ── ANIMAL EMOJI CLUSTER ── -->
            <!-- Three overlapping avatar circles — warm and charming,
                 consistent with the pet avatar style in MainPage -->
            <Grid HeightRequest="130"
                  WidthRequest="200"
                  HorizontalOptions="Center"
                  Margin="0,0,0,32">

                <!-- Back-left pet -->
                <Border WidthRequest="80"
                        HeightRequest="80"
                        BackgroundColor="#5B9BB8"
                        Stroke="#70FFFFFF"
                        StrokeThickness="2"
                        HorizontalOptions="Start"
                        VerticalOptions="End">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#305B9BB8"
                                Offset="0,4"
                                Radius="10"
                                Opacity="0.3"/>
                    </Border.Shadow>
                    <Label Text="🐶"
                           FontSize="38"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Back-right pet -->
                <Border WidthRequest="80"
                        HeightRequest="80"
                        BackgroundColor="#5B9BB8"
                        Stroke="#70FFFFFF"
                        StrokeThickness="2"
                        HorizontalOptions="End"
                        VerticalOptions="End">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#305B9BB8"
                                Offset="0,4"
                                Radius="10"
                                Opacity="0.3"/>
                    </Border.Shadow>
                    <Label Text="🐰"
                           FontSize="38"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Front-center pet — slightly larger, elevated -->
                <Border WidthRequest="96"
                        HeightRequest="96"
                        BackgroundColor="#4A8BAA"
                        Stroke="#80FFFFFF"
                        StrokeThickness="2.5"
                        HorizontalOptions="Center"
                        VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="48"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#404A8BAA"
                                Offset="0,6"
                                Radius="16"
                                Opacity="0.4"/>
                    </Border.Shadow>
                    <Label Text="🐱"
                           FontSize="46"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

            </Grid>

            <!-- ── APP NAME ── -->
            <Label Text="PawLog"
                   FontSize="38"
                   FontAttributes="Bold"
                   TextColor="#1C3D52"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10"/>

            <!-- ── TAGLINE ── -->
            <Label Text="A health diary for the animals you love"
                   FontSize="15"
                   TextColor="#5A7990"
                   HorizontalTextAlignment="Center"
                   Margin="20,0,20,0"/>

        </VerticalStackLayout>

        <!-- ══════════════════════════════════
             BOTTOM ACTION BAR
             Same structure and style as all other pages
        ══════════════════════════════════ -->
        <Border Grid.Row="1"
                Padding="24,18,24,38"
                BackgroundColor="#EEC4A8E0"
                StrokeThickness="0"
                VerticalOptions="End">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#30000000"
                        Offset="0,-2"
                        Radius="10"
                        Opacity="0.18"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="14">

                <!-- Primary CTA — full width purple, same as every primary action -->
                <Border BackgroundColor="#9B6FCC"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#409B6FCC"
                                Offset="0,4"
                                Radius="12"
                                Opacity="0.4"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddPetClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="Add my first pet 🐾"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           Padding="0,15"/>
                </Border>

                <!-- Reassurance line — no skip, just a soft note -->
                <Label Text="Takes about 30 seconds · you can always edit later"
                       FontSize="11"
                       TextColor="#7B91A1"
                       HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
