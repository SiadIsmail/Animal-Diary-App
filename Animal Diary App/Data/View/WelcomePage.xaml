<?xml version="1.0" encoding="utf-8" ?>
<!--
    WelcomePage.xaml
    ─────────────────────────────────────────────────────────
    First screen shown when Pets.Count == 0. Two doors:
      • "Add my first pet" (primary) → CreatePetPage (OnAddPetClicked).
      • "Sign in" (secondary) → the shared account sheet (OnSignInClicked):
        sign in, create an account, or redeem an invite code. When signing in
        or joining pulls a pet down, RemoteChangesApplied hands off to the app.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:MainViewModel"
             x:Class="Animal_Diary_App.Data.View.WelcomePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#C4E6E3">

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ══════════ MAIN CONTENT — vertically centered ══════════ -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Fill"
                             Padding="34,0">

            <!-- Avatar cluster — three overlapping pet circles -->
            <Grid HeightRequest="130"
                  WidthRequest="210"
                  HorizontalOptions="Center"
                  Margin="0,0,0,36">

                <!-- Back-left -->
                <Border WidthRequest="80" HeightRequest="80"
                        Stroke="{StaticResource GlassLine}" StrokeThickness="2"
                        StrokeShape="RoundRectangle 40"
                        HorizontalOptions="Start" VerticalOptions="End">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource SeaHi}" Offset="0"/>
                            <GradientStop Color="{StaticResource SeaMid}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#0D3A3C" Offset="0,6" Radius="14" Opacity="0.12"/>
                    </Border.Shadow>
                    <Label Text="🐶" FontSize="38" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <!-- Back-right -->
                <Border WidthRequest="80" HeightRequest="80"
                        Stroke="{StaticResource GlassLine}" StrokeThickness="2"
                        StrokeShape="RoundRectangle 40"
                        HorizontalOptions="End" VerticalOptions="End">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource SeaGradTop}" Offset="0"/>
                            <GradientStop Color="{StaticResource SeaBlue}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#0D3A3C" Offset="0,6" Radius="14" Opacity="0.12"/>
                    </Border.Shadow>
                    <Label Text="🐰" FontSize="38" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <!-- Front-center -->
                <Border WidthRequest="96" HeightRequest="96"
                        Stroke="{StaticResource GlassLine}" StrokeThickness="2.5"
                        StrokeShape="RoundRectangle 48"
                        HorizontalOptions="Center" VerticalOptions="Start">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource SeaMid}" Offset="0"/>
                            <GradientStop Color="{StaticResource SeaBlue}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#0D3A3C" Offset="0,8" Radius="20" Opacity="0.18"/>
                    </Border.Shadow>
                    <Label Text="🐱" FontSize="46" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- App name -->
            <Label Text="Felova"
                   FontFamily="{StaticResource FontSerif}"
                   FontSize="{StaticResource TypeDisplay}"
                   TextColor="{StaticResource Ink}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,10"/>

            <!-- Tagline -->
            <Label Text="{loc:Translate Welcome_Tagline}"
                   FontFamily="{StaticResource FontSans}"
                   FontSize="15"
                   TextColor="{StaticResource InkSecondary}"
                   HorizontalTextAlignment="Center"
                   Margin="20,0"/>
        </VerticalStackLayout>

        <!-- ══════════ BOTTOM ACTION ══════════ -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="24,16,24,34"
                             Spacing="14">

            <!-- Two doors, side by side: the account door (1/3) for people who already
                 have an account or an invite code, and the primary "Add my first pet"
                 (2/3, unchanged teal) for everyone starting fresh. -->
            <Grid ColumnDefinitions="1*,2*" ColumnSpacing="12">

                <!-- Secondary: the one account door — sign in, create an account, or
                     (once signed in) redeem a code to become a caregiver. -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource Glass}"
                        Stroke="{StaticResource GlassLine}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 15,13,13,16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSignInClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="{loc:Translate Welcome_AccountButton}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Ink}"
                           HorizontalTextAlignment="Center"
                           Padding="0,16"/>
                </Border>

                <!-- Primary CTA (unchanged colour) -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Teal}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 15,13,13,16">
                    <Border.Shadow>
                        <Shadow Brush="#149081" Offset="0,6" Radius="16" Opacity="0.32"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddPetClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="{loc:Translate Welcome_AddFirstPet}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource White}"
                           HorizontalTextAlignment="Center"
                           Padding="0,16"/>
                </Border>
            </Grid>

            <!-- Reassurance -->
            <Label Text="{loc:Translate Welcome_Reassurance}"
                   FontFamily="{StaticResource FontSans}"
                   FontSize="11.5"
                   TextColor="{StaticResource InkTertiary}"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <!-- Account sheet (sign in / create account / join with a code) — the shared
             FelovaBottomSheet; click-through while closed so the buttons stay live. -->
        <view:CloudSheetView Grid.RowSpan="2"
                             BindingContext="{Binding CloudVM}"/>

    </Grid>

</ContentPage>
