<?xml version="1.0" encoding="utf-8" ?>
<!--
    LanguageSelectionPage.xaml
    ─────────────────────────────────────────────────────────
    Shown once, before the WelcomePage, when no language preference has been
    saved yet. The user picks German or English; the choice is applied live
    (so this page re-translates immediately) and persisted, then onboarding
    continues. Styled to match WelcomePage.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             x:Class="Animal_Diary_App.Data.View.LanguageSelectionPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#DCEBF5">

    <Grid RowDefinitions="*,Auto">

        <Image Source="hintergrund_blau.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               InputTransparent="True"
               Grid.RowSpan="2"/>

        <!-- ── MAIN CONTENT ── -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Fill"
                             Padding="32,0">

            <Label Text="🌍"
                   FontSize="56"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24"/>

            <Label Text="{loc:Translate Language_Title}"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1C3D52"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8"/>

            <Label Text="{loc:Translate Language_Subtitle}"
                   FontSize="14"
                   TextColor="#5A7990"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,32"/>

            <!-- Deutsch -->
            <Border x:Name="GermanOption"
                    BackgroundColor="#40FFFFFF"
                    Stroke="#60FFFFFF"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 18"
                    Padding="18"
                    Margin="0,0,0,12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGermanTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="14">
                    <Label Text="🇩🇪" FontSize="28" VerticalOptions="Center"/>
                    <Label Text="Deutsch"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="#1C3D52"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- English -->
            <Border x:Name="EnglishOption"
                    BackgroundColor="#40FFFFFF"
                    Stroke="#60FFFFFF"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 18"
                    Padding="18">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnEnglishTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="14">
                    <Label Text="🇬🇧" FontSize="28" VerticalOptions="Center"/>
                    <Label Text="English"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="#1C3D52"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- ── BOTTOM ACTION BAR ── -->
        <Border Grid.Row="1"
                Padding="24,18,24,38"
                BackgroundColor="#EEC4A8E0"
                StrokeThickness="0"
                VerticalOptions="End">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>

            <Border BackgroundColor="#9B6FCC"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 18">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnContinueTapped"/>
                </Border.GestureRecognizers>
                <Label Text="{loc:Translate Language_Continue}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Padding="0,15"/>
            </Border>
        </Border>

    </Grid>

</ContentPage>
