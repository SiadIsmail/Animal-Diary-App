<?xml version="1.0" encoding="utf-8" ?>
<!--
    LanguageSelectionPage.xaml
    ─────────────────────────────────────────────────────────
    Shown once, before the WelcomePage, when no language preference has been
    saved yet. The user picks German or English; the choice is applied live
    (so this page re-translates immediately) and persisted, then onboarding
    continues. Selection accent colors are set in code-behind.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             x:Class="Animal_Diary_App.Data.View.LanguageSelectionPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#C4E6E3">

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ── MAIN CONTENT ── -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Fill"
                             Padding="34,0">

            <Label Text="🌍"
                   FontSize="54"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24"/>

            <Label Text="{loc:Translate Language_Title}"
                   FontFamily="{StaticResource FontSerif}"
                   FontSize="28"
                   TextColor="{StaticResource Ink}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8"/>

            <Label Text="{loc:Translate Language_Subtitle}"
                   FontFamily="{StaticResource FontSans}"
                   FontSize="14"
                   TextColor="{StaticResource InkSecondary}"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,32"/>

            <!-- Deutsch -->
            <Border x:Name="GermanOption"
                    BackgroundColor="{StaticResource Card}"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 16"
                    Padding="18"
                    Margin="0,0,0,12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGermanTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="14">
                    <Label Text="🇩🇪" FontSize="28" VerticalOptions="Center"/>
                    <Label Text="Deutsch"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Ink}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- English -->
            <Border x:Name="EnglishOption"
                    BackgroundColor="{StaticResource Card}"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="2"
                    StrokeShape="RoundRectangle 16"
                    Padding="18">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnEnglishTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="14">
                    <Label Text="🇬🇧" FontSize="28" VerticalOptions="Center"/>
                    <Label Text="English"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Ink}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- ── BOTTOM ACTION ── -->
        <VerticalStackLayout Grid.Row="1"
                             Padding="24,16,24,34">
            <Border BackgroundColor="{StaticResource Viola}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="#7657B8" Offset="0,6" Radius="16" Opacity="0.32"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnContinueTapped"/>
                </Border.GestureRecognizers>
                <Label Text="{loc:Translate Language_Continue}"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       HorizontalTextAlignment="Center"
                       Padding="0,16"/>
            </Border>
        </VerticalStackLayout>

    </Grid>

</ContentPage>
