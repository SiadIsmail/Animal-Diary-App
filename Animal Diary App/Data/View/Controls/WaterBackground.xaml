<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.Controls.WaterBackground"
             x:Name="Root"
             InputTransparent="True"
             HorizontalOptions="Fill"
             VerticalOptions="Fill">

    <Grid x:Name="RootGrid"
          InputTransparent="True">

        <!-- Layer 1: base vertical wash -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#DDF2EC" Offset="0"/>
                <GradientStop Color="#C4E6E3" Offset="0.52"/>
                <GradientStop Color="#B6DCD9" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Layer 2: top-left glow -->
        <Ellipse x:Name="BlobTopLeft"
                 InputTransparent="True"
                 HorizontalOptions="Start"
                 VerticalOptions="Start">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#E8F7F1" Offset="0"/>
                    <GradientStop Color="#00E8F7F1" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Layer 3: top-right glow -->
        <Ellipse x:Name="BlobTopRight"
                 InputTransparent="True"
                 HorizontalOptions="Start"
                 VerticalOptions="Start">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#B7DCEC" Offset="0"/>
                    <GradientStop Color="#00B7DCEC" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Layer 4: bottom glow -->
        <Ellipse x:Name="BlobBottom"
                 InputTransparent="True"
                 HorizontalOptions="Start"
                 VerticalOptions="Start">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#A8D8CD" Offset="0"/>
                    <GradientStop Color="#00A8D8CD" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Layer 4b: warm sand rising from the very bottom edge — the touch of
             warmth that makes this the "warm" rockpool. Sits above the cool
             bottom glow, matching the HTML sand radial (painted on top). -->
        <Ellipse x:Name="BlobSand"
                 InputTransparent="True"
                 HorizontalOptions="Start"
                 VerticalOptions="Start">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                    <GradientStop Color="#EDDFC0" Offset="0"/>
                    <GradientStop Color="#00EDDFC0" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Layer 5: drifting bubbles -->
        <AbsoluteLayout InputTransparent="True"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill">

            <!-- 1: 78%, 4% — 150px — glass -->
            <Ellipse x:Name="Bubble1"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.78,0.04,150,150"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#73FFFFFF"/>
                </Ellipse.Stroke>
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#8CFFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- 2: 4%, 14% — 78px — outline -->
            <Ellipse x:Name="Bubble2"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.04,0.14,78,78"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Fill="Transparent"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#61FFFFFF"/>
                </Ellipse.Stroke>
            </Ellipse>

            <!-- 3: 88%, 22% — 42px — tint -->
            <Ellipse x:Name="Bubble3"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.88,0.22,42,42"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Fill="Transparent"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#33149081"/>
                </Ellipse.Stroke>
            </Ellipse>

            <!-- 4: 92%, 46% — 120px — outline -->
            <Ellipse x:Name="Bubble4"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.92,0.46,120,120"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Fill="Transparent"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#61FFFFFF"/>
                </Ellipse.Stroke>
            </Ellipse>

            <!-- 5: 10%, 55% — 56px — glass -->
            <Ellipse x:Name="Bubble5"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.10,0.55,56,56"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#73FFFFFF"/>
                </Ellipse.Stroke>
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#8CFFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- 6: 46%, 66% — 26px — tint -->
            <Ellipse x:Name="Bubble6"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.46,0.66,26,26"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Fill="Transparent"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#33149081"/>
                </Ellipse.Stroke>
            </Ellipse>

            <!-- 7: 2%, 82% — 170px — outline -->
            <Ellipse x:Name="Bubble7"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.02,0.82,170,170"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     Fill="Transparent"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#61FFFFFF"/>
                </Ellipse.Stroke>
            </Ellipse>

            <!-- 8: 84%, 76% — 34px — glass -->
            <Ellipse x:Name="Bubble8"
                     InputTransparent="True"
                     AbsoluteLayout.LayoutBounds="0.84,0.76,34,34"
                     AbsoluteLayout.LayoutFlags="PositionProportional"
                     StrokeThickness="1.5">
                <Ellipse.Stroke>
                    <SolidColorBrush Color="#73FFFFFF"/>
                </Ellipse.Stroke>
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.5" Radius="0.5">
                        <GradientStop Color="#8CFFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

        </AbsoluteLayout>

    </Grid>

</ContentView>
