<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             x:Class="Animal_Diary_App.Data.View.Controls.BottomNavigation"
             x:Name="Root">

    <!-- Floating frosted tab bar shared by Today / Journal / Pets.
         Set ActiveTab ("Main" | "Calendar" | "Pets") to highlight the current
         page; taps on the other two navigate via the Shell tab routes. -->
    <Border Margin="16,0,16,16"
            Padding="7"
            BackgroundColor="{StaticResource Glass}"
            Stroke="{StaticResource GlassLine}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 26,23,22,25"
            VerticalOptions="End">

        <Border.Shadow>
            <Shadow Brush="#0D3A3C"
                    Offset="0,10"
                    Radius="24"
                    Opacity="0.16"/>
        </Border.Shadow>

        <Grid ColumnDefinitions="*,*,*">

            <!-- MAIN -->
            <Border Grid.Column="0"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 17"
                    Padding="0,8">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding ActiveTab, Source={x:Reference Root}}"
                                 Value="Main">
                        <Setter Property="BackgroundColor" Value="{StaticResource TealTint}"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMainClicked"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="3">
                    <Image Source="todayicon.png"
                           WidthRequest="36"
                           HeightRequest="36"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"/>
                    <Label Text="{loc:Translate Nav_Main}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="10.5"
                           FontAttributes="Bold"
                           TextColor="{StaticResource InkTertiary}"
                           HorizontalTextAlignment="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding ActiveTab, Source={x:Reference Root}}"
                                         Value="Main">
                                <Setter Property="TextColor" Value="{StaticResource TealDeep}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- CALENDAR -->
            <Border Grid.Column="1"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 17"
                    Padding="0,8">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding ActiveTab, Source={x:Reference Root}}"
                                 Value="Calendar">
                        <Setter Property="BackgroundColor" Value="{StaticResource TealTint}"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCalendarClicked"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="3">
                    <Image Source="journalicon.png"
                           WidthRequest="36"
                           HeightRequest="36"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"/>
                    <Label Text="{loc:Translate Nav_Calendar}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="10.5"
                           FontAttributes="Bold"
                           TextColor="{StaticResource InkTertiary}"
                           HorizontalTextAlignment="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding ActiveTab, Source={x:Reference Root}}"
                                         Value="Calendar">
                                <Setter Property="TextColor" Value="{StaticResource TealDeep}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- PETS -->
            <Border Grid.Column="2"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 17"
                    Padding="0,8">
                <Border.Triggers>
                    <DataTrigger TargetType="Border"
                                 Binding="{Binding ActiveTab, Source={x:Reference Root}}"
                                 Value="Pets">
                        <Setter Property="BackgroundColor" Value="{StaticResource TealTint}"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPetsClicked"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="3">
                    <Image Source="careicon.png"
                           WidthRequest="36"
                           HeightRequest="36"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"/>
                    <Label Text="{loc:Translate Nav_Pets}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="10.5"
                           FontAttributes="Bold"
                           TextColor="{StaticResource InkTertiary}"
                           HorizontalTextAlignment="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label"
                                         Binding="{Binding ActiveTab, Source={x:Reference Root}}"
                                         Value="Pets">
                                <Setter Property="TextColor" Value="{StaticResource TealDeep}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Border>
</ContentView>
