<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             x:Class="Animal_Diary_App.Data.View.Controls.WeekCalendarView"
             x:Name="Root">

    <VerticalStackLayout Spacing="12">

        <!-- ── Week bar: month/range  ‹ › ── -->
        <Grid ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8"
              VerticalOptions="Center">

            <Label Grid.Column="0"
                   Text="{Binding WeekLabel, Source={x:Reference Root}}"
                   FontFamily="{StaticResource FontSerif}"
                   FontSize="19"
                   TextColor="{StaticResource Ink}"
                   VerticalOptions="Center"/>

            <Border Grid.Column="1"
                    WidthRequest="38"
                    HeightRequest="38"
                    BackgroundColor="{StaticResource Glass}"
                    Stroke="{StaticResource GlassLine}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 19">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPrevWeek"/>
                </Border.GestureRecognizers>
                <Label Text="‹"
                       FontSize="19"
                       FontAttributes="Bold"
                       TextColor="{StaticResource InkSecondary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Border Grid.Column="2"
                    WidthRequest="38"
                    HeightRequest="38"
                    BackgroundColor="{StaticResource Glass}"
                    Stroke="{StaticResource GlassLine}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 19">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNextWeek"/>
                </Border.GestureRecognizers>
                <Label Text="›"
                       FontSize="19"
                       FontAttributes="Bold"
                       TextColor="{StaticResource InkSecondary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- ── Week strip: recessed well of 7 cells (Mon–Sun) ── -->
        <Border BackgroundColor="{StaticResource Well}"
                Stroke="{StaticResource GlassLine}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22,19,18,21"
                Padding="6">

            <FlexLayout BindableLayout.ItemsSource="{Binding Cells, Source={x:Reference Root}}"
                        Wrap="Wrap"
                        Direction="Row"
                        AlignItems="Start"
                        JustifyContent="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <!-- No fixed height: at 58 the stacked weekday label, date ring
                             and dot row overflowed once the font metrics rounded up, and
                             the cell Border clipped the dots to its shape. The dot row
                             carries its own HeightRequest, so every cell still measures
                             the same whether it has dots or not. -->
                        <Grid FlexLayout.Basis="14.2857%"
                              Padding="2">
                            <Border BackgroundColor="Transparent"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 13"
                                    Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding SelectDayCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <VerticalStackLayout VerticalOptions="Center" Spacing="3">
                                    <!-- Weekday abbreviation -->
                                    <Label Text="{Binding WeekdayLabel}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="9.5"
                                           FontAttributes="Bold"
                                           CharacterSpacing="0.6"
                                           TextColor="{StaticResource InkTertiary}"
                                           HorizontalOptions="Center"/>

                                    <!-- Date number with a hand-sketched circle behind it when
                                         selected (the squiggle-ring from the HTML). The faint
                                         cell highlight is kept as well so selection never relies
                                         on the sketch alone. -->
                                    <Grid WidthRequest="34"
                                          HeightRequest="30"
                                          HorizontalOptions="Center">
                                        <Path Data="M17 2.5 C26 1.5 32 6 31.5 14 C31 23 25 28 16.5 27.5 C8 27 2.5 22 3 14 C3.4 7 9 3.4 15 2.8"
                                              Stroke="{StaticResource Teal}"
                                              StrokeThickness="1.6"
                                              StrokeLineCap="Round"
                                              IsVisible="{Binding IsSelected}"
                                              HorizontalOptions="Center"
                                              VerticalOptions="Center"/>
                                        <Label Text="{Binding DayNumber}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkSecondary}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource TealDeep}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>

                                    <!-- Activity dots -->
                                    <HorizontalStackLayout Spacing="2.5"
                                                           HeightRequest="6"
                                                           HorizontalOptions="Center"
                                                           BindableLayout.ItemsSource="{Binding Dots}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Ellipse WidthRequest="5"
                                                         HeightRequest="5"
                                                         Fill="{Binding Fill}"
                                                         Stroke="{Binding Stroke}"
                                                         StrokeThickness="{Binding StrokeThickness}"
                                                         VerticalOptions="Center"/>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </Border>

    </VerticalStackLayout>
</ContentView>
