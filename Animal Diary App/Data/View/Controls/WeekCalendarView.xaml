<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             x:Class="Animal_Diary_App.Data.View.Controls.WeekCalendarView"
             x:Name="Root">

    <VerticalStackLayout Spacing="12">

        <!-- ── Week bar: month/range  ‹ › ── -->
        <Grid ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8"
              VerticalOptions="Center">

            <Label Grid.Column="0"
                   Text="{Binding WeekLabel, Source={x:Reference Root}}"
                   FontFamily="{StaticResource FontSerif}"
                   FontSize="19"
                   TextColor="{StaticResource Ink}"
                   VerticalOptions="Center"/>

            <Border Grid.Column="1"
                    WidthRequest="38"
                    HeightRequest="38"
                    BackgroundColor="{StaticResource Card}"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 19">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPrevWeek"/>
                </Border.GestureRecognizers>
                <Label Text="‹"
                       FontSize="19"
                       FontAttributes="Bold"
                       TextColor="{StaticResource InkSecondary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Border Grid.Column="2"
                    WidthRequest="38"
                    HeightRequest="38"
                    BackgroundColor="{StaticResource Card}"
                    Stroke="{StaticResource Line}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 19">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNextWeek"/>
                </Border.GestureRecognizers>
                <Label Text="›"
                       FontSize="19"
                       FontAttributes="Bold"
                       TextColor="{StaticResource InkSecondary}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- ── Week strip: recessed well of 7 cells (Mon–Sun) ── -->
        <Border BackgroundColor="{StaticResource PaperDeep}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                Padding="6">

            <FlexLayout BindableLayout.ItemsSource="{Binding Cells, Source={x:Reference Root}}"
                        Wrap="Wrap"
                        Direction="Row"
                        AlignItems="Start"
                        JustifyContent="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Grid FlexLayout.Basis="14.2857%"
                              Padding="2"
                              HeightRequest="58">
                            <Border BackgroundColor="Transparent"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 13"
                                    Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding SelectDayCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Card}"/>
                                    </DataTrigger>
                                </Border.Triggers>

                                <VerticalStackLayout VerticalOptions="Center" Spacing="3">
                                    <!-- Weekday abbreviation -->
                                    <Label Text="{Binding WeekdayLabel}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="9.5"
                                           FontAttributes="Bold"
                                           CharacterSpacing="0.6"
                                           TextColor="{StaticResource InkTertiary}"
                                           HorizontalOptions="Center"/>

                                    <Label Text="{Binding DayNumber}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource InkSecondary}"
                                           HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource Viola}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Activity dots -->
                                    <HorizontalStackLayout Spacing="2.5"
                                                           HeightRequest="6"
                                                           HorizontalOptions="Center"
                                                           BindableLayout.ItemsSource="{Binding Dots}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Ellipse WidthRequest="5"
                                                         HeightRequest="5"
                                                         Fill="{Binding Fill}"
                                                         Stroke="{Binding Stroke}"
                                                         StrokeThickness="{Binding StrokeThickness}"
                                                         VerticalOptions="Center"/>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </Border>

    </VerticalStackLayout>
</ContentView>
