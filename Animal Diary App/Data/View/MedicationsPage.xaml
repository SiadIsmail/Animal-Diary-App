<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:MainViewModel"
             xmlns:models="clr-namespace:Animal_Diary_App.Data.Models"
             x:Class="Animal_Diary_App.Data.View.MedicationsPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.3"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ══════════ MAIN CONTENT ══════════ -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="16">

                <!-- Header -->
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12"
                      VerticalOptions="Center">

                    <Border Grid.Column="0"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackClicked"/>
                        </Border.GestureRecognizers>
                        <Label Text="‹"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource InkSecondary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label Grid.Column="1"
                           Text="{loc:Translate Med_Title}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="21"
                           TextColor="{StaticResource Ink}"
                           HorizontalTextAlignment="Center"
                           VerticalOptions="Center"/>

                </Grid>

                <!-- Active / Archived segmented control -->
                <Border BackgroundColor="{StaticResource Well}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999"
                        Padding="4">
                    <Grid ColumnDefinitions="*,*">

                        <Border Grid.Column="0"
                                BackgroundColor="Transparent"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding MedicationVM.ActiveTab}" Value="active">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding MedicationVM.SetActiveTabCommand}" CommandParameter="active"/>
                            </Border.GestureRecognizers>
                            <Label Text="{loc:Translate Med_Active}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource InkTertiary}"
                                   HorizontalTextAlignment="Center"
                                   Padding="0,9">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding MedicationVM.ActiveTab}" Value="active">
                                        <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="Transparent"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding MedicationVM.ActiveTab}" Value="archived">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding MedicationVM.SetActiveTabCommand}" CommandParameter="archived"/>
                            </Border.GestureRecognizers>
                            <Label Text="{loc:Translate Med_Archived}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource InkTertiary}"
                                   HorizontalTextAlignment="Center"
                                   Padding="0,9">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding MedicationVM.ActiveTab}" Value="archived">
                                        <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </Grid>
                </Border>

                <!-- Section label -->
                <Label Text="{Binding PetVM.MedicationsHeader}"
                       Style="{StaticResource SectionLabel}"
                       Margin="2,4,0,0"/>

                <!-- Medication list -->
                <CollectionView ItemsSource="{Binding MedicationVM.FilteredMedications}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:FilteredMedication">
                            <Border Padding="15,16"
                                    Margin="0,0,0,11"
                                    BackgroundColor="{StaticResource Glass}"
                                    Stroke="{StaticResource GlassLine}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 17,14,15,18">

                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="13">

                                    <!-- Pill icon -->
                                    <Border WidthRequest="46"
                                            HeightRequest="46"
                                            BackgroundColor="{StaticResource TealTint}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 13"
                                            VerticalOptions="Start">
                                        <Label Text="💊" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Details -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="5"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Ink}"/>
                                        <Label Text="{Binding DoseDisplay}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="12.5"
                                               TextColor="{StaticResource InkSecondary}"/>

                                        <HorizontalStackLayout Spacing="6">
                                            <Border BackgroundColor="{StaticResource TealTint}"
                                                    Padding="8,3"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 999">
                                                <Label Text="{Binding FrequencyDisplay}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource TealDeep}"/>
                                            </Border>
                                            <Border BackgroundColor="{StaticResource HoneyWarmTint}"
                                                    Padding="8,3"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 999">
                                                <Label Text="{Binding TimesDisplay}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource HoneyWarmDeep}"/>
                                            </Border>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding PetName}"
                                                   FontFamily="{StaticResource FontSans}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource InkTertiary}"/>
                                            <Label Text="·"
                                                   FontSize="11"
                                                   TextColor="{StaticResource InkTertiary}"
                                                   IsVisible="{Binding HasFoodNote}"/>
                                            <Label Text="{Binding Note}"
                                                   FontFamily="{StaticResource FontSans}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource InkTertiary}"
                                                   IsVisible="{Binding HasFoodNote}"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Actions -->
                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="8"
                                                         VerticalOptions="Center">
                                        <Border WidthRequest="34"
                                                HeightRequest="34"
                                                BackgroundColor="{StaticResource TealTint}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 17">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MedicationVM.EditMedicationCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="✏️" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                        <Border WidthRequest="34"
                                                HeightRequest="34"
                                                BackgroundColor="{StaticResource ClayTint}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 17">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MedicationVM.ArchiveMedicationCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="🗃️" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <!-- Empty state -->
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             Spacing="10"
                                             Padding="0,40">
                            <Label Text="💊"
                                   FontSize="40"
                                   HorizontalTextAlignment="Center"
                                   Opacity="0.35"/>
                            <Label Text="{loc:Translate Med_EmptyTitle}"
                                   FontFamily="{StaticResource FontSerif}"
                                   FontSize="17"
                                   TextColor="{StaticResource InkSecondary}"
                                   HorizontalTextAlignment="Center"/>
                            <Label Text="{loc:Translate Med_EmptySubtitle}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="12.5"
                                   TextColor="{StaticResource InkTertiary}"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════ STICKY ADD BUTTON ══════════ -->
        <Border Grid.Row="1"
                Margin="22,0,22,20"
                BackgroundColor="{StaticResource Teal}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 15,13,13,16"
                VerticalOptions="End">
            <Border.Shadow>
                <Shadow Brush="#149081" Offset="0,6" Radius="16" Opacity="0.3"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding MedicationVM.AddMedicationCommand}"/>
            </Border.GestureRecognizers>
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Padding="0,15">
                <Label Text="＋"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"/>
                <Label Text="{loc:Translate Med_Add}"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="15"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <!-- ══════════ ADD / EDIT MEDICATION SHEET ══════════ -->
        <view:AddEditMedicationsView Grid.Row="0"
                                     Grid.RowSpan="2"/>

    </Grid>

</ContentPage>
