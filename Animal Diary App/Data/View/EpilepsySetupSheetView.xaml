<?xml version="1.0" encoding="utf-8" ?>
<!--
    EpilepsySetupSheetView
    ─────────────────────────────────────────────────────────
    The reusable "add a seizure log" sheet. Nothing to schedule — one short line on
    WHY it's a log (not a daily task) plus a single action, in the shared
    FelovaBottomSheet. Hosted by BOTH the onboarding condition picker and Manage Pet.
    BindingContext is an EpilepsySetupSheetViewModel; open it via that VM's OpenAsync.
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:EpilepsySetupSheetViewModel"
             x:Class="Animal_Diary_App.Data.View.EpilepsySetupSheetView"
             x:Name="Root"
             InputTransparent="{Binding IsPresented, Converter={StaticResource InvertedBoolConverter}}">

    <controls:FelovaBottomSheet IsPresented="{Binding IsPresented}"
                                Title="{Binding TitleText}"
                                Subtitle="{Binding SubtitleText}"
                                DismissCommand="{Binding DismissCommand}">
        <controls:FelovaBottomSheet.SheetContent>

            <VerticalStackLayout Spacing="16" Padding="0,2,0,0">

                <!-- Why a log, not a daily task -->
                <Border BackgroundColor="{StaticResource GlassSoft}"
                        Stroke="{StaticResource GlassLine}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14,11,13,12"
                        Padding="15,13">
                    <Label Text="{Binding BodyText}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="13"
                           LineHeight="1.4"
                           TextColor="{StaticResource InkSecondary}"/>
                </Border>

                <!-- Actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,2,0,0">
                    <Border BackgroundColor="{StaticResource TealTint}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 15,13,13,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DismissCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate Common_NotNow}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TealDeep}"
                               HorizontalTextAlignment="Center"
                               Padding="0,14"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Teal}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 13,16,15,14">
                        <Border.Shadow>
                            <Shadow Brush="#149081" Offset="0,3" Radius="10" Opacity="0.3"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate CondSetup_EpilepsySave}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}"
                               HorizontalTextAlignment="Center"
                               Padding="0,14"/>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </controls:FelovaBottomSheet.SheetContent>
    </controls:FelovaBottomSheet>

</ContentView>
