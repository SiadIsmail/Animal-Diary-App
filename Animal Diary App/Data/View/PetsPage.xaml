<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:MainViewModel"
             xmlns:models="clr-namespace:Animal_Diary_App.Data.Models"
             x:Class="Animal_Diary_App.Data.View.PetsPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <!-- Felova card surface -->
            <Style x:Key="CardSurface" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                <Setter Property="Stroke" Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 17,14,15,18"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

            <!-- Uppercase section eyebrow -->
            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.3"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ================= CARE ================= -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="22">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="{loc:Translate Care_Eyebrow}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.3"
                               TextColor="{StaticResource InkTertiary}"/>
                        <Label Text="{loc:Translate Care_Title}"
                               FontFamily="{StaticResource FontSerif}"
                               FontSize="{StaticResource TypeH1}"
                               TextColor="{StaticResource Ink}"/>
                    </VerticalStackLayout>

                    <!-- Settings button -->
                    <Border Grid.Column="1"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.OpenSettingsCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="⚙️"
                               FontSize="17"
                               TextColor="{StaticResource InkSecondary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- ═══════════ YOUR PETS ═══════════ -->
                <Label Text="{loc:Translate Care_YourPets}"
                       Style="{StaticResource SectionLabel}"/>

                <!-- Pet switcher -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding PetVM.Pets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Pet">
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource GlassLine}"
                                        BackgroundColor="{StaticResource Glass}"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="7,7,14,7">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Ink}"/>
                                            <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PetVM.SelectPetCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                        <Border WidthRequest="26"
                                                HeightRequest="26"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 13"
                                                BackgroundColor="{StaticResource TealTint}"
                                                VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#28FFFFFF"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="🐾"
                                                   FontSize="12"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <Label Text="{Binding Name}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkSecondary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource White}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Active pet card -->
                <Border Style="{StaticResource CardSurface}"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">

                            <!-- Avatar — profile photo, or the type emoji fallback -->
                            <controls:PetAvatarView Grid.Column="0"
                                                    Diameter="60"
                                                    FallbackFontSize="30"
                                                    PhotoPath="{Binding PetVM.ActivePet.PhotoFullPath}"
                                                    FallbackText="{Binding PetVM.ActivePetEmoji}"
                                                    VerticalOptions="Center"/>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding PetVM.ActivePet.Name}"
                                       FontFamily="{StaticResource FontSerif}"
                                       FontSize="21"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{Binding PetVM.ActivePetSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12.5"
                                       TextColor="{StaticResource InkSecondary}"/>

                                <!-- Tags — the pet's real conditions, then its
                                     medication count. Empty when it has neither. -->
                                <FlexLayout Wrap="Wrap"
                                            Direction="Row"
                                            Margin="0,8,0,0"
                                            BindableLayout.ItemsSource="{Binding PetVM.ActivePetTags}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vms:PetProfileTag">
                                            <Border BackgroundColor="{StaticResource Well}"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 999"
                                                    Padding="10,4"
                                                    Margin="0,0,6,6">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsMedication}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="{StaticResource TealTint}"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="{Binding Label}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource InkSecondary}">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsMedication}" Value="True">
                                                            <Setter Property="TextColor" Value="{StaticResource TealDeep}"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Action — one "Manage" button opens the full Manage Pet page -->
                        <Button Text="{loc:Translate Pets_Manage}"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="13"
                                FontAttributes="Bold"
                                HeightRequest="44"
                                CornerRadius="14"
                                BackgroundColor="{StaticResource Teal}"
                                TextColor="{StaticResource White}"
                                Clicked="OnManageClicked"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Add a pet -->
                <Border BackgroundColor="{StaticResource Glass}"
                        Stroke="{StaticResource TealLine}"
                        StrokeThickness="1.5"
                        StrokeDashArray="4,3"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddPetClicked"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="🐾" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="{loc:Translate Pets_AddPet}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="13.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TealDeep}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- ═══════════ MANAGE ═══════════ -->
                <Label Text="{loc:Translate Pets_QuickManagement}"
                       Style="{StaticResource SectionLabel}"/>

                <Border Style="{StaticResource CardSurface}"
                        Padding="4">
                    <VerticalStackLayout>

                        <!-- Medication -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14"
                              Padding="14,15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAddMedicationClicked"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    BackgroundColor="{StaticResource TealTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 13"
                                    VerticalOptions="Center">
                                <Label Text="💊" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Pets_Medication}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{loc:Translate Pets_MedicationSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="22" TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassLine}" Margin="14,0"/>

                        <!-- Documents -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14"
                              Padding="14,15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDocumentsClicked"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    BackgroundColor="{StaticResource BlueTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 13"
                                    VerticalOptions="Center">
                                <Label Text="📄" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Pets_Documents}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{loc:Translate Pets_DocumentsSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="22" TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassLine}" Margin="14,0"/>

                        <!-- Export -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14"
                              Padding="14,15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ExportSheetVM.OpenCommand}"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    BackgroundColor="{StaticResource HoneyWarmTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 13"
                                    VerticalOptions="Center">
                                <Label Text="📤" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Pets_Export}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{loc:Translate Pets_ExportSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="22" TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= TAB BAR ================= -->
        <controls:BottomNavigation Grid.Row="1"
                                   ActiveTab="Pets"/>

        <!-- Export sheet overlay (FelovaBottomSheet; click-through while closed) -->
        <view:ExportSheetView Grid.RowSpan="2"
                              BindingContext="{Binding ExportSheetVM}"/>

        <!-- Cloud Features sheet (FelovaBottomSheet; click-through while closed) -->
        <view:CloudSheetView Grid.RowSpan="2"
                             BindingContext="{Binding CloudVM}"/>

        <!-- Settings panel overlay — last child renders on top of everything -->
        <view:SettingsPanelView Grid.RowSpan="2"
                                IsPanelOpen="{Binding SettingsVM.IsPanelOpen, Mode=TwoWay}"/>

    </Grid>

</ContentPage>
