<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             x:Class="Animal_Diary_App.Data.View.PetsPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <!-- Felova card surface -->
            <Style x:Key="CardSurface" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                <Setter Property="Stroke" Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 17,14,15,18"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

            <!-- Uppercase section eyebrow -->
            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.3"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ================= CARE ================= -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="22">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <VerticalStackLayout Spacing="2">
                        <Label Text="{loc:Translate Care_Eyebrow}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.3"
                               TextColor="{StaticResource InkTertiary}"/>
                        <Label Text="{loc:Translate Care_Title}"
                               FontFamily="{StaticResource FontSerif}"
                               FontSize="{StaticResource TypeH1}"
                               TextColor="{StaticResource Ink}"/>
                    </VerticalStackLayout>

                    <!-- Settings button -->
                    <Border Grid.Column="1"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.OpenSettingsCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="⚙️"
                               FontSize="17"
                               TextColor="{StaticResource InkSecondary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- ═══════════ YOUR PETS ═══════════ -->
                <Label Text="{loc:Translate Care_YourPets}"
                       Style="{StaticResource SectionLabel}"/>

                <!-- Pet switcher -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding PetVM.Pets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource GlassLine}"
                                        BackgroundColor="{StaticResource Glass}"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="7,7,14,7">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Ink}"/>
                                            <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PetVM.SelectPetCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                        <Border WidthRequest="26"
                                                HeightRequest="26"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 13"
                                                BackgroundColor="{StaticResource TealTint}"
                                                VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#28FFFFFF"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="🐾"
                                                   FontSize="12"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <Label Text="{Binding Name}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkSecondary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource White}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Active pet card -->
                <Border Style="{StaticResource CardSurface}"
                        Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">

                            <!-- Avatar -->
                            <Border Grid.Column="0"
                                    WidthRequest="60"
                                    HeightRequest="60"
                                    Stroke="{StaticResource TealLine}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 30"
                                    VerticalOptions="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{StaticResource SeaHi}" Offset="0"/>
                                        <GradientStop Color="{StaticResource SeaMid}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label Text="{Binding PetVM.ActivePetEmoji}"
                                       FontSize="30"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding PetVM.ActivePet.Name}"
                                       FontFamily="{StaticResource FontSerif}"
                                       FontSize="21"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{Binding PetVM.ActivePetSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12.5"
                                       TextColor="{StaticResource InkSecondary}"/>

                                <!-- Tags -->
                                <FlexLayout Wrap="Wrap"
                                            Direction="Row"
                                            Margin="0,8,0,0">
                                    <Border BackgroundColor="{StaticResource Well}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="10,4"
                                            Margin="0,0,6,6">
                                        <Label Text="{loc:Translate Pets_KidneyTag}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkSecondary}"/>
                                    </Border>
                                    <Border BackgroundColor="{StaticResource TealTint}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 999"
                                            Padding="10,4"
                                            Margin="0,0,6,6">
                                        <Label Text="{loc:Translate Pets_MedicationsTag}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TealDeep}"/>
                                    </Border>
                                </FlexLayout>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Actions -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="9">
                            <Button Grid.Column="0"
                                    Text="{loc:Translate Pets_OpenProfile}"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    HeightRequest="44"
                                    CornerRadius="14"
                                    BackgroundColor="{StaticResource Teal}"
                                    TextColor="{StaticResource White}"
                                    Command="{Binding PetVM.OpenActivePetProfileCommand}"/>
                            <Button Grid.Column="1"
                                    Text="{loc:Translate Pets_Edit}"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    HeightRequest="44"
                                    WidthRequest="96"
                                    CornerRadius="14"
                                    BackgroundColor="{StaticResource TealTint}"
                                    TextColor="{StaticResource TealDeep}"
                                    Command="{Binding PetVM.EditActivePetCommand}"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Add a pet -->
                <Border BackgroundColor="{StaticResource Glass}"
                        Stroke="{StaticResource TealLine}"
                        StrokeThickness="1.5"
                        StrokeDashArray="4,3"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAddPetClicked"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="🐾" FontSize="16" VerticalOptions="Center"/>
                        <Label Text="{loc:Translate Pets_AddPet}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="13.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TealDeep}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- ═══════════ MANAGE ═══════════ -->
                <Label Text="{loc:Translate Pets_QuickManagement}"
                       Style="{StaticResource SectionLabel}"/>

                <Border Style="{StaticResource CardSurface}"
                        Padding="4">
                    <VerticalStackLayout>

                        <!-- Medication -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14"
                              Padding="14,15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAddMedicationClicked"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    BackgroundColor="{StaticResource TealTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 13"
                                    VerticalOptions="Center">
                                <Label Text="💊" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Pets_Medication}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{loc:Translate Pets_MedicationSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="22" TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassLine}" Margin="14,0"/>

                        <!-- Documents -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14"
                              Padding="14,15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PetVM.OpenDocumentsCommand}"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    BackgroundColor="{StaticResource BlueTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 13"
                                    VerticalOptions="Center">
                                <Label Text="📄" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Pets_Documents}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{loc:Translate Pets_DocumentsSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="22" TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassLine}" Margin="14,0"/>

                        <!-- Export -->
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14"
                              Padding="14,15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PetVM.ExportReportCommand}"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    BackgroundColor="{StaticResource HoneyWarmTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 13"
                                    VerticalOptions="Center">
                                <Label Text="📤" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Pets_Export}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{loc:Translate Pets_ExportSubtitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›"
                                   FontSize="22" TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= TAB BAR ================= -->
        <Border Grid.Row="1"
                Margin="16,0,16,16"
                Padding="7"
                BackgroundColor="{StaticResource Glass}"
                Stroke="{StaticResource GlassLine}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                VerticalOptions="End">

            <Border.Shadow>
                <Shadow Brush="#0D3A3C" Offset="0,10" Radius="24" Opacity="0.16"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*">

                <!-- MAIN -->
                <Grid Grid.Column="0" Padding="0,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMainClicked"/>
                    </Grid.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="🏠" FontSize="20" HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Main}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5" FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- CALENDAR -->
                <Grid Grid.Column="1" Padding="0,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCalendarClicked"/>
                    </Grid.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="📅" FontSize="20" HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Calendar}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5" FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- PETS (active) -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource TealTint}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 17"
                        Padding="0,8">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="🐾" FontSize="20" HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Pets}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5" FontAttributes="Bold"
                               TextColor="{StaticResource TealDeep}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Settings panel overlay — last child renders on top of everything -->
        <view:SettingsPanelView Grid.RowSpan="2"
                                IsPanelOpen="{Binding SettingsVM.IsPanelOpen, Mode=TwoWay}"/>

    </Grid>

</ContentPage>
