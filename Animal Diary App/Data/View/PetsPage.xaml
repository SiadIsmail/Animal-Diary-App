<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             x:Class="Animal_Diary_App.Data.View.PetsPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#DCEBF5">

    <Grid RowDefinitions="*,Auto">

        <!-- Background -->
        <Image Source="hintergrund_blau.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               InputTransparent="True"
               Grid.RowSpan="2"/>

        <!-- MAIN CONTENT -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="24,20"
                                 Spacing="24">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <Label Text="My Pets"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1C3D52"
                           VerticalOptions="Center"/>

                    <!-- Settings button -->
                    <Border Grid.Column="1"
                            WidthRequest="38"
                            HeightRequest="38"
                            BackgroundColor="#55FFFFFF"
                            StrokeThickness="0"
                            HorizontalOptions="End"
                            VerticalOptions="Center">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="19"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.OpenSettingsCommand}"/>
                        </Border.GestureRecognizers>

                        <Label Text="⚙️"
                               FontSize="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                    </Border>

                </Grid>

                <!-- ═════════════════════════════ -->
                <!-- PET SWITCHER -->
                <!-- ═════════════════════════════ -->

                <VerticalStackLayout Spacing="12">

                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">

                        <HorizontalStackLayout Spacing="10"
                                               BindableLayout.ItemsSource="{Binding PetVM.Pets}">

                            <BindableLayout.ItemTemplate>

                                <DataTemplate>

                                    <Border StrokeThickness="2"
                                            StrokeShape="RoundRectangle 22"
                                            Padding="14,10">

                                        <!-- Selected state -->
                                        <Border.Triggers>

                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsSelected}"
                                                         Value="True">

                                                <Setter Property="BackgroundColor"
                                                        Value="#809B6FCC"/>

                                                <Setter Property="Stroke"
                                                        Value="#B39B6FCC"/>

                                            </DataTrigger>

                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding IsSelected}"
                                                         Value="False">

                                                <Setter Property="BackgroundColor"
                                                        Value="#339B6FCC"/>

                                                <Setter Property="Stroke"
                                                        Value="#599B6FCC"/>

                                            </DataTrigger>

                                        </Border.Triggers>

                                        <Border.GestureRecognizers>

                                            <!-- Single tap = set active pet -->
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PetVM.SelectPetCommand}"
                                                CommandParameter="{Binding .}"/>

                                        </Border.GestureRecognizers>

                                        <HorizontalStackLayout Spacing="8">

                                            <Label Text="{Binding Emoji}"
                                                   FontSize="15"
                                                   VerticalOptions="Center"/>

                                                <Label Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       TextColor="#4A1580"/>

                                        </HorizontalStackLayout>

                                    </Border>

                                </DataTemplate>

                            </BindableLayout.ItemTemplate>

                        </HorizontalStackLayout>

                    </ScrollView>

                </VerticalStackLayout>

                <!-- ═════════════════════════════ -->
                <!-- ACTIVE PET HERO -->
                <!-- ═════════════════════════════ -->

                <Border BackgroundColor="#5B9BB8"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 28"
                        Padding="20">

                    <Border.Shadow>
                        <Shadow Brush="#40000000"
                                Offset="0,8"
                                Radius="18"
                                Opacity="0.35"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="18">

                        <!-- Top Row -->
                        <Grid ColumnDefinitions="Auto,*,Auto">

                            <!-- Emoji -->
                            <Border Grid.Column="0"
                                    WidthRequest="72"
                                    HeightRequest="72"
                                    BackgroundColor="#38FFFFFF"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 36"
                                    VerticalOptions="Center">

                                <Label Text="{Binding PetVM.ActivePetEmoji}"
                                       FontSize="34"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>

                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="16,0,0,0"
                                                 VerticalOptions="Center"
                                                 Spacing="2">

                                <Label Text="{Binding PetVM.ActivePet.Name}"
                                       FontSize="20"
                                       FontFamily="Georgia"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <Label Text="{Binding PetVM.ActivePetSubtitle}"
                                       FontSize="14"
                                       TextColor="White"
                                       Opacity="0.7"/>

                                <!-- Tags -->
                                <FlexLayout Wrap="Wrap"
                                            Direction="Row"
                                            Margin="0,6,0,0">

                                    <!-- ? Bind conditions/tags collection -->
                                    <Border BackgroundColor="#33FFFFFF"
                                            StrokeThickness="1"
                                            Stroke="#55FFFFFF"
                                            StrokeShape="RoundRectangle 20"
                                            Padding="10,4"
                                            Margin="0,0,6,6">

                                        <Label Text="Kidney Stage 1"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="White"/>

                                    </Border>

                                    <Border BackgroundColor="#33FFFFFF"
                                            StrokeThickness="1"
                                            Stroke="#55FFFFFF"
                                            StrokeShape="RoundRectangle 20"
                                            Padding="10,4"
                                            Margin="0,0,6,6">

                                        <Label Text="2 Medications"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="White"/>

                                    </Border>

                                </FlexLayout>

                            </VerticalStackLayout>

                            <!-- Manage -->
                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="30"
                                   TextColor="White"
                                   Opacity="0.7"
                                   VerticalOptions="Center"/>

                        </Grid>

                        <!-- Action Buttons -->
                        <HorizontalStackLayout Spacing="10">

                            <Button Text="Open Profile"
                                    FontSize="13"
                                    HeightRequest="40"
                                    CornerRadius="20"
                                    HorizontalOptions="Fill"
                                    BackgroundColor="#38FFFFFF"
                                    TextColor="White"
                                    Command="{Binding PetVM.OpenActivePetProfileCommand}"/>

                            <Button Text="Edit"
                                    FontSize="13"
                                    HeightRequest="40"
                                    WidthRequest="90"
                                    CornerRadius="20"
                                    BackgroundColor="#38FFFFFF"
                                    TextColor="White"
                                    Command="{Binding PetVM.EditActivePetCommand}"/>

                        </HorizontalStackLayout>

                    </VerticalStackLayout>

                </Border>

                <!-- ═════════════════════════════ -->
                <!-- QUICK ACTIONS -->
                <!-- ═════════════════════════════ -->

                <VerticalStackLayout Spacing="12">

                    <Label Text="QUICK MANAGEMENT"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextColor="#2E6B85"
                           CharacterSpacing="1.5"/>

                    <!-- Row 1 -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">

                        <!-- Add Pet -->
                        <Border Grid.Column="0"
                                BackgroundColor="#40FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                Padding="18">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnAddPetClicked"/>
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">

                                <Label Text="🐾"
                                       FontSize="28"/>

                                <Label Text="Add Pet"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <Label Text="Create a new pet profile"
                                       FontSize="12"
                                       TextColor="White"
                                       Opacity="0.7"/>

                            </VerticalStackLayout>

                        </Border>

                        <!-- Add Medication -->
                        <Border Grid.Column="1"
                                BackgroundColor="#40FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                Padding="18">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnAddMedicationClicked"/>
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">

                                <Label Text="💊"
                                       FontSize="28"/>

                                <Label Text="Medication"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <Label Text="Manage schedules and doses"
                                       FontSize="12"
                                       TextColor="White"
                                       Opacity="0.7"/>

                            </VerticalStackLayout>

                        </Border>

                    </Grid>

                    <!-- Row 2 -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">

                        <!-- Documents -->
                        <Border Grid.Column="0"
                                BackgroundColor="#40FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                Padding="18">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding PetVM.OpenDocumentsCommand}"/>
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">

                                <Label Text="📄"
                                       FontSize="28"/>

                                <Label Text="Documents"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <Label Text="Reports, scans and files"
                                       FontSize="12"
                                       TextColor="White"
                                       Opacity="0.7"/>

                            </VerticalStackLayout>

                        </Border>

                        <!-- Export -->
                        <Border Grid.Column="1"
                                BackgroundColor="#40FFFFFF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                Padding="18">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding PetVM.ExportReportCommand}"/>
                            </Border.GestureRecognizers>

                            <VerticalStackLayout Spacing="8">

                                <Label Text="📤"
                                       FontSize="28"/>

                                <Label Text="Export"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <Label Text="Generate health PDF"
                                       FontSize="12"
                                       TextColor="White"
                                       Opacity="0.7"/>

                            </VerticalStackLayout>

                        </Border>

                    </Grid>

                </VerticalStackLayout>

            </VerticalStackLayout>

        </ScrollView>

        <!-- ═════════════════════════════ -->
        <!-- BOTTOM NAVIGATION -->
        <!-- ═════════════════════════════ -->

        <Border Grid.Row="1"
                Margin="0"
                Padding="12,10,12,20"
                BackgroundColor="#E6C4A8E0"
                StrokeThickness="0"
                VerticalOptions="End">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#30000000"
                        Offset="0,-2"
                        Radius="10"
                        Opacity="0.18"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*">

                <!-- MAIN -->
                <Grid>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMainClicked"/>
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="2">

                        <Label Text="🏠"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Main"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#664A1580"
                               HorizontalTextAlignment="Center"/>

                    </VerticalStackLayout>

                </Grid>

                <!-- CALENDAR -->
                <Grid Grid.Column="1">

                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCalendarClicked"/>
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="2">

                        <Label Text="📅"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Calendar"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#664A1580"
                               HorizontalTextAlignment="Center"/>

                    </VerticalStackLayout>

                </Grid>

                <!-- PETS -->
                <Grid Grid.Column="2">

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="2">

                        <Label Text="🐾"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Pets"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#4A1580"
                               HorizontalTextAlignment="Center"/>

                    </VerticalStackLayout>

                </Grid>

            </Grid>

        </Border>

        <!-- Settings panel overlay — last child renders on top of everything -->
        <view:SettingsPanelView Grid.RowSpan="2"
                                IsPanelOpen="{Binding SettingsVM.IsPanelOpen, Mode=TwoWay}"/>

    </Grid>

</ContentPage>