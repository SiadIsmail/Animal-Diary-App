<?xml version="1.0" encoding="utf-8" ?>
<!--
    AddEditMedicationsView.xaml
    ─────────────────────────────────────────────────────────
    Add / edit a medication. The slide-up chrome + motion now live in the shared
    FelovaBottomSheet; this view only supplies the sheet's Title/Subtitle and its
    body (the form + footer). Presented by binding the sheet's IsPresented to
    MedicationVM.IsAddEditSheetVisible; tapping the scrim runs CancelMedication.
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             x:Class="Animal_Diary_App.Data.View.AddEditMedicationsView"
             x:Name="Root"
             InputTransparent="{Binding MedicationVM.IsAddEditSheetVisible, Converter={StaticResource InvertedBoolConverter}}">

    <ContentView.Resources>
        <ResourceDictionary>
            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="0.8"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>
            <Style x:Key="FieldBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                <Setter Property="Stroke" Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 13"/>
            </Style>
            <Style x:Key="ErrorLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextColor" Value="{StaticResource Clay}"/>
            </Style>
        </ResourceDictionary>
    </ContentView.Resources>

    <controls:FelovaBottomSheet x:Name="Sheet"
                                IsPresented="{Binding MedicationVM.IsAddEditSheetVisible}"
                                Title="{Binding MedicationVM.SheetTitle}"
                                Subtitle="{Binding MedicationVM.SheetSubtitle}"
                                DismissCommand="{Binding MedicationVM.CancelMedicationCommand}">
        <controls:FelovaBottomSheet.SheetContent>

            <Grid RowDefinitions="*,Auto" RowSpacing="16">

                <!-- Form body -->
                <ScrollView Grid.Row="0"
                            VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout Spacing="14" Padding="0,0,0,4">

                        <!-- Name -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate MedEdit_NameLabel}" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="{loc:Translate MedEdit_NamePlaceholder}"
                                       Text="{Binding MedicationVM.MedicationDraft.Name}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14"
                                       TextColor="{StaticResource Ink}"
                                       PlaceholderColor="{StaticResource InkTertiary}"
                                       Margin="14,0"/>
                            </Border>
                            <Label Text="{Binding MedicationVM.MedicationNameError}"
                                   Style="{StaticResource ErrorLabel}"
                                   IsVisible="{Binding MedicationVM.MedicationNameError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Dose + unit -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{loc:Translate MedEdit_DoseLabel}" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Placeholder="2.5"
                                           Text="{Binding MedicationVM.MedicationDraft.Dosage}"
                                           Keyboard="Numeric"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="14"
                                           TextColor="{StaticResource Ink}"
                                           PlaceholderColor="{StaticResource InkTertiary}"
                                           Margin="14,0"/>
                                </Border>
                                <Label Text="{Binding MedicationVM.DosageError}"
                                       Style="{StaticResource ErrorLabel}"
                                       IsVisible="{Binding MedicationVM.DosageError, Converter={StaticResource StringToBoolConverter}}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6" WidthRequest="90">
                                <Label Text="{loc:Translate MedEdit_UnitLabel}" Style="{StaticResource FieldLabel}"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Picker Title="mg"
                                            SelectedItem="{Binding MedicationVM.MedicationDraft.Unit}"
                                            ItemsSource="{Binding MedicationVM.UnitOptions}"
                                            FontFamily="{StaticResource FontSans}"
                                            FontSize="14"
                                            TextColor="{StaticResource Ink}"
                                            Margin="10,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Weekday selector -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{loc:Translate MedEdit_DaysLabel}" Style="{StaticResource FieldLabel}"/>
                            <CollectionView ItemsSource="{Binding MedicationVM.Days}"
                                            ItemsLayout="HorizontalList"
                                            SelectionMode="None"
                                            HeightRequest="52">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border WidthRequest="42"
                                                HeightRequest="42"
                                                Stroke="{StaticResource GlassLine}"
                                                StrokeThickness="1"
                                                BackgroundColor="{StaticResource Glass}"
                                                StrokeShape="RoundRectangle 21"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"
                                                Margin="0,0,7,0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MedicationVM.ToggleDayCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource Teal}"/>
                                                    <Setter Property="Stroke" Value="{StaticResource Teal}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding DisplayName}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontFamily="{StaticResource FontSans}"
                                                   FontAttributes="Bold"
                                                   FontSize="13"
                                                   TextColor="{StaticResource InkSecondary}">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="TextColor" Value="{StaticResource White}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Label Text="{Binding MedicationVM.DaysError}"
                                   Style="{StaticResource ErrorLabel}"
                                   IsVisible="{Binding MedicationVM.DaysError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Times per day -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate MedEdit_TimesPerDayLabel}" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker ItemsSource="{Binding MedicationVM.FrequencyOptions}"
                                        SelectedItem="{Binding MedicationVM.SelectedFrequency}"
                                        FontFamily="{StaticResource FontSans}"
                                        FontSize="14"
                                        TextColor="{StaticResource Ink}"
                                        Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Dynamic reminder time pickers -->
                        <VerticalStackLayout Spacing="10"
                                             BindableLayout.ItemsSource="{Binding MedicationVM.ReminderTimes}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Label}" Style="{StaticResource FieldLabel}"/>
                                        <Border Style="{StaticResource FieldBorder}">
                                            <TimePicker Time="{Binding Time}"
                                                        Format="HH:mm"
                                                        FontFamily="{StaticResource FontSans}"
                                                        FontSize="14"
                                                        TextColor="{StaticResource Ink}"
                                                        Margin="14,8"/>
                                        </Border>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Assigned pet -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate MedEdit_ForPetLabel}" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker ItemsSource="{Binding PetVM.Pets}"
                                        SelectedItem="{Binding PetVM.SelectedPet}"
                                        ItemDisplayBinding="{Binding Name}"
                                        FontFamily="{StaticResource FontSans}"
                                        FontSize="14"
                                        TextColor="{StaticResource Ink}"
                                        Margin="10,0"/>
                            </Border>
                            <Label Text="{Binding MedicationVM.PetError}"
                                   Style="{StaticResource ErrorLabel}"
                                   IsVisible="{Binding MedicationVM.PetError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <!-- Food note -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate MedEdit_NotesLabel}" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="{loc:Translate MedEdit_NotesPlaceholder}"
                                       Text="{Binding MedicationVM.MedicationDraft.Notes}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14"
                                       TextColor="{StaticResource Ink}"
                                       PlaceholderColor="{StaticResource InkTertiary}"
                                       Margin="14,0"/>
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Footer actions -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <Border BackgroundColor="{StaticResource TealTint}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 15,13,13,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding MedicationVM.CancelMedicationCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate Common_Cancel}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TealDeep}"
                               HorizontalTextAlignment="Center"
                               Padding="0,14"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Teal}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 13,16,15,14"
                            Opacity="{Binding MedicationVM.CanSaveMedication, Converter={StaticResource BoolToOpacityConverter}}"
                            IsEnabled="{Binding MedicationVM.CanSaveMedication}">
                        <Border.Shadow>
                            <Shadow Brush="#149081" Offset="0,3" Radius="10" Opacity="0.3"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding MedicationVM.SaveMedicationCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{Binding MedicationVM.SaveButtonText}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}"
                               HorizontalTextAlignment="Center"
                               Padding="0,14"/>
                    </Border>
                </Grid>

            </Grid>
        </controls:FelovaBottomSheet.SheetContent>
    </controls:FelovaBottomSheet>

</ContentView>
