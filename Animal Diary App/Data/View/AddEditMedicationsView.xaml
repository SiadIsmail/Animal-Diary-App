<?xml version="1.0" encoding="utf-8" ?>
<!--
    AddEditMedicationsView.xaml
    ─────────────────────────────────────────────────────────
    A slide-up bottom sheet for adding OR editing a medication. It is embedded
    as an overlay inside MedicationsPage (spanning all rows) so the page behind
    stays visible and is dimmed by the scrim while the sheet is open.

    Visibility + slide/fade animation are driven by
    MedicationVM.IsAddEditSheetVisible (see the code-behind). The form binds the
    same MedicationVM draft properties used for both add and edit; the title and
    save-button label switch via MedicationVM.SheetTitle / SaveButtonText, and an
    "editing" indicator shows when MedicationVM.IsEditingMedication is true.
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.AddEditMedicationsView"
             x:Name="Root"
             IsVisible="False"
             InputTransparent="False">

    <Grid>
        <!-- Semi-transparent scrim — dims the page behind; tapping it dismisses the sheet -->
        <BoxView x:Name="Scrim"
                 BackgroundColor="#60000000"
                 InputTransparent="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding MedicationVM.CancelMedicationCommand}"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- ── Sheet itself, anchored to bottom ──
             Capped to a fraction of the screen height in code-behind so the
             body scrolls and the footer stays pinned and clickable. -->
        <Border x:Name="SheetContainer"
                BackgroundColor="#F0EBF8"
                StrokeThickness="0"
                VerticalOptions="End"
                Padding="20,0,20,28">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28,28,0,0"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#40000000"
                        Offset="0,-4"
                        Radius="20"
                        Opacity="0.25"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*,Auto"
                  RowSpacing="16">

                <!-- Handle + title (fixed header) -->
                <VerticalStackLayout Grid.Row="0"
                                     Spacing="14"
                                     Padding="0,14,0,0">

                    <!-- Drag handle -->
                    <BoxView WidthRequest="40"
                             HeightRequest="4"
                             CornerRadius="2"
                             BackgroundColor="#C4A8E0"
                             HorizontalOptions="Center"/>

                    <!-- "Add Medication" / "Edit Medication" -->
                    <Label Text="{Binding MedicationVM.SheetTitle}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1C3D52"
                           HorizontalOptions="Center"/>

                    <!-- Editing indicator — only shown when overriding an existing med -->
                    <Label Text="You're editing an existing medication"
                           FontSize="12"
                           FontAttributes="Italic"
                           TextColor="#7A5D99"
                           HorizontalOptions="Center"
                           IsVisible="{Binding MedicationVM.IsEditingMedication}"/>

                </VerticalStackLayout>

                <!-- ── FORM FIELDS (scrollable body) ── -->
                <ScrollView Grid.Row="1"
                            VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="12"
                                     Padding="0,0,0,4">

                    <!-- Medication name -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="MEDICATION NAME"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#5A7990"/>
                        <Border BackgroundColor="#FFFFFF"
                                Stroke="#D0C8E0"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="e.g. Methimazole"
                                   Text="{Binding MedicationVM.MedicationDraft.Name}"
                                   FontSize="14"
                                   TextColor="#1C3D52"
                                   PlaceholderColor="#A0B0BC"
                                   Margin="14,0"/>
                        </Border>
                        <Label Text="{Binding MedicationVM.MedicationNameError}"
                               FontSize="11"
                               TextColor="#E83E5F"
                               IsVisible="{Binding MedicationVM.MedicationNameError, Converter={StaticResource StringToBoolConverter}}"/>
                    </VerticalStackLayout>

                    <!-- Dose + unit side by side -->
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">

                        <VerticalStackLayout Spacing="5">
                            <Label Text="DOSE"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="#5A7990"/>
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#D0C8E0"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Entry Placeholder="2.5"
                                       Text="{Binding MedicationVM.MedicationDraft.Dosage}"
                                       Keyboard="Numeric"
                                       FontSize="14"
                                       TextColor="#1C3D52"
                                       PlaceholderColor="#A0B0BC"
                                       Margin="14,0"/>
                            </Border>
                            <Label Text="{Binding MedicationVM.DosageError}"
                                   FontSize="11"
                                   TextColor="#E83E5F"
                                   IsVisible="{Binding MedicationVM.DosageError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="5"
                                             WidthRequest="90">
                            <Label Text="UNIT"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="#5A7990"/>
                            <Border BackgroundColor="#FFFFFF"
                                    Stroke="#D0C8E0"
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Picker Title="mg"
                                        SelectedItem="{Binding MedicationVM.MedicationDraft.Unit}"
                                        ItemsSource="{Binding MedicationVM.UnitOptions}"
                                        FontSize="14"
                                        TextColor="#1C3D52"
                                        Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>

                    </Grid>

                    <!-- WEEKDAY SELECTOR -->

                    <VerticalStackLayout Spacing="8">

                        <Label Text="MEDICATION DAYS"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#5A7990"/>

                        <CollectionView
                            ItemsSource="{Binding MedicationVM.Days}"
                            ItemsLayout="HorizontalList"
                            SelectionMode="None"
                            HeightRequest="60">

                            <CollectionView.ItemTemplate>

                                <DataTemplate>

                                    <Border
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        Stroke="#D0C8E0"
                                        StrokeThickness="1"
                                        BackgroundColor="White"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="21"/>
                                        </Border.StrokeShape>

                                        <Border.GestureRecognizers>

                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MedicationVM.ToggleDayCommand}"
                                                CommandParameter="{Binding .}"/>

                                        </Border.GestureRecognizers>

                                        <Border.Triggers>

                                            <DataTrigger
                                                TargetType="Border"
                                                Binding="{Binding IsSelected}"
                                                Value="True">

                                                <Setter Property="BackgroundColor"
                                                        Value="#9B6FCC"/>

                                                <Setter Property="Stroke"
                                                        Value="#9B6FCC"/>

                                            </DataTrigger>

                                        </Border.Triggers>

                                        <Label
                                            Text="{Binding DisplayName}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            TextColor="#1C3D52"
                                            FontAttributes="Bold"
                                            FontSize="13"/>

                                    </Border>

                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>

                        <Label Text="{Binding MedicationVM.DaysError}"
                               FontSize="11"
                               TextColor="#E83E5F"
                               IsVisible="{Binding MedicationVM.DaysError, Converter={StaticResource StringToBoolConverter}}"/>

                    </VerticalStackLayout>


                    <!-- TIMES PER DAY -->

                    <VerticalStackLayout Spacing="5">

                        <Label Text="TIMES PER DAY"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#5A7990"/>

                        <Border BackgroundColor="#FFFFFF"
                                Stroke="#D0C8E0"
                                StrokeThickness="1">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>

                            <Picker
                                ItemsSource="{Binding MedicationVM.FrequencyOptions}"
                                SelectedItem="{Binding MedicationVM.SelectedFrequency}"
                                FontSize="14"
                                TextColor="#1C3D52"
                                Margin="10,0"/>

                        </Border>



                    </VerticalStackLayout>


                    <!-- DYNAMIC TIME PICKERS
                         One picker per reminder time. The number of items is
                         driven by MedicationVM.SelectedFrequency, which keeps
                         MedicationVM.ReminderTimes in sync (1–5 entries). Each
                         TimePicker is bound to its own slot's Time. -->

                    <VerticalStackLayout
                        Spacing="10"
                        BindableLayout.ItemsSource="{Binding MedicationVM.ReminderTimes}">

                        <BindableLayout.ItemTemplate>

                            <DataTemplate>

                                <VerticalStackLayout Spacing="5">

                                    <Label Text="{Binding Label}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#5A7990"/>

                                    <Border BackgroundColor="#FFFFFF"
                                            Stroke="#D0C8E0"
                                            StrokeThickness="1">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14"/>
                                        </Border.StrokeShape>

                                        <TimePicker
                                            Time="{Binding Time}"
                                            Format="HH:mm"
                                            FontSize="14"
                                            TextColor="#1C3D52"
                                            Margin="14,8"/>

                                    </Border>

                                </VerticalStackLayout>

                            </DataTemplate>

                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>


                    <!-- Assigned pet -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="FOR PET"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#5A7990"/>
                        <Border BackgroundColor="#FFFFFF"
                                Stroke="#D0C8E0"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Picker
                                ItemsSource="{Binding PetVM.Pets}"
                                SelectedItem="{Binding PetVM.SelectedPet}"
                                ItemDisplayBinding="{Binding Name}"
                                FontSize="14"
                                TextColor="#1C3D52"
                                Margin="10,0"/>
                        </Border>
                        <Label Text="{Binding MedicationVM.PetError}"
                               FontSize="11"
                               TextColor="#E83E5F"
                               IsVisible="{Binding MedicationVM.PetError, Converter={StaticResource StringToBoolConverter}}"/>
                    </VerticalStackLayout>

                    <!-- Food note (optional) -->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="NOTES (OPTIONAL)"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="#5A7990"/>
                        <Border BackgroundColor="#FFFFFF"
                                Stroke="#D0C8E0"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="e.g. with food, after meal…"
                                   Text="{Binding MedicationVM.MedicationDraft.Notes}"
                                   FontSize="14"
                                   TextColor="#1C3D52"
                                   PlaceholderColor="#A0B0BC"
                                   Margin="14,0"/>
                        </Border>
                    </VerticalStackLayout>

                </VerticalStackLayout>
                </ScrollView>

                <!-- ── ACTION BUTTONS (pinned footer) ── -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <!-- Cancel -->
                    <Border BackgroundColor="#40C4A8E0"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding MedicationVM.CancelMedicationCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancel"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#7A5D99"
                               HorizontalTextAlignment="Center"
                               Padding="0,13"/>
                    </Border>

                    <!-- Save / Override -->
                    <Border Grid.Column="1"
                            BackgroundColor="#9B6FCC"
                            StrokeThickness="0"
                            Opacity="{Binding MedicationVM.CanSaveMedication, Converter={StaticResource BoolToOpacityConverter}}"
                            IsEnabled="{Binding MedicationVM.CanSaveMedication}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#409B6FCC"
                                    Offset="0,3"
                                    Radius="8"
                                    Opacity="0.35"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding MedicationVM.SaveMedicationCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{Binding MedicationVM.SaveButtonText}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center"
                               Padding="0,13"/>
                    </Border>

                </Grid>

            </Grid>
        </Border>

    </Grid>

</ContentView>
