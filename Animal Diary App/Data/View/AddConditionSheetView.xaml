<?xml version="1.0" encoding="utf-8" ?>
<!--
    AddConditionSheetView
    ─────────────────────────────────────────────────────────
    Manage Pet's "add a condition" sheet. Lists the conditions the pet doesn't have
    yet; picking one either opens its setup sheet (diabetes/ckd/epilepsy) or adds it
    straight away. BindingContext is the ManagePetViewModel (set by the page).
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             x:Class="Animal_Diary_App.Data.View.AddConditionSheetView"
             x:Name="Root"
             InputTransparent="{Binding IsAddConditionSheetVisible, Converter={StaticResource InvertedBoolConverter}}">

    <controls:FelovaBottomSheet IsPresented="{Binding IsAddConditionSheetVisible}"
                                Title="{loc:Translate Manage_AddConditionTitle}"
                                Subtitle="{loc:Translate Manage_AddConditionSub}"
                                DismissCommand="{Binding CloseAddConditionCommand}">
        <controls:FelovaBottomSheet.SheetContent>

            <!-- CollectionView, not BindableLayout: BindableLayout is an attached
                 property that procedurally adds/removes children, and on Android it
                 fails to regenerate items when ItemsSource changes on a layout whose
                 handler was created while IsVisible=false (this sheet's hidden-until-
                 opened state). CollectionView drives a real RecyclerView with its own
                 adapter, which rebuilds correctly regardless of prior visibility. -->
            <VerticalStackLayout Padding="0,2,0,0">
              <CollectionView ItemsSource="{Binding AddConditionOptions}"
                              SelectionMode="None"
                              VerticalOptions="Start"
                              VerticalScrollBarVisibility="Never">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{StaticResource GlassSoft}"
                                Stroke="{StaticResource GlassLine}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 15,13,14,15"
                                Padding="14,13">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={x:Reference Root}, Path=BindingContext.PickAddConditionCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="13">
                                <Label Grid.Column="0" Text="{Binding Icon}" FontSize="22" VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14.5"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
              </CollectionView>
            </VerticalStackLayout>

        </controls:FelovaBottomSheet.SheetContent>
    </controls:FelovaBottomSheet>

</ContentView>
