<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             x:Class="Animal_Diary_App.Data.View.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#DCEBF5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:WeightToHeightConverter x:Key="WeightToHeightConverter"/>
            <helpers:WeightMaxConverter x:Key="WeightMaxConverter"/>
            <helpers:WeightMidConverter x:Key="WeightMidConverter"/>
            <helpers:WeightMinConverter x:Key="WeightMinConverter"/>
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Background -->
        <Image Source="hintergrund_blau.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               InputTransparent="True"
               Grid.RowSpan="2"/>

        <!-- Main Content -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="20,16,20,120"
                                 Spacing="18">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <VerticalStackLayout Spacing="2">

                        <!-- ? greeting binding -->
                        <Label Text="{loc:Translate Main_GreetingMorning}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#4A6172"
                               Opacity="0.7"/>

                    </VerticalStackLayout>

                    <!-- Settings button -->
                    <Border Grid.Column="1"
                            WidthRequest="38"
                            HeightRequest="38"
                            BackgroundColor="#55FFFFFF"
                            StrokeThickness="0"
                            HorizontalOptions="End"
                            VerticalOptions="Center">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="19"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.OpenSettingsCommand}"/>
                        </Border.GestureRecognizers>

                        <Label Text="⚙️"
                               FontSize="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                    </Border>

                </Grid>

                <!-- ACTIVE PET HERO -->

                <Border Padding="18"
                        BackgroundColor="#5B9BB8"
                        StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Brush="#40000000"
                                Offset="0,8"
                                Radius="18"
                                Opacity="0.35"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">

                        <!-- Avatar -->
                        <Grid WidthRequest="72"
                              HeightRequest="72">

                            <Border BackgroundColor="#30FFFFFF"
                                    Stroke="#55FFFFFF"
                                    StrokeThickness="2">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="36"/>
                                </Border.StrokeShape>

                                <!-- ? bind pet image -->
                                <Image Source="animal1.jpg"
                                       Aspect="AspectFill"/>
                            </Border>

                            <!-- Mood / health indicator -->
                            <Border WidthRequest="16"
                                    HeightRequest="16"
                                    BackgroundColor="#6DD39E"
                                    Stroke="#5B9BB8"
                                    StrokeThickness="2"
                                    HorizontalOptions="End"
                                    VerticalOptions="End">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>

                            </Border>

                        </Grid>

                        <!-- Pet Info -->
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="6"
                                             VerticalOptions="Center">

                            <Label Text="{Binding MainPageVM.ActivePet.Name}"
                                   FontSize="20"
                                   FontFamily="Georgia"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <Label FontSize="12"
                                   TextColor="White"
                                   Opacity="0.72">

                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding MainPageVM.ActivePet.Type}"/>
                                        <Span Text=" · "/>
                                        <Span Text="{Binding MainPageVM.ActivePet.Age}"/>
                                        <Span Text="{loc:Translate Common_YearsSeparator}"/>
                                        <Span Text="{Binding MainPageVM.LatestWeight}"/>
                                        <Span Text="{loc:Translate Common_KgSuffix}"/>
                                    </FormattedString>
                                </Label.FormattedText>

                            </Label>

                            <!-- Health Tags -->
                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        AlignItems="Start"
                                        JustifyContent="Start">

                                <!-- ? convert to bindable collection later -->
                                <Border BackgroundColor="#30FFFFFF"
                                        Padding="10,4"
                                        Margin="0,0,6,6"
                                        StrokeThickness="0">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20"/>
                                    </Border.StrokeShape>

                                    <Label Text="{loc:Translate Main_HealthyPlaceholder}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                </Border>

                                <Border BackgroundColor="#40F0C060"
                                        Padding="10,4"
                                        Margin="0,0,6,6"
                                        StrokeThickness="0">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="20"/>
                                    </Border.StrokeShape>

                                    <!-- ? medication reminder binding -->
                                    <Label Text="{loc:Translate Main_MedsPlaceholder}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="#7A4A00"/>
                                </Border>

                            </FlexLayout>

                        </VerticalStackLayout>

                    </Grid>

                </Border>

                <!-- QUICK STATS -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="14">

                    <!-- Latest Weight -->
                    <Border Padding="16"
                            BackgroundColor="#40FFFFFF"
                            Stroke="#50FFFFFF"
                            StrokeThickness="1">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{loc:Translate Main_Weight}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.5"
                                   TextColor="#2E6B85"/>

                            <Label Text="{Binding MainPageVM.LatestWeight, StringFormat='{0} kg'}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#1C3D52"/>

                            <!-- ? trend binding -->
                            <Label Text="{loc:Translate Main_StableThisWeek}"
                                   FontSize="11"
                                   TextColor="#6D8291"/>

                        </VerticalStackLayout>

                    </Border>

                    <!-- Mood -->
                    <Border Grid.Column="1"
                            Padding="16"
                            BackgroundColor="#40FFFFFF"
                            Stroke="#50FFFFFF"
                            StrokeThickness="1">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="6">

                            <Label Text="{loc:Translate Main_Mood}"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.5"
                                   TextColor="#2E6B85"/>

                            <!-- ? latest mood binding -->
                            <Label Text="{loc:Translate Main_HappyPlaceholder}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#1C3D52"/>

                            <!-- ? date binding -->
                            <Label Text="{loc:Translate Main_LoggedToday}"
                                   FontSize="11"
                                   TextColor="#6D8291"/>

                        </VerticalStackLayout>

                    </Border>

                </Grid>
                <VerticalStackLayout
                    IsVisible="{Binding MainPageVM.MoodTimeline.HasMoodData}">
                    <Label Text="{loc:Translate Main_MoodLabel}"
                           FontSize="10"
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"
                           TextColor="#2E6B85"/>

                    <!-- MOOD TIMELINE -->
                    <Border BackgroundColor="#40FFFFFF"
                            Stroke="#50FFFFFF"
                            StrokeThickness="1"
                            Padding="12,8"
                            StrokeShape="RoundRectangle 16">

                        <VerticalStackLayout Spacing="8">

                            <Label Text="{loc:Translate Main_Last30Days}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#2E6B85"/>

                            <FlexLayout Direction="Row"
                                        Wrap="NoWrap"
                                        AlignItems="Center"
                                        HeightRequest="26"
                                        BindableLayout.ItemsSource="{Binding MainPageVM.MoodTimeline.TimelineDays}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border HeightRequest="26"
                                                Margin="1,0"
                                                BackgroundColor="{Binding MoodColor}"
                                                StrokeThickness="0"
                                                FlexLayout.Grow="1"
                                                StrokeShape="RoundRectangle 3">

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MainPageVM.NavigateToMoodDateCommand}"
                                                    CommandParameter="{Binding Date}"/>
                                            </Border.GestureRecognizers>

                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>

                            </FlexLayout>

                        </VerticalStackLayout>

                    </Border>
                </VerticalStackLayout>


                <VerticalStackLayout Spacing="8"
                                     IsVisible="{Binding MainPageVM.MoodTimeline.HasMoodData, Converter={StaticResource InvertedBoolConverter}}"
                                     Padding="16"
                                     VerticalOptions="Start">
                    <Label Text="😊"
                           FontSize="32"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate Main_MoodEmptyState}"
                           FontSize="12"
                           TextColor="#6D8291"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- WEIGHT CHART -->
                <view:WeightChartView/>

                <VerticalStackLayout Spacing="10">

                    <Label Text="{loc:Translate Main_RecentActivity}"
                           FontSize="10"
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"
                           TextColor="#2E6B85"/>

                    <!-- This should eventually become a CollectionView -->
                    <!-- ? recent activity collection -->

                    <!-- Activity Card -->
                    <Border Padding="14"
                            BackgroundColor="#35FFFFFF"
                            Stroke="#45FFFFFF"
                            StrokeThickness="1">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">

                            <Border WidthRequest="42"
                                    HeightRequest="42"
                                    BackgroundColor="#30C4A8E0"
                                    StrokeThickness="0">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>

                                <Label Text="💊"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">

                                <!-- ? medication binding -->
                                <Label Text="{loc:Translate Main_MedicationGiven}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#1C3D52"/>

                                <!-- ? details binding -->
                                <Label Text="{loc:Translate Main_MedicationDetailPlaceholder}"
                                       FontSize="11"
                                       TextColor="#6D8291"/>

                            </VerticalStackLayout>

                            <!-- ? time binding -->
                            <Label Grid.Column="2"
                                   Text="08:00"
                                   FontSize="10"
                                   TextColor="#7B91A1"
                                   VerticalOptions="Start"/>

                        </Grid>

                    </Border>

                </VerticalStackLayout>



            </VerticalStackLayout>

        </ScrollView>

        <!-- BOTTOM NAVIGATION -->
        <Border Grid.Row="1"
                Margin="0"
                Padding="12,10,12,20"
                BackgroundColor="#E6C4A8E0"
                StrokeThickness="0"
                VerticalOptions="End">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#30000000"
                        Offset="0,-2"
                        Radius="10"
                        Opacity="0.18"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*">

                <!-- MAIN -->
                <Grid>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="2">

                        <Label Text="🏠"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="{loc:Translate Nav_Main}"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#4A1580"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- CALENDAR -->
                <Grid Grid.Column="1">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCalendarClicked"/>
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="2">

                        <Label Text="📅"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="{loc:Translate Nav_Calendar}"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#664A1580"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- PETS -->
                <Grid Grid.Column="2">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPetsClicked"/>
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="2">

                        <Label Text="🐾"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="{loc:Translate Nav_Pets}"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#664A1580"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

            </Grid>
        </Border>

        <!-- Settings panel overlay — last child renders on top of everything -->
        <view:SettingsPanelView Grid.RowSpan="2"
                                IsPanelOpen="{Binding SettingsVM.IsPanelOpen, Mode=TwoWay}"/>

    </Grid>

</ContentPage>