<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:MainViewModel"
             x:Class="Animal_Diary_App.Data.View.MainPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <helpers:MoodToHeightConverter x:Key="MoodToHeight"/>

            <!-- Frosted glass card surface (matches Journal) -->
            <Style x:Key="GlassCard"
                   TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{StaticResource Glass}"/>
                <Setter Property="Stroke"
                        Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness"
                        Value="1"/>
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 17,14,15,18"/>
                <Setter Property="Padding"
                        Value="16"/>
            </Style>

            <!-- Warm italic-serif section heading -->
            <Style x:Key="SerifHeading"
                   TargetType="Label">
                <Setter Property="FontFamily"
                        Value="{StaticResource FontSerifItalic}"/>
                <Setter Property="FontSize"
                        Value="17"/>
                <Setter Property="TextColor"
                        Value="{StaticResource Ink}"/>
            </Style>

            <!-- Small stat-card eyebrow -->
            <Style x:Key="StatLabel"
                   TargetType="Label">
                <Setter Property="FontFamily"
                        Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"
                        Value="10.5"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="CharacterSpacing"
                        Value="1.2"/>
                <Setter Property="TextColor"
                        Value="{StaticResource InkTertiary}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ================= TODAY ================= -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="22">

                <!-- 1 ── Header: greeting + handwritten aside + settings ── -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="1"
                                         VerticalOptions="Center">
                        <Label Text="{Binding MainPageVM.Greeting}"
                               FontFamily="{StaticResource FontSerif}"
                               FontSize="{StaticResource TypeH1}"
                               TextColor="{StaticResource Ink}"/>
                        <!-- rotating handwritten aside (set per load, Caveat) -->
                        <Label x:Name="AsideLabel"
                               FontFamily="{StaticResource FontHand}"
                               FontSize="18"
                               TextColor="{StaticResource TealDeep}"/>
                    </VerticalStackLayout>

                    <!-- Settings button -->
                    <Border Grid.Column="1"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20,19,19,20"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            SemanticProperties.Description="Settings">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.OpenSettingsCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="⚙️"
                               FontSize="17"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- 2 ── Active pet hero: precise care ring + avatar ── -->
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="3"
                                     Margin="0,6,0,0">

                    <Grid HorizontalOptions="Center"
                          WidthRequest="132"
                          HeightRequest="132">

                        <!-- Care-completion ring (DATA — precise, animated fill).
                             Progress = today's done/total from the same PendingEngine
                             snapshot the Journal's "Still to do" chips use. -->
                        <controls:ProgressRingView x:Name="CareRing"
                                                   WidthRequest="132"
                                                   HeightRequest="132"
                                                   Progress="{Binding MainPageVM.CareProgress}"
                                                   ProgressColor="{StaticResource Teal}"
                                                   TrackColor="{StaticResource TealLine}"
                                                   RingThickness="6"/>

                        <!-- Avatar — profile photo, or the type emoji fallback -->
                        <controls:PetAvatarView Diameter="108"
                                                FallbackFontSize="48"
                                                PhotoPath="{Binding MainPageVM.ActivePet.PhotoFullPath}"
                                                FallbackText="{Binding PetVM.ActivePetEmoji}"
                                                HorizontalOptions="Center"
                                                VerticalOptions="Center"/>
                    </Grid>

                    <!-- Pet name -->
                    <Label Text="{Binding MainPageVM.ActivePet.Name}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="{StaticResource TypeDisplay}"
                           TextColor="{StaticResource Ink}"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"/>

                    <!-- Meta line: type · age · weight (DATA — precise) -->
                    <Label HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="13.5"
                           TextColor="{StaticResource InkSecondary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span>
                                    <Span.Text>
                                        <MultiBinding Converter="{StaticResource PetTypeLocalizedConverter}">
                                            <Binding Path="MainPageVM.ActivePet.Type"/>
                                            <Binding Path="CurrentLanguage" Source="{x:Static loc:LocalizationManager.Instance}"/>
                                        </MultiBinding>
                                    </Span.Text>
                                </Span>
                                <Span Text=" · "/>
                                <Span Text="{Binding MainPageVM.ActivePet.AgeYears}"/>
                                <Span Text="{loc:Translate Common_YearsSeparator}"/>
                                <Span Text="{Binding MainPageVM.LatestWeight}"/>
                                <Span Text="{loc:Translate Common_KgSuffix}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>                    
                </VerticalStackLayout>

                <!-- 3 ── Next up: first pending med dose or care-plan tracker ── -->
                <Grid Margin="0,4,0,0">
                    <Border x:Name="NextMedCard"
                            Rotation="-1.2"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16,13,14,15"
                            Padding="15,14">
                        <Border.Shadow>
                            <Shadow Brush="#0D3A3C"
                                    Offset="0,6"
                                    Radius="18"
                                    Opacity="0.10"/>
                        </Border.Shadow>

                        <!-- contents counter-rotated so the readout stays level -->
                        <Grid Rotation="1.2"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="14">

                            <Border WidthRequest="44"
                                    HeightRequest="44"
                                    BackgroundColor="{StaticResource HoneyWarmTint}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 14"
                                    VerticalOptions="Center">
                                <Label x:Name="NextMedIcon"
                                       Text="💊"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="{loc:Translate Main_NextMedEyebrow}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="10.5"
                                       FontAttributes="Bold"
                                       CharacterSpacing="1.1"
                                       TextColor="{StaticResource InkTertiary}"/>
                                <Label x:Name="NextMedName"
                                       Text="{loc:Translate Main_MedsPlaceholder}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14.5"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label x:Name="NextMedDetail"
                                       Text="{loc:Translate Main_MedicationDetailPlaceholder}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12.5"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2"
                                                 Spacing="6"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="End">
                                <Label x:Name="NextMedTime"
                                       Text="08:00"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource InkSecondary}"
                                       HorizontalOptions="End"/>
                                <Button x:Name="NextMedAction"
                                        Text="{loc:Translate Journal_MarkGiven}"
                                        IsVisible="False"
                                        FontFamily="{StaticResource FontSans}"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        HeightRequest="34"
                                        Padding="14,0"
                                        CornerRadius="11"
                                        BackgroundColor="{StaticResource Teal}"
                                        TextColor="{StaticResource White}"
                                        Clicked="OnNextUpAction"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Paperclip overlapping the top-left corner (chrome) -->
                    <Path Data="M7 3 L7 17 Q7 21 11 21 Q15 21 15 17 L15 7 Q15 4 12 4 Q10 4 10 7 L10 15"
                          Stroke="{StaticResource InkTertiary}"
                          StrokeThickness="1.6"
                          StrokeLineCap="Round"
                          StrokeLineJoin="Round"
                          Rotation="-24"
                          WidthRequest="22"
                          HeightRequest="24"
                          HorizontalOptions="Start"
                          VerticalOptions="Start"
                          Margin="10,-6,0,0"/>
                </Grid>

                <!-- 4 ── Quick stats: weight + mood ── -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <!-- Weight (DATA — precise serif number) -->
                    <Border Style="{StaticResource GlassCard}"
                            StrokeShape="RoundRectangle 16,13,14,15"
                            Padding="16,16,16,14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate Main_Weight}"
                                   Style="{StaticResource StatLabel}"/>

                            <!-- The pet's most recent weigh-in and when it was taken.
                                 The chip states the date, never a judgement on the
                                 value — the app can't know what a change means. -->
                            <Label IsVisible="{Binding MainPageVM.HasLoggedWeight}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding MainPageVM.LatestWeight}"
                                              FontFamily="{StaticResource FontSerif}"
                                              FontSize="27"
                                              TextColor="{StaticResource Ink}"/>
                                        <Span Text=" kg"
                                              FontFamily="{StaticResource FontSans}"
                                              FontSize="14"
                                              TextColor="{StaticResource InkSecondary}"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Border BackgroundColor="{StaticResource TealTint}"
                                    Padding="9,4"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 999"
                                    HorizontalOptions="Start"
                                    IsVisible="{Binding MainPageVM.HasLoggedWeight}">
                                <Label Text="{Binding MainPageVM.LatestWeightLoggedLabel}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TealDeep}"/>
                            </Border>

                            <!-- Empty state: no weigh-in for this pet yet. -->
                            <Label Text="{loc:Translate Main_WeightEmptyCard}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="12"
                                   LineHeight="1.35"
                                   TextColor="{StaticResource InkSecondary}"
                                   IsVisible="{Binding MainPageVM.HasLoggedWeight, Converter={StaticResource InvertedBoolConverter}}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Mood -->
                    <Border Grid.Column="1"
                            Style="{StaticResource GlassCard}"
                            StrokeShape="RoundRectangle 13,16,15,14"
                            Padding="16,16,16,14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate Main_Mood}"
                                   Style="{StaticResource StatLabel}"/>

                            <!-- The pet's most recent mood — swatch, word and when it
                                 was logged all come from the same entry. -->
                            <HorizontalStackLayout Spacing="7"
                                                   IsVisible="{Binding MainPageVM.HasLoggedMood}">
                                <Border WidthRequest="11"
                                        HeightRequest="11"
                                        BackgroundColor="{Binding MainPageVM.LatestMoodColor}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 6"
                                        VerticalOptions="Center"/>
                                <Label Text="{Binding MainPageVM.LatestMoodLabel}"
                                       FontFamily="{StaticResource FontSerif}"
                                       FontSize="20"
                                       TextColor="{StaticResource Ink}"/>
                            </HorizontalStackLayout>
                            <Border BackgroundColor="{StaticResource TealTint}"
                                    Padding="9,4"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 999"
                                    HorizontalOptions="Start"
                                    IsVisible="{Binding MainPageVM.HasLoggedMood}">
                                <Label Text="{Binding MainPageVM.LatestMoodLoggedLabel}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TealDeep}"/>
                            </Border>

                            <!-- Empty state: nothing logged for this pet yet. -->
                            <Label Text="{loc:Translate Main_MoodEmptyCard}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="12"
                                   LineHeight="1.35"
                                   TextColor="{StaticResource InkSecondary}"
                                   IsVisible="{Binding MainPageVM.HasLoggedMood, Converter={StaticResource InvertedBoolConverter}}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- 5 ── Mood ribbon (DATA — accurate heights) ── -->
                <VerticalStackLayout Spacing="12"
                                     IsVisible="{Binding MainPageVM.MoodTimeline.HasMoodData}">

                    <Label Text="{loc:Translate Main_MoodMonthHeading}"
                           Style="{StaticResource SerifHeading}"/>

                    <Border Style="{StaticResource GlassCard}">
                        <VerticalStackLayout Spacing="12">

                            <Label Text="{loc:Translate Main_Last30Days}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource InkTertiary}"/>

                            <FlexLayout Direction="Row"
                                        Wrap="NoWrap"
                                        AlignItems="End"
                                        HeightRequest="30"
                                        BindableLayout.ItemsSource="{Binding MainPageVM.MoodTimeline.TimelineDays}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vms:MoodTimelineDay">
                                        <!-- Height encodes the real mood value; only the
                                             corner radius is decorative. -->
                                        <Border HeightRequest="{Binding Mood, Converter={StaticResource MoodToHeight}}"
                                                Margin="1.5,0"
                                                BackgroundColor="{Binding MoodColor}"
                                                StrokeThickness="0"
                                                FlexLayout.Grow="1"
                                                VerticalOptions="End"
                                                StrokeShape="RoundRectangle 4,3,4,3">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MainPageVM.NavigateToMoodDateCommand}"
                                                    CommandParameter="{Binding Date}"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>

                            <!-- Legend (colours mirror MoodLevel.GetColor — kept exact) -->
                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        AlignItems="Center">
                                <HorizontalStackLayout Spacing="5"
                                                       Margin="0,0,12,0">
                                    <Border WidthRequest="8"
                                            HeightRequest="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            BackgroundColor="{StaticResource MGreat}"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Excellent}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="10.5"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5"
                                                       Margin="0,0,12,0">
                                    <Border WidthRequest="8"
                                            HeightRequest="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            BackgroundColor="{StaticResource MGood}"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Good}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="10.5"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5"
                                                       Margin="0,0,12,0">
                                    <Border WidthRequest="8"
                                            HeightRequest="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            BackgroundColor="{StaticResource MOkay}"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Neutral}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="10.5"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5"
                                                       Margin="0,0,12,0">
                                    <Border WidthRequest="8"
                                            HeightRequest="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            BackgroundColor="{StaticResource MLow}"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Bad}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="10.5"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5"
                                                       Margin="0,0,12,0">
                                    <Border WidthRequest="8"
                                            HeightRequest="8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3"
                                            BackgroundColor="{StaticResource MUnwell}"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_VeryBad}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="10.5"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Mood empty state -->
                <VerticalStackLayout Spacing="8"
                                     Padding="16"
                                     IsVisible="{Binding MainPageVM.MoodTimeline.HasMoodData, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="😊"
                           FontSize="32"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate Main_MoodEmptyState}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12"
                           TextColor="{StaticResource InkSecondary}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- 6 ── Weight chart (DATA — precise line chart) ── -->
                <view:WeightChartView/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= TAB BAR ================= -->
        <controls:BottomNavigation Grid.Row="1"
                                   ActiveTab="Main"/>

        <!-- Confirm micro-interaction overlay (bubbles) -->
        <AbsoluteLayout x:Name="EffectLayer"
                        Grid.RowSpan="2"
                        InputTransparent="True"
                        IsClippedToBounds="False"/>

        <!-- Toast (warm confirmation pill) -->
        <Border x:Name="Toast"
                Grid.RowSpan="2"
                Opacity="0"
                InputTransparent="True"
                BackgroundColor="{StaticResource Ink}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18,15,14,17"
                Rotation="-0.5"
                Padding="14,11"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,92">
            <Border.Shadow>
                <Shadow Brush="#0D3A3C"
                        Offset="0,12"
                        Radius="34"
                        Opacity="0.20"/>
            </Border.Shadow>
            <HorizontalStackLayout Spacing="8"
                                   VerticalOptions="Center">
                <Label Text="✓"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{StaticResource MGreat}"
                       VerticalOptions="Center"/>
                <Label x:Name="ToastLabel"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <!-- Cloud Features sheet (FelovaBottomSheet; click-through while closed) -->
        <view:CloudSheetView Grid.RowSpan="2"
                             BindingContext="{Binding CloudVM}"/>

        <!-- Settings panel overlay — last child renders on top of everything -->
        <view:SettingsPanelView Grid.RowSpan="2"
                                IsPanelOpen="{Binding SettingsVM.IsPanelOpen, Mode=TwoWay}"/>

    </Grid>

</ContentPage>
