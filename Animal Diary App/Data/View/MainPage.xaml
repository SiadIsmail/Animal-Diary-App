<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.MainPage">

    <Grid>

        <!-- Background -->
        <Image Source="hintergrund_blau.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               InputTransparent="True"/>

        <!-- Main Content -->
        <ScrollView>

            <VerticalStackLayout Padding="24,20"
                                 Spacing="24">

                <CollectionView ItemsSource="{Binding PetVM.Pets}"
                                SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <Border Padding="20"
                                    Background="#AA5E72CC"
                                    Stroke="#DDDDDD">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20"/>
                                </Border.StrokeShape>

                                <Border.Shadow>
                                    <Shadow Opacity="0.3"
                                            Radius="10"
                                            Offset="0,4"/>
                                </Border.Shadow>

                                <VerticalStackLayout Spacing="12"
                                                     HorizontalOptions="Center">

                                    <Image Source="animal1.jpg"
                                           WidthRequest="200"
                                           HeightRequest="200"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center"/>

                                    <Label Text="{Binding Name}"
                                           FontSize="24"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"/>

                                    <Label Text="{Binding Type}"
                                           FontSize="16"
                                           TextColor="#666666"
                                           HorizontalTextAlignment="Center"/>

                                    <Label Text="{Binding Age, StringFormat='{0} years old'}"
                                           FontSize="16"
                                           TextColor="#666666"
                                           HorizontalTextAlignment="Center"/>

                                </VerticalStackLayout>

                            </Border>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

                <Border Padding="16"
                        Background="#AA5E72CC"
                        Stroke="#DDDDDD">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow Opacity="0.3"
                                Radius="10"
                                Offset="0,4"/>
                    </Border.Shadow>

                    <Label Text="{Binding MainPageVM.LatestWeight, StringFormat='Latest weight: {0} kg'}"
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="#666666"/>

                </Border>

            </VerticalStackLayout>

        </ScrollView>

        <!-- Bottom Navigation -->
        <Grid RowDefinitions="*,Auto"
              ColumnDefinitions="*,*"
              VerticalOptions="End">

            <Button Text="Main"
                    Grid.Row="1"
                    Grid.Column="0"/>

            <Button Text="Calendar"
                    Clicked="OnCalendarClicked"
                    Grid.Row="1"
                    Grid.Column="1"/>

        </Grid>

    </Grid>

</ContentPage>