<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="24,20"
                             Spacing="20">
            <CollectionView ItemsSource="{Binding Pets}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14"
                              VerticalOptions="Center">
                            <VerticalStackLayout Padding="24,20"
                                                 Spacing="20">
                                <Label Text="{Binding Name}"
                                       FontSize="22"
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding Type}"
                                       FontSize="15"
                                       TextColor="#666666"/>

                                <Label Text="{Binding Age}"
                                       FontSize="15"
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <HorizontalStackLayout VerticalOptions="End">
                <Button Text="Main"/>
                <Button Text="Calendar"
                        Clicked="OnCalendarClicked"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>