<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:view="clr-namespace:Animal_Diary_App.Data.View"
             x:Class="Animal_Diary_App.Data.View.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Paper}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter"/>

            <!-- Felova card surface -->
            <Style x:Key="CardSurface" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Card}"/>
                <Setter Property="Stroke" Value="{StaticResource Line}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 22"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

            <!-- Uppercase section eyebrow -->
            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.3"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>

            <!-- Small stat-card label -->
            <Style x:Key="StatLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="10.5"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.2"/>
                <Setter Property="TextColor" Value="{StaticResource InkTertiary}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- ================= TODAY ================= -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="22">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <Label Text="{loc:Translate Main_GreetingMorning}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="{StaticResource TypeH1}"
                           TextColor="{StaticResource Ink}"
                           VerticalOptions="Center"/>

                    <!-- Settings button -->
                    <Border Grid.Column="1"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="{StaticResource Card}"
                            Stroke="{StaticResource Line}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            HorizontalOptions="End"
                            VerticalOptions="Center">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.OpenSettingsCommand}"/>
                        </Border.GestureRecognizers>

                        <Label Text="⚙️"
                               FontSize="17"
                               TextColor="{StaticResource InkSecondary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- ACTIVE PET HERO -->
                <VerticalStackLayout HorizontalOptions="Center"
                                     Spacing="3"
                                     Margin="0,6,0,0">

                    <!-- Ring + avatar -->
                    <Grid HorizontalOptions="Center"
                          WidthRequest="132"
                          HeightRequest="132">

                        <!-- Progress ring (decorative) -->
                        <Border WidthRequest="132"
                                HeightRequest="132"
                                BackgroundColor="Transparent"
                                Stroke="{StaticResource SageTint}"
                                StrokeThickness="5"
                                StrokeShape="RoundRectangle 66"/>

                        <!-- Avatar -->
                        <Border WidthRequest="108"
                                HeightRequest="108"
                                Stroke="{StaticResource ViolaLine}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 54"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">

                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#EFE9F8" Offset="0"/>
                                    <GradientStop Color="#E3D9F2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Image Source="animal1.jpg"
                                   Aspect="AspectFill"/>
                        </Border>
                    </Grid>

                    <!-- Pet name -->
                    <Label Text="{Binding MainPageVM.ActivePet.Name}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="{StaticResource TypeDisplay}"
                           TextColor="{StaticResource Ink}"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"/>

                    <!-- Meta line: type · age · weight -->
                    <Label HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="13.5"
                           TextColor="{StaticResource InkSecondary}">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding MainPageVM.ActivePet.Type}"/>
                                <Span Text=" · "/>
                                <Span Text="{Binding MainPageVM.ActivePet.Age}"/>
                                <Span Text="{loc:Translate Common_YearsSeparator}"/>
                                <Span Text="{Binding MainPageVM.LatestWeight}"/>
                                <Span Text="{loc:Translate Common_KgSuffix}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <!-- Health tags -->
                    <FlexLayout Wrap="Wrap"
                                Direction="Row"
                                JustifyContent="Center"
                                AlignItems="Center"
                                Margin="0,10,0,0">

                        <Border BackgroundColor="{StaticResource SageTint}"
                                Padding="10,4"
                                Margin="3"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999">
                            <Label Text="{loc:Translate Main_HealthyPlaceholder}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource SageDeep}"/>
                        </Border>

                        <Border BackgroundColor="{StaticResource HoneyTint}"
                                Padding="10,4"
                                Margin="3"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999">
                            <Label Text="{loc:Translate Main_MedsPlaceholder}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource HoneyDeep}"/>
                        </Border>
                    </FlexLayout>
                </VerticalStackLayout>

                <!-- NEXT-UP MEDICATION -->
                <Border Style="{StaticResource CardSurface}"
                        Padding="15,14">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">

                        <Border WidthRequest="44"
                                HeightRequest="44"
                                BackgroundColor="{StaticResource HoneyTint}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14"
                                VerticalOptions="Center">
                            <Label Text="💊"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="{loc:Translate Main_MedsPlaceholder}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="14.5"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Ink}"/>
                            <Label Text="{loc:Translate Main_MedicationDetailPlaceholder}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="12.5"
                                   TextColor="{StaticResource InkSecondary}"/>
                        </VerticalStackLayout>

                        <Label Grid.Column="2"
                               Text="›"
                               FontSize="24"
                               TextColor="{StaticResource InkTertiary}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- QUICK STATS -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">

                    <!-- Weight -->
                    <Border Style="{StaticResource CardSurface}"
                            Padding="16,16,16,14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate Main_Weight}"
                                   Style="{StaticResource StatLabel}"/>

                            <Label TextColor="{StaticResource Ink}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding MainPageVM.LatestWeight}"
                                              FontFamily="{StaticResource FontSerif}"
                                              FontSize="27"/>
                                        <Span Text=" kg"
                                              FontFamily="{StaticResource FontSans}"
                                              FontSize="14"
                                              TextColor="{StaticResource InkSecondary}"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Trend (placeholder) -->
                            <Border BackgroundColor="{StaticResource SageTint}"
                                    Padding="9,4"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 999"
                                    HorizontalOptions="Start">
                                <Label Text="{loc:Translate Main_StableThisWeek}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SageDeep}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Mood -->
                    <Border Grid.Column="1"
                            Style="{StaticResource CardSurface}"
                            Padding="16,16,16,14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate Main_Mood}"
                                   Style="{StaticResource StatLabel}"/>

                            <HorizontalStackLayout Spacing="7">
                                <Border WidthRequest="11"
                                        HeightRequest="11"
                                        BackgroundColor="{StaticResource Sage}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 6"
                                        VerticalOptions="Center"/>
                                <Label Text="{loc:Translate Main_HappyPlaceholder}"
                                       FontFamily="{StaticResource FontSerif}"
                                       FontSize="20"
                                       TextColor="{StaticResource Ink}"/>
                            </HorizontalStackLayout>

                            <Border BackgroundColor="{StaticResource SageTint}"
                                    Padding="9,4"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 999"
                                    HorizontalOptions="Start">
                                <Label Text="{loc:Translate Main_LoggedToday}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource SageDeep}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- MOOD RIBBON -->
                <VerticalStackLayout Spacing="12"
                                     IsVisible="{Binding MainPageVM.MoodTimeline.HasMoodData}">

                    <Label Text="{loc:Translate Main_MoodLabel}"
                           Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource CardSurface}">
                        <VerticalStackLayout Spacing="12">

                            <Label Text="{loc:Translate Main_Last30Days}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource InkTertiary}"/>

                            <FlexLayout Direction="Row"
                                        Wrap="NoWrap"
                                        AlignItems="End"
                                        HeightRequest="30"
                                        BindableLayout.ItemsSource="{Binding MainPageVM.MoodTimeline.TimelineDays}">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border HeightRequest="30"
                                                Margin="1.5,0"
                                                BackgroundColor="{Binding MoodColor}"
                                                StrokeThickness="0"
                                                FlexLayout.Grow="1"
                                                StrokeShape="RoundRectangle 4">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MainPageVM.NavigateToMoodDateCommand}"
                                                    CommandParameter="{Binding Date}"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>

                            <!-- Legend (colors mirror MoodLevel.GetColor) -->
                            <FlexLayout Wrap="Wrap"
                                        Direction="Row"
                                        AlignItems="Center">

                                <HorizontalStackLayout Spacing="5" Margin="0,0,12,0">
                                    <Border WidthRequest="8" HeightRequest="8" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3" BackgroundColor="#2D5016"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Excellent}"
                                           FontFamily="{StaticResource FontSans}" FontSize="10.5"
                                           FontAttributes="Bold" TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="5" Margin="0,0,12,0">
                                    <Border WidthRequest="8" HeightRequest="8" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3" BackgroundColor="#4CAF50"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Good}"
                                           FontFamily="{StaticResource FontSans}" FontSize="10.5"
                                           FontAttributes="Bold" TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="5" Margin="0,0,12,0">
                                    <Border WidthRequest="8" HeightRequest="8" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3" BackgroundColor="#FFC107"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Neutral}"
                                           FontFamily="{StaticResource FontSans}" FontSize="10.5"
                                           FontAttributes="Bold" TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="5" Margin="0,0,12,0">
                                    <Border WidthRequest="8" HeightRequest="8" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3" BackgroundColor="#FF9800"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_Bad}"
                                           FontFamily="{StaticResource FontSans}" FontSize="10.5"
                                           FontAttributes="Bold" TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="5" Margin="0,0,12,0">
                                    <Border WidthRequest="8" HeightRequest="8" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3" BackgroundColor="#F44336"
                                            VerticalOptions="Center"/>
                                    <Label Text="{loc:Translate Mood_VeryBad}"
                                           FontFamily="{StaticResource FontSans}" FontSize="10.5"
                                           FontAttributes="Bold" TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- MOOD EMPTY STATE -->
                <VerticalStackLayout Spacing="8"
                                     Padding="16"
                                     IsVisible="{Binding MainPageVM.MoodTimeline.HasMoodData, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="😊"
                           FontSize="32"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate Main_MoodEmptyState}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12"
                           TextColor="{StaticResource InkSecondary}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- WEIGHT CHART -->
                <view:WeightChartView/>

                <!-- RECENT ACTIVITY -->
                <VerticalStackLayout Spacing="12">

                    <Label Text="{loc:Translate Main_RecentActivity}"
                           Style="{StaticResource SectionLabel}"/>

                    <Border Style="{StaticResource CardSurface}"
                            Padding="14">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="12">

                            <Border WidthRequest="42"
                                    HeightRequest="42"
                                    BackgroundColor="{StaticResource ViolaTint}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    VerticalOptions="Center">
                                <Label Text="💊"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="{loc:Translate Main_MedicationGiven}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="13.5"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Text="{loc:Translate Main_MedicationDetailPlaceholder}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="12"
                                       TextColor="{StaticResource InkSecondary}"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="08:00"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Start"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= TAB BAR ================= -->
        <Border Grid.Row="1"
                Margin="16,0,16,16"
                Padding="7"
                BackgroundColor="{StaticResource Card}"
                Stroke="{StaticResource Line}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                VerticalOptions="End">

            <Border.Shadow>
                <Shadow Brush="#241E2E"
                        Offset="0,10"
                        Radius="24"
                        Opacity="0.16"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*">

                <!-- MAIN (active) -->
                <Border BackgroundColor="{StaticResource ViolaTint}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 17"
                        Padding="0,8">
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="3">
                        <Label Text="🏠"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Main}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource ViolaDeep}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- CALENDAR -->
                <Grid Grid.Column="1"
                      Padding="0,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCalendarClicked"/>
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="3">
                        <Label Text="📅"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Calendar}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- PETS -->
                <Grid Grid.Column="2"
                      Padding="0,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPetsClicked"/>
                    </Grid.GestureRecognizers>

                    <VerticalStackLayout HorizontalOptions="Center"
                                         Spacing="3">
                        <Label Text="🐾"
                               FontSize="20"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Pets}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Border>

        <!-- Settings panel overlay — last child renders on top of everything -->
        <view:SettingsPanelView Grid.RowSpan="2"
                                IsPanelOpen="{Binding SettingsVM.IsPanelOpen, Mode=TwoWay}"/>

    </Grid>

</ContentPage>
