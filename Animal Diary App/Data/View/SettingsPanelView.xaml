<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             x:Class="Animal_Diary_App.Data.View.SettingsPanelView">

    <Grid x:Name="RootOverlay"
          IsVisible="False">

        <!-- Dimming overlay — tap to close -->
        <BoxView x:Name="DimmingOverlay"
                 BackgroundColor="#000000"
                 Opacity="0"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Settings panel — slides in from the right -->
        <Border x:Name="SettingsPanel"
                WidthRequest="290"
                HorizontalOptions="End"
                VerticalOptions="Fill"
                BackgroundColor="#EDE4F7"
                StrokeThickness="0"
                TranslationX="300">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,0,0,24"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#50000000"
                        Offset="-6,0"
                        Radius="24"
                        Opacity="0.35"/>
            </Border.Shadow>

            <VerticalStackLayout Padding="24,52,24,36"
                                 Spacing="0">

                <!-- Header row -->
                <Grid ColumnDefinitions="*,Auto"
                      Margin="0,0,0,20">

                    <Label Text="{loc:Translate Settings_Title}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#1C3D52"
                           VerticalOptions="Center"/>

                    <!-- Close button -->
                    <Border Grid.Column="1"
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="#25000000"
                            StrokeThickness="0"
                            VerticalOptions="Center">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseTapped"/>
                        </Border.GestureRecognizers>

                        <Label Text="✕"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#4A6172"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                    </Border>

                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         BackgroundColor="#25000000"
                         Margin="0,0,0,28"/>

                <!-- ── LANGUAGE SECTION ── -->
                <Label Text="{loc:Translate Settings_LanguageSection}"
                       FontSize="10"
                       FontAttributes="Bold"
                       CharacterSpacing="1.5"
                       TextColor="#7B91A1"
                       Margin="0,0,0,12"/>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      Margin="0,0,0,28">

                    <!-- Deutsch -->
                    <Border Grid.Column="0"
                            BackgroundColor="#40FFFFFF"
                            Stroke="#60FFFFFF"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            Padding="0,12">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding SettingsVM.IsGerman}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#809B6FCC"/>
                                <Setter Property="Stroke" Value="#B39B6FCC"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.SetLanguageCommand}"
                                                  CommandParameter="de"/>
                        </Border.GestureRecognizers>
                        <Label Text="🇩🇪 Deutsch"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1C3D52"
                               HorizontalTextAlignment="Center"/>
                    </Border>

                    <!-- English -->
                    <Border Grid.Column="1"
                            BackgroundColor="#40FFFFFF"
                            Stroke="#60FFFFFF"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            Padding="0,12">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding SettingsVM.IsEnglish}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="#809B6FCC"/>
                                <Setter Property="Stroke" Value="#B39B6FCC"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.SetLanguageCommand}"
                                                  CommandParameter="en"/>
                        </Border.GestureRecognizers>
                        <Label Text="🇬🇧 English"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#1C3D52"
                               HorizontalTextAlignment="Center"/>
                    </Border>

                </Grid>

                <!-- Section label -->
                <Label Text="{loc:Translate Settings_DataSection}"
                       FontSize="10"
                       FontAttributes="Bold"
                       CharacterSpacing="1.5"
                       TextColor="#7B91A1"
                       Margin="0,0,0,12"/>

                <!-- Delete All Data row -->
                <Border BackgroundColor="#FFEEEE"
                        StrokeThickness="1"
                        Stroke="#FFCCCC"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,14">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SettingsVM.DeleteAllDataCommand}"/>
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="14">

                        <Border WidthRequest="42"
                                HeightRequest="42"
                                BackgroundColor="#20FF0000"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                VerticalOptions="Center">

                            <Label Text="🗑️"
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>

                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             VerticalOptions="Center">

                            <Label Text="{loc:Translate Settings_DeleteAllData}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#C0392B"/>

                            <Label Text="{loc:Translate Settings_ResetSubtitle}"
                                   FontSize="11"
                                   TextColor="#D07070"/>

                        </VerticalStackLayout>

                    </Grid>

                </Border>

            </VerticalStackLayout>

        </Border>

    </Grid>

</ContentView>
