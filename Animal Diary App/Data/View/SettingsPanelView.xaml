<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             x:Class="Animal_Diary_App.Data.View.SettingsPanelView">

    <Grid x:Name="RootOverlay"
          IsVisible="False">

        <!-- Dimming overlay — tap to close -->
        <BoxView x:Name="DimmingOverlay"
                 BackgroundColor="#0D3A3C"
                 Opacity="0"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped"/>
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Settings panel — slides in from the right -->
        <Border x:Name="SettingsPanel"
                WidthRequest="290"
                HorizontalOptions="End"
                VerticalOptions="Fill"
                BackgroundColor="{StaticResource Paper}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,0,0,24"
                TranslationX="300">

            <VerticalStackLayout Padding="24,52,24,36" Spacing="0">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                    <Label Text="{loc:Translate Settings_Title}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="24"
                           TextColor="{StaticResource Ink}"
                           VerticalOptions="Center"/>

                    <Border Grid.Column="1"
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="✕"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource InkSecondary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource GlassLine}"
                         Margin="0,0,0,28"/>

                <!-- ── LANGUAGE ── -->
                <Label Text="{loc:Translate Settings_LanguageSection}"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="1.3"
                       TextColor="{StaticResource InkTertiary}"
                       Margin="0,0,0,12"/>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      Margin="0,0,0,28">

                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            Padding="0,12">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding SettingsVM.IsGerman}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke" Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.SetLanguageCommand}" CommandParameter="de"/>
                        </Border.GestureRecognizers>
                        <Label Text="🇩🇪 Deutsch"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Ink}"
                               HorizontalTextAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14"
                            Padding="0,12">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding SettingsVM.IsEnglish}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke" Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SettingsVM.SetLanguageCommand}" CommandParameter="en"/>
                        </Border.GestureRecognizers>
                        <Label Text="🇬🇧 English"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Ink}"
                               HorizontalTextAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- ── DATA ── -->
                <Label Text="{loc:Translate Settings_DataSection}"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="11"
                       FontAttributes="Bold"
                       CharacterSpacing="1.3"
                       TextColor="{StaticResource InkTertiary}"
                       Margin="0,0,0,12"/>

                <Border BackgroundColor="{StaticResource ClayTint}"
                        StrokeThickness="1"
                        Stroke="#EFD3CE"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SettingsVM.DeleteAllDataCommand}"/>
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border WidthRequest="42"
                                HeightRequest="42"
                                BackgroundColor="#F2DAD6"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                VerticalOptions="Center">
                            <Label Text="🗑️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Translate Settings_DeleteAllData}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Clay}"/>
                            <Label Text="{loc:Translate Settings_ResetSubtitle}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11"
                                   TextColor="#B07B76"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentView>
