<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             x:Class="Animal_Diary_App.Data.View.LoadingPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#C4E6E3">

    <Grid>

        <!-- Water background — same rockpool wash as every other screen -->
        <controls:WaterBackground/>

        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="18">

            <!-- Felova wordmark (current brand mark — no separate logo asset) -->
            <Label Text="Felova"
                   FontFamily="{StaticResource FontSerif}"
                   FontSize="{StaticResource TypeDisplay}"
                   TextColor="{StaticResource Ink}"
                   HorizontalTextAlignment="Center"/>

            <ActivityIndicator IsRunning="True"
                               Color="{StaticResource Teal}"
                               HeightRequest="34"
                               WidthRequest="34"/>

            <Label Text="{loc:Translate Loading_Message}"
                   FontFamily="{StaticResource FontHand}"
                   FontSize="19"
                   TextColor="{StaticResource TealDeep}"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
