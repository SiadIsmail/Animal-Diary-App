<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.WeightChartView">

    <VerticalStackLayout Spacing="12">
        <!-- Header -->
        <Label Text="WEIGHT TREND"
               FontSize="11"
               FontAttributes="Bold"
               TextColor="#5A7990"/>

        <!-- Chart Container -->
        <Border BackgroundColor="#40FFFFFF"
                Stroke="#50FFFFFF"
                StrokeThickness="1"
                Padding="16"
                StrokeShape="RoundRectangle 20">

            <Grid RowDefinitions="*,Auto"
                  ColumnDefinitions="Auto,*"
                  RowSpacing="8"
                  ColumnSpacing="8">

                <!-- Y-Axis Labels -->
                <VerticalStackLayout Grid.Row="0"
                                     Grid.Column="0"
                                     Spacing="0"
                                     VerticalOptions="Fill"
                                     Padding="0,0,8,0">

                    <Label Text="{Binding MainPageVM.WeightChartData, Converter={StaticResource WeightMaxConverter}}"
                           FontSize="9"
                           TextColor="#6D8291"
                           VerticalOptions="Start"
                           HorizontalTextAlignment="End"/>

                    <Label Text="{Binding MainPageVM.WeightChartData, Converter={StaticResource WeightMidConverter}}"
                           FontSize="9"
                           TextColor="#6D8291"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="End"/>

                    <Label Text="{Binding MainPageVM.WeightChartData, Converter={StaticResource WeightMinConverter}}"
                           FontSize="9"
                           TextColor="#6D8291"
                           VerticalOptions="End"
                           HorizontalTextAlignment="End"/>
                </VerticalStackLayout>

                <!-- Chart Area -->
                <Grid Grid.Row="0"
                      Grid.Column="1"
                      RowDefinitions="*"
                      ColumnDefinitions="*"
                      HeightRequest="120">

                    <!-- Grid Lines -->
                    <BoxView BackgroundColor="#E0E0E0"
                             Opacity="0.2"
                             VerticalOptions="Fill"
                             HorizontalOptions="Fill"/>

                    <!-- Data Points -->
                    <CollectionView ItemsSource="{Binding MainPageVM.WeightChartData}"
                                    SelectionMode="None"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="2"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="0"
                                                     HorizontalOptions="Fill"
                                                     VerticalOptions="Fill">

                                    <!-- Bar -->
                                    <BoxView BackgroundColor="#5B9BB8"
                                             HeightRequest="{Binding Value, Converter={StaticResource WeightToHeightConverter}}"
                                             VerticalOptions="End"
                                             CornerRadius="2"/>

                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </Grid>

                <!-- X-Axis Labels -->
                <ScrollView Grid.Row="1"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">

                    <HorizontalStackLayout Spacing="2"
                                           BindableLayout.ItemsSource="{Binding MainPageVM.WeightChartData}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding DateLabel}"
                                       FontSize="8"
                                       TextColor="#6D8291"
                                       WidthRequest="24"
                                       HorizontalTextAlignment="Center"/>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>

                </ScrollView>

            </Grid>

        </Border>

        <!-- No Data State -->
        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding MainPageVM.HasSufficientWeightData, Converter={StaticResource InvertedBoolConverter}}"
                             Padding="16"
                             VerticalOptions="Center">

            <Label Text="📊"
                   FontSize="32"
                   HorizontalTextAlignment="Center"/>

            <Label Text="Add weight entries to see trends"
                   FontSize="12"
                   TextColor="#6D8291"
                   HorizontalTextAlignment="Center"/>

        </VerticalStackLayout>

    </VerticalStackLayout>

</ContentView>
