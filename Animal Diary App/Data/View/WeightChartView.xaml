<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.WeightChartView"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers">
    <ContentView.Resources>
        <ResourceDictionary>
            <helpers:WeightMaxConverter x:Key="WeightMaxConverter"/>
            <helpers:WeightMidConverter x:Key="WeightMidConverter"/>
            <helpers:WeightMinConverter x:Key="WeightMinConverter"/>
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="8">

        <!-- Has Data -->
        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding MainPageVM.HasSufficientWeightData}">

            <!-- Header (matches the other section headers) -->
            <Label Text="{loc:Translate Weight_TrendHeader}"
                   FontSize="10"
                   FontAttributes="Bold"
                   CharacterSpacing="1.5"
                   TextColor="#2E6B85"/>

            <!-- Chart Card (matches the mood timeline card) -->
            <Border BackgroundColor="#40FFFFFF"
                    Stroke="#50FFFFFF"
                    StrokeThickness="1"
                    Padding="12,10"
                    StrokeShape="RoundRectangle 16">

                <VerticalStackLayout Spacing="10">

                    <Label Text="{loc:Translate Main_Last30Days}"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#2E6B85"/>

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="10">

                        <!-- Y-Axis Labels (spread evenly across the chart height) -->
                        <Grid Grid.Column="0"
                              RowDefinitions="*,*,*"
                              HeightRequest="140"
                              WidthRequest="28"
                              VerticalOptions="Start">

                            <Label Grid.Row="0"
                                   Text="{Binding MainPageVM.WeightChartData, Converter={StaticResource WeightMaxConverter}}"
                                   FontSize="9"
                                   TextColor="#6D8291"
                                   VerticalOptions="Start"
                                   HorizontalTextAlignment="End"
                                   HorizontalOptions="End"/>

                            <Label Grid.Row="1"
                                   Text="{Binding MainPageVM.WeightChartData, Converter={StaticResource WeightMidConverter}}"
                                   FontSize="9"
                                   TextColor="#6D8291"
                                   VerticalOptions="Center"
                                   HorizontalTextAlignment="End"
                                   HorizontalOptions="End"/>

                            <Label Grid.Row="2"
                                   Text="{Binding MainPageVM.WeightChartData, Converter={StaticResource WeightMinConverter}}"
                                   FontSize="9"
                                   TextColor="#6D8291"
                                   VerticalOptions="End"
                                   HorizontalTextAlignment="End"
                                   HorizontalOptions="End"/>
                        </Grid>

                        <!-- Chart Area: bars + aligned date labels in one scroll -->
                        <ScrollView Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never">

                            <HorizontalStackLayout Spacing="6"
                                                   BindableLayout.ItemsSource="{Binding MainPageVM.WeightChartData}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Spacing="4"
                                                             WidthRequest="32">

                                            <!-- Bar (bottom-aligned in a fixed-height plot area) -->
                                            <Grid HeightRequest="140">
                                                <BoxView WidthRequest="22"
                                                         HeightRequest="{Binding BarHeight}"
                                                         Color="#5B9BB8"
                                                         CornerRadius="4"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="End"/>
                                            </Grid>

                                            <!-- Weight value -->
                                            <Label Text="{Binding ValueLabel}"
                                                   FontSize="8"
                                                   FontAttributes="Bold"
                                                   TextColor="#1C3D52"
                                                   HorizontalTextAlignment="Center"
                                                   HorizontalOptions="Center"/>

                                            <!-- Date -->
                                            <Label Text="{Binding DateLabel}"
                                                   FontSize="8"
                                                   TextColor="#6D8291"
                                                   HorizontalTextAlignment="Center"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </HorizontalStackLayout>

                        </ScrollView>

                    </Grid>

                </VerticalStackLayout>

            </Border>
        </VerticalStackLayout>

        <!-- No Data State -->
        <VerticalStackLayout Spacing="8"
                             IsVisible="{Binding MainPageVM.HasSufficientWeightData, Converter={StaticResource InvertedBoolConverter}}"
                             Padding="16"
                             VerticalOptions="Center">

            <Label Text="📊"
                   FontSize="32"
                   HorizontalTextAlignment="Center"/>

            <Label Text="{loc:Translate Weight_EmptyState}"
                   FontSize="12"
                   TextColor="#6D8291"
                   HorizontalTextAlignment="Center"/>

        </VerticalStackLayout>

    </VerticalStackLayout>

</ContentView>
