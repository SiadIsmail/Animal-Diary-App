<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.View.WeightChartView"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers">
    <ContentView.Resources>
        <ResourceDictionary>
            <helpers:InvertedBoolConverter x:Key="InvertedBoolConverter"/>

            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.3"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>

            <!-- One range button; the label + selected accent are set per-instance. -->
            <Style x:Key="RangeTab" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="{StaticResource InkTertiary}"/>
                <Setter Property="HorizontalTextAlignment" Value="Center"/>
                <Setter Property="Padding" Value="0,6"/>
            </Style>
        </ResourceDictionary>
    </ContentView.Resources>

    <VerticalStackLayout Spacing="12">

        <!-- ── Has data ── -->
        <VerticalStackLayout Spacing="12"
                             IsVisible="{Binding MainPageVM.HasSufficientWeightData}">

            <Label Text="{loc:Translate Main_WeighInsHeading}"
                   FontFamily="{StaticResource FontSerifItalic}"
                   FontSize="17"
                   TextColor="{StaticResource Ink}"/>

            <Border BackgroundColor="{StaticResource Glass}"
                    Stroke="{StaticResource GlassLine}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 17,14,15,18"
                    Padding="16">
                <VerticalStackLayout Spacing="14">

                    <!-- Range selector -->
                    <Border BackgroundColor="{StaticResource Well}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 999"
                            Padding="3">
                        <Grid ColumnDefinitions="*,*,*,*">

                            <Border Grid.Column="0" BackgroundColor="Transparent"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 999">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding MainPageVM.ChartRangeDays}" Value="14">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding MainPageVM.SetChartRangeCommand}" CommandParameter="14"/>
                                </Border.GestureRecognizers>
                                <Label Text="2W" Style="{StaticResource RangeTab}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding MainPageVM.ChartRangeDays}" Value="14">
                                            <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>

                            <Border Grid.Column="1" BackgroundColor="Transparent"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 999">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding MainPageVM.ChartRangeDays}" Value="30">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding MainPageVM.SetChartRangeCommand}" CommandParameter="30"/>
                                </Border.GestureRecognizers>
                                <Label Text="1M" Style="{StaticResource RangeTab}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding MainPageVM.ChartRangeDays}" Value="30">
                                            <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>

                            <Border Grid.Column="2" BackgroundColor="Transparent"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 999">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding MainPageVM.ChartRangeDays}" Value="90">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding MainPageVM.SetChartRangeCommand}" CommandParameter="90"/>
                                </Border.GestureRecognizers>
                                <Label Text="3M" Style="{StaticResource RangeTab}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding MainPageVM.ChartRangeDays}" Value="90">
                                            <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>

                            <Border Grid.Column="3" BackgroundColor="Transparent"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 999">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding MainPageVM.ChartRangeDays}" Value="3650">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding MainPageVM.SetChartRangeCommand}" CommandParameter="3650"/>
                                </Border.GestureRecognizers>
                                <Label Text="All" Style="{StaticResource RangeTab}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding MainPageVM.ChartRangeDays}" Value="3650">
                                            <Setter Property="TextColor" Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Current value + trend -->
                    <VerticalStackLayout Spacing="8">
                        <Label VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding MainPageVM.CurrentWeightLabel}"
                                          FontFamily="{StaticResource FontSerif}"
                                          FontSize="24"
                                          TextColor="{StaticResource Ink}"/>
                                    <Span Text=" kg"
                                          FontFamily="{StaticResource FontSans}"
                                          FontSize="13"
                                          TextColor="{StaticResource InkSecondary}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <!-- Trend chip. One neutral treatment in every state: the app
                             cannot know whether a weight change is good or bad for a
                             given pet, so the colour must not imply a verdict. It sits
                             under the readout rather than beside it because the steady
                             state is a sentence, not a short number. -->
                        <Border Padding="10,4"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 999"
                                BackgroundColor="{StaticResource Well}"
                                HorizontalOptions="Start"
                                IsVisible="{Binding MainPageVM.WeightTrendLabel, Converter={StaticResource StringToBoolConverter}}">
                            <Label Text="{Binding MainPageVM.WeightTrendLabel}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11.5"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource InkSecondary}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Line chart -->
                    <GraphicsView x:Name="ChartSurface"
                                  HeightRequest="132"
                                  HorizontalOptions="Fill"/>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- ── No data ── -->
        <VerticalStackLayout Spacing="8"
                             Padding="16"
                             IsVisible="{Binding MainPageVM.HasSufficientWeightData, Converter={StaticResource InvertedBoolConverter}}">
            <Label Text="📈"
                   FontSize="32"
                   HorizontalTextAlignment="Center"/>
            <Label Text="{loc:Translate Weight_EmptyState}"
                   FontFamily="{StaticResource FontSans}"
                   FontSize="12"
                   TextColor="{StaticResource InkSecondary}"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

    </VerticalStackLayout>

</ContentView>
