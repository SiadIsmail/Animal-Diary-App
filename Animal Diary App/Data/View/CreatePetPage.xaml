<?xml version="1.0" encoding="utf-8" ?>
<!--
    CreatePetPage.xaml — onboarding step 1 of 2: IDENTITY
    ─────────────────────────────────────────────────────────
    The simple, personal first screen: just the pet's name and a placeholder for
    the future profile-picture feature. "Next" carries the shared PetVM draft to
    PetDetailsPage (step 2) where the technical details are collected.

    Used in three contexts (all share this two-page flow):
      1. First launch — no cancel button, welcoming feel
      2. Add pet from Pets page — cancel button visible
      3. Edit pet from Manage — prefilled, cancel button visible
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:MainViewModel"
             x:Class="Animal_Diary_App.Data.View.CreatePetPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="0.8"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>
            <Style x:Key="FieldBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
                <Setter Property="Stroke" Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 13"/>
            </Style>
            <Style x:Key="ErrorLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextColor" Value="{StaticResource Clay}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ══════════ SCROLLABLE CONTENT ══════════ -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="22,26,22,24"
                                 Spacing="22">

                <!-- Header -->
                <Label Text="{Binding PetVM.IdentityTitle}"
                       FontFamily="{StaticResource FontSerif}"
                       FontSize="{StaticResource TypeH1}"
                       TextColor="{StaticResource Ink}"
                       HorizontalTextAlignment="Center"/>

                <!-- Subtitle -->
                <Label Text="{Binding PetVM.IdentitySubtitle}"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="14"
                       TextColor="{StaticResource InkSecondary}"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding PetVM.IdentitySubtitle, Converter={StaticResource StringToBoolConverter}}"
                       Margin="10,0"/>

                <!-- ── Profile photo — tap to add/change/remove ── -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPhotoTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <controls:PetAvatarView Diameter="112"
                                            FallbackFontSize="40"
                                            FallbackText="📷"
                                            PhotoPath="{Binding PetVM.DraftPhotoPath}"
                                            HorizontalOptions="Center"/>
                    <Label Text="{loc:Translate CreatePet_PhotoLabel}"
                           Style="{StaticResource FieldLabel}"
                           HorizontalTextAlignment="Center"/>
                    <!-- "Add a photo" until one is set, then "Change photo" -->
                    <Label Text="{loc:Translate CreatePet_PhotoAdd}"
                           IsVisible="{Binding PetVM.HasDraftPhoto, Converter={StaticResource InvertedBoolConverter}}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12"
                           TextColor="{StaticResource TealDeep}"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{loc:Translate CreatePet_PhotoChange}"
                           IsVisible="{Binding PetVM.HasDraftPhoto}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12"
                           TextColor="{StaticResource TealDeep}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Name field -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{loc:Translate CreatePet_NameLabel}"
                           Style="{StaticResource FieldLabel}"/>
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry Placeholder="{loc:Translate CreatePet_NamePlaceholder}"
                               Text="{Binding PetVM.EnteredPetName}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Ink}"
                               PlaceholderColor="{StaticResource InkTertiary}"
                               Margin="14,0"/>
                    </Border>
                    <Label Text="{Binding PetVM.PetNameError}"
                           Style="{StaticResource ErrorLabel}"
                           IsVisible="{Binding PetVM.PetNameError, Converter={StaticResource StringToBoolConverter}}"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════ BOTTOM ACTION BAR ══════════ -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Glass}"
                Stroke="{StaticResource GlassLine}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 28,24,0,0"
                Padding="20,16,20,28"
                VerticalOptions="End">

            <Grid ColumnDefinitions="*,2*"
                  ColumnSpacing="12">

                <!-- Cancel (not first launch) -->
                <Border BackgroundColor="{StaticResource TealTint}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        IsVisible="{Binding PetVM.ShowBackButton}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCancelClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="{loc:Translate Common_Cancel}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TealDeep}"
                           HorizontalTextAlignment="Center"
                           Padding="0,14"/>
                </Border>

                <!-- Next → details -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Teal}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        Opacity="{Binding PetVM.CanContinueIdentity, Converter={StaticResource BoolToOpacityConverter}}"
                        IsEnabled="{Binding PetVM.CanContinueIdentity}">
                    <Border.Shadow>
                        <Shadow Brush="#149081" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNextClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="{loc:Translate CreatePet_NextButton}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource White}"
                           HorizontalTextAlignment="Center"
                           Padding="0,14"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════ PHOTO SOURCE CHOOSER (FelovaBottomSheet) ══════════ -->
        <!-- Opened from OnPhotoTapped; the buttons call code-behind handlers because
             the media picker is a device API (pages own device interaction). -->
        <controls:FelovaBottomSheet x:Name="PhotoChooser"
                                    Grid.RowSpan="2"
                                    Title="{loc:Translate CreatePet_PhotoSheetTitle}">
            <controls:FelovaBottomSheet.SheetContent>
                <VerticalStackLayout Spacing="12" Padding="0,2,0,0">

                    <Border BackgroundColor="{StaticResource Teal}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 13">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTakePhoto"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate CreatePet_PhotoTake}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource White}"
                               HorizontalTextAlignment="Center"
                               Padding="0,14"/>
                    </Border>

                    <Border BackgroundColor="{StaticResource TealTint}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 13">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChooseFromLibrary"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate CreatePet_PhotoChoose}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TealDeep}"
                               HorizontalTextAlignment="Center"
                               Padding="0,14"/>
                    </Border>

                    <!-- Remove — only when a photo is set -->
                    <Border BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 13"
                            IsVisible="{Binding PetVM.HasDraftPhoto}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRemovePhoto"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate CreatePet_PhotoRemove}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Clay}"
                               HorizontalTextAlignment="Center"
                               Padding="0,14"/>
                    </Border>

                    <!-- Permission-denied / picker-failed inline line (never an alert) -->
                    <Label x:Name="PhotoErrorLabel"
                           IsVisible="False"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12.5"
                           TextColor="{StaticResource Clay}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </controls:FelovaBottomSheet.SheetContent>
        </controls:FelovaBottomSheet>

    </Grid>

</ContentPage>
