<?xml version="1.0" encoding="utf-8" ?>
<!--
    CreatePetPage.xaml
    ─────────────────────────────────────────────────────────
    Used in two contexts:
      1. First launch — no back/cancel button, full welcoming feel
      2. Add pet from Pets page — cancel button visible
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             x:Class="Animal_Diary_App.Data.View.CreatePetPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Paper}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="CardSurface" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Card}"/>
                <Setter Property="Stroke" Value="{StaticResource Line}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 22"/>
                <Setter Property="Padding" Value="18"/>
            </Style>
            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="0.8"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>
            <Style x:Key="FieldBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Card}"/>
                <Setter Property="Stroke" Value="{StaticResource Line}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 13"/>
            </Style>
            <Style x:Key="ErrorLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextColor" Value="{StaticResource Clay}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- ══════════ SCROLLABLE CONTENT ══════════ -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="22,26,22,24"
                                 Spacing="20">

                <!-- Header -->
                <Label Text="{Binding PetVM.PageTitle}"
                       FontFamily="{StaticResource FontSerif}"
                       FontSize="{StaticResource TypeH1}"
                       TextColor="{StaticResource Ink}"
                       HorizontalTextAlignment="Center"/>

                <!-- Welcome subtitle (first launch) -->
                <Label Text="{loc:Translate CreatePet_Subtitle}"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="14"
                       TextColor="{StaticResource InkSecondary}"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding PetVM.IsFirstLaunch}"
                       Margin="10,0"/>

                <!-- Avatar preview -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Border WidthRequest="100"
                            HeightRequest="100"
                            Stroke="{StaticResource ViolaLine}"
                            StrokeThickness="2"
                            StrokeShape="RoundRectangle 50"
                            HorizontalOptions="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EFE9F8" Offset="0"/>
                                <GradientStop Color="#E3D9F2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#241E2E" Offset="0,6" Radius="16" Opacity="0.14"/>
                        </Border.Shadow>
                        <Label Text="{Binding PetVM.SelectedTypeEmoji}"
                               FontSize="52"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="{Binding PetVM.PreviewName}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="18"
                           TextColor="{StaticResource Ink}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Pet type selector -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="{loc:Translate CreatePet_WhatAnimal}"
                           Style="{StaticResource FieldLabel}"
                           Margin="2,0,0,0"/>

                    <CollectionView ItemsSource="{Binding PetVM.PetTypeOptions}"
                                    ItemsLayout="HorizontalList"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding PetVM.SelectedPetType}"
                                    HeightRequest="92">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Padding="5,0" Spacing="6">
                                    <Border WidthRequest="58"
                                            HeightRequest="58"
                                            BackgroundColor="{StaticResource Card}"
                                            Stroke="{StaticResource Line}"
                                            StrokeThickness="1.5"
                                            StrokeShape="RoundRectangle 16"
                                            HorizontalOptions="Center">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource ViolaTint}"/>
                                                <Setter Property="Stroke" Value="{StaticResource Viola}"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding Emoji}"
                                               FontSize="28"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="{Binding DisplayName}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="10.5"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource InkSecondary}"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Custom type (Other) -->
                <VerticalStackLayout Spacing="6"
                                     IsVisible="{Binding PetVM.ShowCustomPetType}">
                    <Label Text="{loc:Translate CreatePet_DescribeType}"
                           Style="{StaticResource FieldLabel}"
                           Margin="2,0,0,0"/>
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry Placeholder="{loc:Translate CreatePet_CustomTypePlaceholder}"
                               Text="{Binding PetVM.EnteredPetType}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="15"
                               TextColor="{StaticResource Ink}"
                               PlaceholderColor="{StaticResource InkTertiary}"
                               Margin="14,0"/>
                    </Border>
                    <Label Text="{Binding PetVM.PetTypeError}"
                           Style="{StaticResource ErrorLabel}"
                           IsVisible="{Binding PetVM.PetTypeError, Converter={StaticResource StringToBoolConverter}}"/>
                </VerticalStackLayout>

                <!-- Generic pet-type validation error -->
                <Label Text="{Binding PetVM.PetTypeError}"
                       Style="{StaticResource ErrorLabel}"
                       IsVisible="{Binding PetVM.PetTypeError, Converter={StaticResource StringToBoolConverter}}"
                       Margin="2,0,0,0"/>

                <!-- Name + Age card -->
                <Border Style="{StaticResource CardSurface}">
                    <VerticalStackLayout Spacing="16">

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate CreatePet_NameLabel}"
                                   Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="{loc:Translate CreatePet_NamePlaceholder}"
                                       Text="{Binding PetVM.EnteredPetName}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"
                                       PlaceholderColor="{StaticResource InkTertiary}"
                                       Margin="14,0"/>
                            </Border>
                            <Label Text="{Binding PetVM.PetNameError}"
                                   Style="{StaticResource ErrorLabel}"
                                   IsVisible="{Binding PetVM.PetNameError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource Line}"/>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{loc:Translate CreatePet_AgeLabel}"
                                   Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Placeholder="{loc:Translate CreatePet_AgePlaceholder}"
                                       Text="{Binding PetVM.EnteredPetAge}"
                                       Keyboard="Numeric"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"
                                       PlaceholderColor="{StaticResource InkTertiary}"
                                       Margin="14,0"/>
                            </Border>
                            <Label Text="{Binding PetVM.PetAgeError}"
                                   Style="{StaticResource ErrorLabel}"
                                   IsVisible="{Binding PetVM.PetAgeError, Converter={StaticResource StringToBoolConverter}}"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Conditions hint -->
                <Border BackgroundColor="{StaticResource ViolaTint}"
                        Stroke="{StaticResource ViolaLine}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="14,12">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="🏷️" FontSize="18" VerticalOptions="Center"/>
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="{loc:Translate CreatePet_ConditionsTitle}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="12.5"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Ink}"/>
                            <Label Text="{loc:Translate CreatePet_ConditionsSubtitle}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11"
                                   TextColor="{StaticResource InkSecondary}"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════ BOTTOM ACTION BAR ══════════ -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Card}"
                Stroke="{StaticResource Line}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24,24,0,0"
                Padding="20,16,20,28"
                VerticalOptions="End">

            <Grid ColumnDefinitions="*,2*"
                  ColumnSpacing="12">

                <!-- Cancel (not first launch) -->
                <Border BackgroundColor="{StaticResource ViolaTint}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        IsVisible="{Binding PetVM.ShowBackButton}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="{loc:Translate Common_Cancel}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{StaticResource ViolaDeep}"
                           HorizontalTextAlignment="Center"
                           Padding="0,14"/>
                </Border>

                <!-- Create / Save -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Viola}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 14"
                        Opacity="{Binding PetVM.CanSavePet, Converter={StaticResource BoolToOpacityConverter}}"
                        IsEnabled="{Binding PetVM.CanSavePet}">
                    <Border.Shadow>
                        <Shadow Brush="#7657B8" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSaveClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="{Binding PetVM.SaveButtonLabel}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource White}"
                           HorizontalTextAlignment="Center"
                           Padding="0,14"/>
                </Border>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
