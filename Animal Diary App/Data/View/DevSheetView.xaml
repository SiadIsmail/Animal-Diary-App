<?xml version="1.0" encoding="utf-8" ?>
<!-- DevSheetView — hidden developer diagnostics on the shared FelovaBottomSheet.
     Reached from Settings → "Code"; a gate code reveals cloud/auth state + the
     recent event log, with a Copy button. English-only by intent (a dev tool,
     not a user feature). BindingContext is a DevSheetViewModel. -->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:DevSheetViewModel"
             x:Class="Animal_Diary_App.Data.View.DevSheetView"
             x:Name="Root"
             InputTransparent="{Binding IsPresented, Converter={StaticResource InvertedBoolConverter}}">

    <controls:FelovaBottomSheet IsPresented="{Binding IsPresented}"
                                Title="{Binding Title}"
                                Subtitle="{Binding Subtitle}"
                                DismissCommand="{Binding DismissCommand}">
        <controls:FelovaBottomSheet.SheetContent>
            <VerticalStackLayout Spacing="12" Padding="0,2,0,0">

                <!-- Locked: code entry -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsLocked}">
                    <Border BackgroundColor="{StaticResource Glass}" Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 14" Padding="14,2">
                        <Entry Text="{Binding CodeInput}" Placeholder="Code"
                               FontFamily="{StaticResource FontSans}" FontSize="14"
                               TextColor="{StaticResource Ink}" BackgroundColor="Transparent"/>
                    </Border>
                    <Border BackgroundColor="{StaticResource Teal}" StrokeThickness="0" StrokeShape="RoundRectangle 13,16,15,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding UnlockCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Unlock" FontFamily="{StaticResource FontSans}" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource White}" HorizontalTextAlignment="Center" Padding="0,13"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Unlocked: diagnostics -->
                <VerticalStackLayout Spacing="12" IsVisible="{Binding IsUnlocked}">

                    <Border BackgroundColor="{StaticResource TealTint}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="12,10">
                        <Label Text="{Binding AuthState}" FontFamily="{StaticResource FontSans}"
                               FontSize="12" TextColor="{StaticResource Ink}"/>
                    </Border>

                    <Border BackgroundColor="{StaticResource Glass}" Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="10,8">
                        <ScrollView HeightRequest="220" Orientation="Both">
                            <Label Text="{Binding Log}" FontFamily="{StaticResource FontSans}"
                                   FontSize="11" LineHeight="1.3" TextColor="{StaticResource InkSecondary}"/>
                        </ScrollView>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Border BackgroundColor="{StaticResource Teal}" StrokeThickness="0" StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CopyCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Copy" FontFamily="{StaticResource FontSans}" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource White}" HorizontalTextAlignment="Center" Padding="0,12"/>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource Glass}" Stroke="{StaticResource GlassLine}"
                                StrokeThickness="1.5" StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Refresh" FontFamily="{StaticResource FontSans}" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource Ink}" HorizontalTextAlignment="Center" Padding="0,12"/>
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Border BackgroundColor="{StaticResource Glass}" Stroke="{StaticResource GlassLine}" StrokeThickness="1.5" StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SyncNowCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Sync now" FontFamily="{StaticResource FontSans}" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource Ink}" HorizontalTextAlignment="Center" Padding="0,11"/>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource Glass}" Stroke="{StaticResource GlassLine}" StrokeThickness="1.5" StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ForceRefreshCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Refresh token" FontFamily="{StaticResource FontSans}" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource Ink}" HorizontalTextAlignment="Center" Padding="0,11"/>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="{StaticResource ClayTint}" Stroke="#EFD3CE" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ClearLogCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Clear" FontFamily="{StaticResource FontSans}" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource Clay}" HorizontalTextAlignment="Center" Padding="0,11"/>
                        </Border>
                    </Grid>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </controls:FelovaBottomSheet.SheetContent>
    </controls:FelovaBottomSheet>
</ContentView>
