<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:vms="clr-namespace:Animal_Diary_App.Data.ViewModels"
             x:DataType="vms:MainViewModel"
             x:Class="Animal_Diary_App.Data.View.PetTypePage">


    <Grid>
        <Image Source="dotnet_bot.png"
               Aspect="AspectFill"/>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label
                Text="{loc:Translate PetTypePage_Hello}"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1"/>

            <Label
                Text="{loc:Translate PetTypePage_WhatType}"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I"/>

            <Entry
                Placeholder="{loc:Translate Common_EnterText}"
                Text="{Binding PetVM.EnteredPetType}"
                SemanticProperties.Description="Type your pet's type here"/>

            <Label
                Text="{loc:Translate PetTypePage_HowOld}"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I"/>

            <Entry
                Placeholder="{loc:Translate Common_EnterText}"
                Text="{Binding PetVM.EnteredPetAge}"
                Completed="OnEntryCompleted"
                SemanticProperties.Description="Type your pet's age here"/>
        </VerticalStackLayout>
    </Grid>


</ContentPage>
