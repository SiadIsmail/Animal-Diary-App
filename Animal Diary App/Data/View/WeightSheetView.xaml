<?xml version="1.0" encoding="utf-8" ?>
<!-- WeightSheetView — value stepper in the shared FelovaBottomSheet. BindingContext
     is a WeightSheetViewModel. -->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             x:Class="Animal_Diary_App.Data.View.WeightSheetView"
             x:Name="Root"
             InputTransparent="{Binding IsPresented, Converter={StaticResource InvertedBoolConverter}}">

    <ContentView.Resources>
        <Style x:Key="StepButton" TargetType="Border">
            <Setter Property="WidthRequest" Value="46"/>
            <Setter Property="HeightRequest" Value="46"/>
            <Setter Property="BackgroundColor" Value="{StaticResource Glass}"/>
            <Setter Property="Stroke" Value="{StaticResource GlassLine}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 15,13,14,16"/>
        </Style>
    </ContentView.Resources>

    <controls:FelovaBottomSheet IsPresented="{Binding IsPresented}"
                                Title="{Binding Title}"
                                Subtitle="{Binding Subtitle}"
                                DismissCommand="{Binding DismissCommand}">
        <controls:FelovaBottomSheet.SheetContent>
            <VerticalStackLayout Spacing="16" Padding="0,2,0,0">

                <VerticalStackLayout Spacing="8">
                    <Label Text="{loc:Translate Journal_WeightFieldLabel}"
                           FontFamily="{StaticResource FontSans}" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1" TextColor="{StaticResource InkSecondary}"/>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" Style="{StaticResource StepButton}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding StepCommand}" CommandParameter="-0.1"/>
                            </Border.GestureRecognizers>
                            <Label Text="−" FontSize="24" TextColor="{StaticResource TealDeep}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="{StaticResource Glass}"
                                Stroke="{StaticResource GlassLine}" StrokeThickness="1" StrokeShape="RoundRectangle 14">
                            <Entry Text="{Binding ValueText}" Keyboard="Numeric" HorizontalTextAlignment="Center"
                                   FontFamily="{StaticResource FontSerif}" FontSize="24" TextColor="{StaticResource Ink}"/>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StepButton}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding StepCommand}" CommandParameter="0.1"/>
                            </Border.GestureRecognizers>
                            <Label Text="+" FontSize="24" TextColor="{StaticResource TealDeep}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,6,0,0">
                    <Border BackgroundColor="{StaticResource TealTint}" StrokeThickness="0" StrokeShape="RoundRectangle 15,13,13,16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DismissCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate Common_NotNow}" FontFamily="{StaticResource FontSans}" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource TealDeep}" HorizontalTextAlignment="Center" Padding="0,14"/>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource Teal}" StrokeThickness="0" StrokeShape="RoundRectangle 13,16,15,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate Journal_SaveWeight}" FontFamily="{StaticResource FontSans}" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource White}" HorizontalTextAlignment="Center" Padding="0,14"/>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </controls:FelovaBottomSheet.SheetContent>
    </controls:FelovaBottomSheet>
</ContentView>
