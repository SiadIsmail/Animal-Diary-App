<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:calendar="clr-namespace:Syncfusion.Maui.Calendar;assembly=Syncfusion.Maui.Calendar"
             x:Class="Animal_Diary_App.Data.View.CalendarPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#DCEBF5">
        <ContentPage.Resources>
                <ResourceDictionary>
                        <helpers:ZeroToWeightPlaceholderConverter x:Key="ZeroWeightPlaceholderConverter"/>
                        <helpers:EmptyToMoodPlaceholderConverter x:Key="EmptyMoodPlaceholderConverter"/>

                </ResourceDictionary>
        </ContentPage.Resources>

        <Grid RowDefinitions="*,Auto">

                <!-- Background -->
                <Image Source="hintergrund_blau.png"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill"
                       InputTransparent="True"
                       Grid.RowSpan="2"/>

                <!-- Main Content -->
                <VerticalStackLayout Grid.Row="0"
                                     Padding="20,16"
                                     Spacing="16">

                        <!-- Pet Selector Chips -->
                        <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never">
                                <HorizontalStackLayout Spacing="10"
                                                       BindableLayout.ItemsSource="{Binding CalendarVM.Pets}">
                                        <BindableLayout.ItemTemplate>
                                                <DataTemplate>
                                                        <Border StrokeThickness="2"
                                                                StrokeShape="RoundRectangle 20"
                                                                Padding="14,8">
                                                                <!-- ? Chip selected state: bind Stroke/BackgroundColor to something like
                                     IsSelected on each pet, e.g. Stroke="{Binding IsSelected, Converter=...}"
                                     You'll need a bool-to-color converter or handle this in code-behind -->
                                                                <Border.Triggers>
                                                                        <DataTrigger TargetType="Border"
                                                                                     Binding="{Binding IsSelected}"
                                                                                     Value="True">
                                                                                <Setter Property="BackgroundColor"
                                                                                        Value="#809B6FCC"/>
                                                                                <Setter Property="Stroke"
                                                                                        Value="#B39B6FCC"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Border"
                                                                                     Binding="{Binding IsSelected}"
                                                                                     Value="False">
                                                                                <Setter Property="BackgroundColor"
                                                                                        Value="#339B6FCC"/>
                                                                                <Setter Property="Stroke"
                                                                                        Value="#599B6FCC"/>
                                                                        </DataTrigger>
                                                                </Border.Triggers>
                                                                <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectPetCommand}"
                                                                                CommandParameter="{Binding .}"/>
                                                                </Border.GestureRecognizers>
                                                                <HorizontalStackLayout Spacing="6">
                                                                        <!--   ? Pet avatar/icon: bind Source to pet.AvatarImage or similar 
                                                                        <Image Source="{Binding AvatarImage}"
                                                                               WidthRequest="24"
                                                                               HeightRequest="24"
                                                                               VerticalOptions="Center"/>-->
                                                                        <Label Text="{Binding Name}"
                                                                               FontSize="13"
                                                                               FontAttributes="Bold"
                                                                               TextColor="#4A1580"
                                                                               VerticalOptions="Center"/>

                                                                        <Label Text="{Binding Age, StringFormat='({0} yrs)'}"
                                                                               FontSize="13"
                                                                               FontAttributes="Bold"
                                                                               TextColor="#4A1580"
                                                                               VerticalOptions="Center"/>
                                                                </HorizontalStackLayout>
                                                        </Border>
                                                </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                </HorizontalStackLayout>
                        </ScrollView>

                        <!-- Calendar -->
                        <VerticalStackLayout Spacing="16">

                                <calendar:SfCalendar
                                        x:Name="Calendar"
                                        BackgroundColor="#5B9BB8"
                                        SelectedDate="{Binding CalendarVM.CurrentSelectedDate, Mode=TwoWay}"
                                        HeightRequest="170"
                                        VerticalOptions="Start"
                                        ShowTrailingAndLeadingDates="False">
                                        <calendar:SfCalendar.MonthView>
                                                <calendar:CalendarMonthView NumberOfVisibleWeeks="1"/>
                                        </calendar:SfCalendar.MonthView>
                                </calendar:SfCalendar>

                                <Label Text="{Binding CalendarVM.CurrentSelectedDate, StringFormat='Selected Date: {0:d}'}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#2E6B85"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"/>

                        </VerticalStackLayout>
                        <ScrollView Orientation="Horizontal"
                                    HorizontalScrollBarVisibility="Never">
                                <!-- Action Buttons -->
                                <HorizontalStackLayout Spacing="14"
                                                       HorizontalOptions="Center">

                                        <Button Text="+ Mood"
                                                FontSize="13"
                                                WidthRequest="120"
                                                HeightRequest="40"
                                                CornerRadius="20"
                                                BackgroundColor="#CCC4A8E0"
                                                TextColor="#4A1580"
                                                IsVisible="{Binding CalendarVM.MoodSection.IsAddButtonVisible}"
                                                Command="{Binding CalendarVM.ShowMoodInputCommand}"/>

                                        <Button Text="+ Weight"
                                                FontSize="13"
                                                WidthRequest="120"
                                                HeightRequest="40"
                                                CornerRadius="20"
                                                BackgroundColor="#CCC4A8E0"
                                                TextColor="#4A1580"
                                                IsVisible="{Binding CalendarVM.WeightSection.IsAddButtonVisible}"
                                                Command="{Binding CalendarVM.ShowWeightInputCommand}"/>

                                </HorizontalStackLayout>
                        </ScrollView>
                        <!-- Mood Input - TEMPORARILY DISABLED FOR DEBUGGING -->
                        <VerticalStackLayout IsVisible="{Binding CalendarVM.MoodSection.IsInputVisible}"
                                             Spacing="12">
                                <Label Text="How is your pet feeling today?"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#1C3D52"/>

                                <HorizontalStackLayout Spacing="8"
                                                       HorizontalOptions="Center">
                                        <Border Padding="12,10"
                                                BackgroundColor="#D06060"
                                                StrokeThickness="2"
                                                StrokeShape="RoundRectangle 12">
                                                <Border.Triggers>
                                                        <DataTrigger TargetType="Border"
                                                                     Binding="{Binding CalendarVM.SelectedMoodLevel}"
                                                                     Value="1">
                                                                <Setter Property="Stroke" Value="#FFFFFF"/>
                                                                <Setter Property="BackgroundColor" Value="#BE4A4A"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border"
                                                                     Binding="{Binding CalendarVM.SelectedMoodLevel}"
                                                                     Value="0">
                                                                <Setter Property="Stroke" Value="#D06060"/>
                                                        </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}"
                                                                              CommandParameter="1"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="😢" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                                        </Border>
                                        <Border Padding="12,10" BackgroundColor="#E88A6A" StrokeThickness="2" StrokeShape="RoundRectangle 12">
                                                <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="2">
                                                                <Setter Property="Stroke" Value="#FFFFFF"/>
                                                                <Setter Property="BackgroundColor" Value="#D07050"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="0">
                                                                <Setter Property="Stroke" Value="#E88A6A"/>
                                                        </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}"
                                                                              CommandParameter="2"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="😟" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                                        </Border>
                                        <Border Padding="12,10" BackgroundColor="#F0C060" StrokeThickness="2" StrokeShape="RoundRectangle 12">
                                                <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="3">
                                                                <Setter Property="Stroke" Value="#FFFFFF"/>
                                                                <Setter Property="BackgroundColor" Value="#D9A840"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="0">
                                                                <Setter Property="Stroke" Value="#F0C060"/>
                                                        </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}"
                                                                              CommandParameter="3"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="😐" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                                        </Border>
                                        <Border Padding="12,10" BackgroundColor="#7EC8A0" StrokeThickness="2" StrokeShape="RoundRectangle 12">
                                                <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="4">
                                                                <Setter Property="Stroke" Value="#FFFFFF"/>
                                                                <Setter Property="BackgroundColor" Value="#5BAA80"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="0">
                                                                <Setter Property="Stroke" Value="#7EC8A0"/>
                                                        </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}"
                                                                              CommandParameter="4"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="😊" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                                        </Border>
                                        <Border Padding="12,10" BackgroundColor="#5BBF8A" StrokeThickness="2" StrokeShape="RoundRectangle 12">
                                                <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="5">
                                                                <Setter Property="Stroke" Value="#FFFFFF"/>
                                                                <Setter Property="BackgroundColor" Value="#3A9A6A"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="0">
                                                                <Setter Property="Stroke" Value="#5BBF8A"/>
                                                        </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}"
                                                                              CommandParameter="5"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="😄" FontSize="20" VerticalOptions="Center" HorizontalOptions="Center"/>
                                        </Border>
                                </HorizontalStackLayout>
                                <Button Text="Confirm Mood" FontSize="13" HeightRequest="40" CornerRadius="20"
                                        BackgroundColor="#CCC4A8E0" TextColor="#4A1580"
                                        Command="{Binding CalendarVM.OnMoodEntryCompleted}"/>
                        </VerticalStackLayout>

                        <Entry Placeholder="Enter your pet's weight today"
                               Text="{Binding CalendarVM.EnteredWeight}"
                               FontSize="18"
                               Keyboard="Numeric"
                               Completed="OnWeightEntryCompleted"
                               IsVisible="{Binding CalendarVM.WeightSection.IsInputVisible}"/>


                        <!-- Day Overview Card -->
                        <ScrollView>
                                <Border BackgroundColor="#5B9BB8"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16"
                                        Padding="20,16">
                                        <Border.Shadow>
                                                <Shadow Brush="#40000000"
                                                        Offset="0,8"
                                                        Radius="18"
                                                        Opacity="0.35"/>
                                        </Border.Shadow>
                                        <VerticalStackLayout Spacing="12">

                                                <Label Text="TODAY'S OVERVIEW"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       CharacterSpacing="1.5"
                                                       TextColor="White"
                                                       Opacity="0.85"/>

                                                <!-- Mood Row -->
                                                <HorizontalStackLayout Spacing="10">
                                                        <Label Text="😊"
                                                               FontSize="20"
                                                               VerticalOptions="Center"/>
                                                        <Label Text="Mood"
                                                               FontSize="13"
                                                               TextColor="White"
                                                               Opacity="0.75"
                                                               VerticalOptions="Center"
                                                               WidthRequest="70"/>
                                                        <Label Text="{Binding CalendarVM.ShownMood}"
                                                               FontSize="13"
                                                               FontAttributes="Bold"
                                                               TextColor="White"
                                                               VerticalOptions="Center">
                                                                <Label.Triggers>

                                                                        <DataTrigger
                                                                                TargetType="Label"
                                                                                Binding="{Binding CalendarVM.ShownMood}"
                                                                                Value="">

                                                                                <Setter Property="Text"
                                                                                        Value="No mood recorded yet..."/>
                                                                                <Setter Property="Opacity"
                                                                                        Value="0.5"/>
                                                                                <Setter Property="FontAttributes"
                                                                                        Value="Italic"/>

                                                                        </DataTrigger>

                                                                </Label.Triggers>
                                                        </Label>
                                                </HorizontalStackLayout>

                                                <!-- Divider -->
                                                <BoxView HeightRequest="1"
                                                         BackgroundColor="White"
                                                         Opacity="0.2"/>

                                                <!-- Weight Row -->
                                                <HorizontalStackLayout Spacing="10">
                                                        <Label Text="⚖️"
                                                               FontSize="20"
                                                               VerticalOptions="Center"/>
                                                        <Label Text="Weight"
                                                               FontSize="13"
                                                               TextColor="White"
                                                               Opacity="0.75"
                                                               VerticalOptions="Center"
                                                               WidthRequest="70"/>
                                                        <Label Text="{Binding CalendarVM.ShownWeight, StringFormat='{0} kg'}"
                                                               FontSize="13"
                                                               FontAttributes="Bold"
                                                               TextColor="White"
                                                               VerticalOptions="Center">
                                                                <Label.Triggers>

                                                                        <DataTrigger
                                                                                TargetType="Label"
                                                                                Binding="{Binding CalendarVM.ShownWeight}"
                                                                                Value="">

                                                                                <Setter Property="Text"
                                                                                        Value="No weight recorded yet..."/>
                                                                                <Setter Property="Opacity"
                                                                                        Value="0.5"/>
                                                                                <Setter Property="FontAttributes"
                                                                                        Value="Italic"/>

                                                                        </DataTrigger>

                                                                </Label.Triggers>
                                                        </Label>
                                                </HorizontalStackLayout>

                                        </VerticalStackLayout>
                                </Border>
                        </ScrollView>

                </VerticalStackLayout>

                <!-- BOTTOM NAVIGATION -->
                <Border Grid.Row="1"
                        Margin="0"
                        Padding="12,10,12,20"
                        BackgroundColor="#E6C4A8E0"
                        StrokeThickness="0"
                        VerticalOptions="End">

                        <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24,24,0,0"/>
                        </Border.StrokeShape>

                        <Border.Shadow>
                                <Shadow Brush="#30000000"
                                        Offset="0,-2"
                                        Radius="10"
                                        Opacity="0.18"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="*,*,*">

                                <!-- MAIN -->
                                <Grid>
                                        <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnMainClicked"/>
                                        </Grid.GestureRecognizers>

                                        <VerticalStackLayout HorizontalOptions="Center"
                                                             Spacing="2">

                                                <Label Text="🏠"
                                                       FontSize="20"
                                                       HorizontalTextAlignment="Center"/>

                                                <Label Text="Main"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#664A1580"
                                                       HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                </Grid>

                                <!-- CALENDAR -->
                                <Grid Grid.Column="1">


                                        <VerticalStackLayout HorizontalOptions="Center"
                                                             Spacing="2">

                                                <Label Text="📅"
                                                       FontSize="20"
                                                       HorizontalTextAlignment="Center"/>

                                                <Label Text="Calendar"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#4A1580"
                                                       HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                </Grid>

                                <!-- PETS -->
                                <Grid Grid.Column="2">
                                        <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPetsClicked"/>
                                        </Grid.GestureRecognizers>

                                        <VerticalStackLayout HorizontalOptions="Center"
                                                             Spacing="2">

                                                <Label Text="🐾"
                                                       FontSize="20"
                                                       HorizontalTextAlignment="Center"/>

                                                <Label Text="Pets"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="#664A1580"
                                                       HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                </Grid>

                        </Grid>
                </Border>

        </Grid>

</ContentPage>