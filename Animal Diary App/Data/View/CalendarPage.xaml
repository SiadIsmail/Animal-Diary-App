<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:calendar="clr-namespace:Syncfusion.Maui.Calendar;assembly=Syncfusion.Maui.Calendar"
             x:Class="Animal_Diary_App.Data.View.CalendarPage">
    <Grid>
        <Image Source="hintergrund_blau.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"/>
        <VerticalStackLayout
            Padding="24,20"
            Spacing="20">



            <calendar:SfCalendar
                x:Name="calendar"
                View="Month"
                BackgroundColor="#FF20A5E7"
                SelectedDate="{Binding CurrentSelectedDate, Mode=TwoWay}"/>

            <Label  Text="{Binding CurrentSelectedDate, StringFormat='Selected Date: {0:d}'}"
                    FontSize="18"
                    HorizontalOptions="Center"/>

            <Entry Placeholder="Enter your pet's mood for the day!"
                   Text="{Binding EnteredMood}"
                   FontSize="18"
                   HorizontalOptions="FillAndExpand"
                   Completed="OnMoodEntryCompleted"/>
            <Entry Placeholder="Enter your pet's weight today!"
                   Text="{Binding EnteredWeight}"
                   FontSize="18"
                   HorizontalOptions="FillAndExpand"
                   Completed="OnWeightEntryCompleted"/>

            <Label Text="{Binding ShownMood}"
                   FontSize="18"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>

        <Grid RowDefinitions="*,Auto"
              ColumnDefinitions="*,*"
              VerticalOptions="End">
            <Button Text="Main"
                    Grid.Row="1"
                    Grid.Column="0"/>

            <Button Text="Calendar"
                    Grid.Row="1"
                    Grid.Column="1"/>

        </Grid>
    </Grid>

</ContentPage>
