<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:calendar="clr-namespace:Syncfusion.Maui.Calendar;assembly=Syncfusion.Maui.Calendar"
             x:Class="Animal_Diary_App.Data.View.CalendarPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,20"
            Spacing="20">

            <Button Text="Open Calendar"
                    x:Name="calendarButton"
                    Clicked="Button_Clicked"/>

            <calendar:SfCalendar
                x:Name="calendar"
                View="Month"
                BackgroundColor="#FFE7E720"
                Mode="Dialog"
                SelectedDate="{Binding CurrentSelectedDate, Mode=TwoWay}"/>

            <Label  Text="{Binding CurrentSelectedDate, StringFormat='Selected Date: {0:d}'}"
                    FontSize="18"
                    HorizontalOptions="Center"/>
            <Entry Placeholder="Enter your pet's mood for the day"
                   Text="{Binding EnteredMood}"
                   FontSize="18"
                   HorizontalOptions="FillAndExpand"
                   Completed="OnEntryCompleted"/>
            <CollectionView ItemsSource="{Binding petsentries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="14"
                              VerticalOptions="Center">
                            <Label Text="{Binding Date, StringFormat='Date: {0:d}'}"
                                   FontSize="18"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding Mood}"
                                   FontSize="18"
                                   HorizontalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <HorizontalStackLayout
                VerticalOptions="End">

                <Button
                    Text="Main"
                    Clicked="OnMainClicked"/>

                <Button
                    Text="Calendar"/>

            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
