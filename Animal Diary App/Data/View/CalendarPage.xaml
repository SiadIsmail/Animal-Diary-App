<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:views="clr-namespace:Animal_Diary_App.Data.View"
             x:Class="Animal_Diary_App.Data.View.CalendarPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <helpers:FirstLetterConverter x:Key="FirstLetter"/>

            <!-- Frosted glass card surface -->
            <Style x:Key="GlassCard"
                    TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{StaticResource Glass}"/>
                <Setter Property="Stroke"
                        Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness"
                        Value="1"/>
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 17,14,15,18"/>
                <Setter Property="Padding"
                        Value="14"/>
            </Style>

            <!-- Uppercase section eyebrow -->
            <Style x:Key="SectionLabel"
                    TargetType="Label">
                <Setter Property="FontFamily"
                        Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"
                        Value="11"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="CharacterSpacing"
                        Value="1.3"/>
                <Setter Property="TextColor"
                        Value="{StaticResource InkSecondary}"/>
            </Style>

            <!-- ── Chronological timeline cards (one ordering, two layouts) ── -->
            <!-- Mood: title + time, then the warm-paper washi note -->
            <DataTemplate x:Key="TimelineMoodTemplate">
                <Grid ColumnDefinitions="38,*" ColumnSpacing="13">
                    <Grid Grid.Column="0" RowDefinitions="38,*">
                        <Border WidthRequest="38" HeightRequest="38" Rotation="{Binding IconRotation}"
                                BackgroundColor="{Binding Tint}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 19,18,19,18" VerticalOptions="Start">
                            <Label Text="{Binding Icon}" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <BoxView Grid.Row="1" WidthRequest="2" Color="{StaticResource GlassLine}"
                                 HorizontalOptions="Center" Margin="0,4,0,0"/>
                    </Grid>
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                        <VerticalStackLayout Spacing="2">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Title}"
                                       FontFamily="{StaticResource FontSans}" FontSize="13.5" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Grid.Column="1" Text="{Binding TimeDisplay}" IsVisible="{Binding HasTime}"
                                       FontFamily="{StaticResource FontSans}" FontSize="11"
                                       TextColor="{StaticResource InkTertiary}" VerticalOptions="Center"/>
                            </Grid>
                            <!-- warm-paper note with washi tape -->
                            <Grid Margin="0,10,0,0">
                                <Border BackgroundColor="{StaticResource PaperWarm}" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 3,8,9,4" Rotation="-0.6" Padding="12,12,12,9">
                                    <Border.Shadow>
                                        <Shadow Brush="#0D3A3C" Offset="0,2" Radius="6" Opacity="0.08"/>
                                    </Border.Shadow>
                                    <Label Text="{Binding Note}"
                                           FontFamily="{StaticResource FontSerifItalic}" FontSize="13.5"
                                           TextColor="{StaticResource NoteInk}"/>
                                </Border>
                                <BoxView WidthRequest="46" HeightRequest="15" Color="{StaticResource Washi}"
                                         Rotation="-3" HorizontalOptions="Start" VerticalOptions="Start"
                                         Margin="16,-7,0,0"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </DataTemplate>

            <!-- Standard: icon + title + time + sub (weight, glucose, appetite, seizure, dose) -->
            <DataTemplate x:Key="TimelineStandardTemplate">
                <Grid ColumnDefinitions="38,*" ColumnSpacing="13">
                    <Grid Grid.Column="0" RowDefinitions="38,*">
                        <Border WidthRequest="38" HeightRequest="38" Rotation="{Binding IconRotation}"
                                BackgroundColor="{Binding Tint}" StrokeThickness="0"
                                StrokeShape="RoundRectangle 19,18,19,18" VerticalOptions="Start">
                            <Label Text="{Binding Icon}" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <BoxView Grid.Row="1" WidthRequest="2" Color="{StaticResource GlassLine}"
                                 HorizontalOptions="Center" Margin="0,4,0,0"/>
                    </Grid>
                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                        <VerticalStackLayout Spacing="2">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Title}"
                                       FontFamily="{StaticResource FontSans}" FontSize="13.5" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <Label Grid.Column="1" Text="{Binding TimeDisplay}" IsVisible="{Binding HasTime}"
                                       FontFamily="{StaticResource FontSans}" FontSize="11"
                                       TextColor="{StaticResource InkTertiary}" VerticalOptions="Center"/>
                            </Grid>
                            <Label Text="{Binding Sub}" IsVisible="{Binding HasSub}"
                                   FontFamily="{StaticResource FontSans}" FontSize="12.5"
                                   TextColor="{StaticResource InkSecondary}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </DataTemplate>

            <views:TimelineTemplateSelector x:Key="TimelineSelector"
                    MoodTemplate="{StaticResource TimelineMoodTemplate}"
                    StandardTemplate="{StaticResource TimelineStandardTemplate}"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ================= JOURNAL ================= -->
        <ScrollView Grid.Row="0"
                x:Name="JournalScroll">

            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="18">

                <!-- 1 ── Header ─────────────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0"
                            Spacing="2">
                        <Label Text="{Binding CalendarVM.EyebrowText}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.3"
                               TextColor="{StaticResource InkSecondary}"/>
                        <Label Text="{loc:Translate Journal_Title}"
                               FontFamily="{StaticResource FontSerif}"
                               FontSize="{StaticResource TypeH1}"
                               TextColor="{StaticResource Ink}"
                               Margin="0,2,0,0"/>
                        <!-- hand-drawn squiggle underline -->
                        <Path Data="M2 5.5 Q 12 1 22 5 T 42 5 T 62 5 T 84 4"
                              Stroke="{StaticResource Teal}"
                              StrokeThickness="2.2"
                              StrokeLineCap="Round"
                              HeightRequest="8"
                              HorizontalOptions="Start"
                              Margin="1,3,0,0"/>
                    </VerticalStackLayout>

                    <!-- jump-to-today -->
                    <Border Grid.Column="1"
                            WidthRequest="38"
                            HeightRequest="38"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 19,18,18,19"
                            VerticalOptions="Start"
                            SemanticProperties.Description="{loc:Translate Journal_JumpToday}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnJumpTodayClicked"/>
                        </Border.GestureRecognizers>
                        <Grid WidthRequest="22"
                                HeightRequest="22"
                              HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Ellipse WidthRequest="20"
                                    HeightRequest="20"
                                     Stroke="{StaticResource InkSecondary}"
                                     StrokeThickness="1.8"
                                     HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            <Ellipse WidthRequest="7"
                                    HeightRequest="7"
                                     Stroke="{StaticResource InkSecondary}"
                                     StrokeThickness="1.8"
                                     HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2 ── Pet chips ─────────────────────────────────────── -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding CalendarVM.Pets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource GlassLine}"
                                        BackgroundColor="{StaticResource GlassSoft}"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="7,7,14,7">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                Binding="{Binding IsSelected}"
                                                Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="{StaticResource Ink}"/>
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectPetCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <HorizontalStackLayout Spacing="8"
                                            VerticalOptions="Center">
                                        <!-- Mini avatar with the pet's initial (serif italic) -->
                                        <Border WidthRequest="26"
                                                HeightRequest="26"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 13"
                                                BackgroundColor="{StaticResource TealTint}"
                                                VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                        Binding="{Binding IsSelected}"
                                                        Value="True">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#28FFFFFF"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Name, Converter={StaticResource FirstLetter}}"
                                                   FontFamily="{StaticResource FontSerifItalic}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource TealDeep}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                            Binding="{Binding IsSelected}"
                                                            Value="True">
                                                        <Setter Property="TextColor"
                                                                Value="{StaticResource White}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>

                                        <Label Text="{Binding Name}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkSecondary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                        Binding="{Binding IsSelected}"
                                                        Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{StaticResource White}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding AgeDisplay}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="12"
                                               TextColor="{StaticResource InkTertiary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                        Binding="{Binding IsSelected}"
                                                        Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{StaticResource GlassLine}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- 3 ── Week calendar (month label, arrows, sketched selection) -->
                <controls:WeekCalendarView
                    x:Name="Calendar"
                    SelectedDate="{Binding CalendarVM.CurrentSelectedDate, Mode=TwoWay}"
                    Activities="{Binding CalendarVM.WeekActivities}"/>

                <!-- 4 ── Date heading + relative label ─────────────────── -->
                <Grid ColumnDefinitions="*,Auto"
                        Margin="2,2,2,0">
                    <Label Grid.Column="0"
                           Text="{Binding CalendarVM.CurrentSelectedDate, StringFormat='{0:ddd, d MMM}'}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="21"
                           TextColor="{StaticResource Ink}"
                           VerticalOptions="End"/>
                    <Label Grid.Column="1"
                           Text="{Binding CalendarVM.RelativeDateLabel}"
                           FontFamily="{StaticResource FontHand}"
                           FontSize="18"
                           TextColor="{StaticResource TealDeep}"
                           VerticalOptions="End"/>
                </Grid>

                <!-- 5 ── "Still to do" chip row / all-done / past-day add ─── -->
                <!-- Replaces the old "Today's Tracking" card. Today drives the -->
                <!-- pending chips; past days show a single "add" affordance.    -->

                <!-- (a) Today, with things left: heading + wrapped chips + "+" -->
                <VerticalStackLayout Spacing="9"
                                     IsVisible="{Binding JournalVM.ShowStillToDo}">
                    <Label Text="{Binding JournalVM.Heading}"
                           FontFamily="{StaticResource FontSerifItalic}"
                           FontSize="15"
                           TextColor="{StaticResource InkSecondary}"
                           Margin="2,0,0,0"/>
                    <FlexLayout Wrap="Wrap"
                                AlignItems="Center"
                                BindableLayout.ItemsSource="{Binding JournalVM.Chips}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Rotation="{Binding Tilt}"
                                        Margin="0,0,8,8"
                                        BackgroundColor="{StaticResource GlassSoft}"
                                        Stroke="{StaticResource TealLine}"
                                        StrokeThickness="1.5"
                                        StrokeShape="RoundRectangle 14,11,13,12"
                                        Padding="13,9"
                                        SemanticProperties.Description="{Binding SemanticLabel}">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsMedication}" Value="True">
                                            <Setter Property="Stroke" Value="{StaticResource HoneyWarm}"/>
                                            <Setter Property="BackgroundColor" Value="{StaticResource HoneyWarmTint}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnChipTapped"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="7" VerticalOptions="Center">
                                        <Label Text="{Binding Icon}"
                                               FontSize="14"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding Label}"
                                               IsVisible="{Binding Label, Converter={StaticResource StringToBoolConverter}}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="12.5"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TealDeep}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsMedication}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource HoneyWarmDeep}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Text="{Binding Detail}"
                                               IsVisible="{Binding HasDetail}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkTertiary}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>

                <!-- (b) Today, all done: paw celebration + quiet add chip -->
                <VerticalStackLayout Spacing="8"
                                     Padding="2,4,0,0"
                                     IsVisible="{Binding JournalVM.ShowAllDone}">
                    <HorizontalStackLayout x:Name="PawRow" Spacing="14">
                        <Label x:Name="Paw1" Text="🐾" FontSize="20" Rotation="-14" Opacity="0"/>
                        <Label x:Name="Paw2" Text="🐾" FontSize="20" Rotation="10" TranslationY="-5" Opacity="0"/>
                        <Label x:Name="Paw3" Text="🐾" FontSize="20" Rotation="-8" Opacity="0"/>
                        <Label x:Name="Paw4" Text="🐾" FontSize="20" Rotation="12" TranslationY="-5" Opacity="0"/>
                    </HorizontalStackLayout>
                    <Label Text="{Binding JournalVM.CelebrationText}"
                           FontFamily="{StaticResource FontHand}"
                           FontSize="20"
                           TextColor="{StaticResource TealDeep}"/>
                    <Border BackgroundColor="{StaticResource GlassSoft}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14,11,13,12"
                            Padding="13,9"
                            HorizontalOptions="Start"
                            Margin="0,4,0,0"
                            SemanticProperties.Description="Add something else">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding JournalVM.OpenAddSheetCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate Journal_ChipAddMore}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="12.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- (c) A past day: a single "add to this day" chip -->
                <Border IsVisible="{Binding JournalVM.ShowPastAdd}"
                        BackgroundColor="{StaticResource GlassSoft}"
                        Stroke="{StaticResource GlassLine}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 14,11,13,12"
                        Padding="13,9"
                        HorizontalOptions="Start"
                        SemanticProperties.Description="Add to this day">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding JournalVM.OpenAddSheetCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="{loc:Translate Journal_ChipAddDay}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12.5"
                           FontAttributes="Bold"
                           TextColor="{StaticResource InkTertiary}"/>
                </Border>
                <!-- 6 ── Day heading (italic serif) ────────────────────── -->
                <Label Text="{Binding CalendarVM.DayHeading}"
                       FontFamily="{StaticResource FontSerifItalic}"
                       FontSize="17"
                       TextColor="{StaticResource Ink}"
                       Margin="2,6,0,0"/>

                <!-- 7 ── Timeline ──────────────────────────────────────── -->
                <VerticalStackLayout x:Name="TimelineSection"
                        Spacing="4">

                    <!-- One chronological list of everything logged for the day
                         (mood, weight, glucose, appetite, seizures, doses), sorted
                         purely by time in JournalVM. Two card layouts via the
                         TimelineSelector; a single ordering. -->
                    <VerticalStackLayout Spacing="4"
                                         BindableLayout.ItemsSource="{Binding JournalVM.TimelineItems}"
                                         BindableLayout.ItemTemplateSelector="{StaticResource TimelineSelector}"/>


                    <!-- Empty state: sleeping-cat doodle -->
                    <VerticalStackLayout IsVisible="{Binding JournalVM.IsTimelineEmpty}"
                                         HorizontalOptions="Center"
                                         Spacing="6"
                                         Padding="24,34,24,40">
                        <!-- single-stroke cat: tail + body + head + ears + eyes -->
                        <Path Data="M14 46 q-9 -1 -8 -9 q1 -6 8 -6 M13 40 a21 13 0 1 0 42 0 a21 13 0 1 0 -42 0 M45.5 32 a9.5 9.5 0 1 0 19 0 a9.5 9.5 0 1 0 -19 0 M49 24 l-1.5 -6 5 3.5 M60 23.5 l2 -5.5 3 5 M51 32 q1.8 1.8 3.6 0 M58 32 q1.8 1.8 3.6 0"
                              Stroke="{StaticResource TealDeep}"
                              StrokeThickness="1.8"
                              StrokeLineCap="Round"
                              StrokeLineJoin="Round"
                              Opacity="0.8"
                              WidthRequest="76"
                                HeightRequest="58"
                              HorizontalOptions="Center"/>
                        <Label Text="{Binding CalendarVM.EmptyHeadline}"
                               FontFamily="{StaticResource FontHand}"
                               FontSize="24"
                               TextColor="{StaticResource TealDeep}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Journal_EmptySub}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="12.5"
                                FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- (The all-care-complete celebration now lives in the chip row
                         area above, driven by JournalVM.ShowAllDone.) -->

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= TAB BAR ================= -->
        <controls:BottomNavigation Grid.Row="1"
                                   ActiveTab="Calendar"/>

        <!-- Confirm micro-interaction: bubbles rising from a tapped action.
             Full-bleed, input-transparent overlay above every layer. -->
        <AbsoluteLayout x:Name="EffectLayer"
                        Grid.RowSpan="2"
                        InputTransparent="True"
                        IsClippedToBounds="False"/>

        <!-- Toast: warm confirmation pill, floats above the tab bar. -->
        <Border x:Name="Toast"
                Grid.RowSpan="2"
                Opacity="0"
                InputTransparent="True"
                BackgroundColor="{StaticResource Ink}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18,15,14,17"
                Rotation="-0.5"
                Padding="14,11"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,92">
            <Border.Shadow>
                <Shadow Brush="#0D3A3C"
                        Offset="0,12"
                        Radius="34"
                        Opacity="0.20"/>
            </Border.Shadow>
            <HorizontalStackLayout Spacing="8"
                    VerticalOptions="Center">
                <Label Text="✓"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="13"
                        FontAttributes="Bold"
                       TextColor="{StaticResource MGreat}"
                       VerticalOptions="Center"/>
                <Label x:Name="ToastLabel"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="13"
                        FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"/>
                <!-- Undo: the safety net for one-tap logging. Reachable by screen
                     reader while the toast is up. -->
                <Border x:Name="UndoButton"
                        IsVisible="False"
                        BackgroundColor="#1FFFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        Padding="12,6"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Undo">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUndoTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Undo"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12.5"
                           FontAttributes="Bold"
                           TextColor="#8FE3CD"/>
                </Border>
            </HorizontalStackLayout>
        </Border>

        <!-- Journal input sheets (all share FelovaBottomSheet). Overlays above every
             layer; input-transparent when closed so they never block the Journal. -->
        <views:GlucoseSheetView Grid.RowSpan="2" BindingContext="{Binding GlucoseSheetVM}"/>
        <views:MoodSheetView Grid.RowSpan="2" BindingContext="{Binding MoodSheetVM}"/>
        <views:WeightSheetView Grid.RowSpan="2" BindingContext="{Binding WeightSheetVM}"/>
        <views:AppetiteSheetView Grid.RowSpan="2" BindingContext="{Binding AppetiteSheetVM}"/>
        <views:SeizureSheetView Grid.RowSpan="2" BindingContext="{Binding SeizureSheetVM}"/>
        <views:AddAnythingSheetView Grid.RowSpan="2" BindingContext="{Binding JournalVM}"/>

    </Grid>

</ContentPage>
