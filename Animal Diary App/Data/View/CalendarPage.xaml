<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             x:Class="Animal_Diary_App.Data.View.CalendarPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <!-- Felova card surface -->
            <Style x:Key="CardSurface" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource Card}"/>
                <Setter Property="Stroke" Value="{StaticResource Line}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 22"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

            <!-- Uppercase section eyebrow -->
            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.3"/>
                <Setter Property="TextColor" Value="{StaticResource InkSecondary}"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ================= JOURNAL ================= -->
        <ScrollView Grid.Row="0">

            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="18">

                <!-- Header -->
                <VerticalStackLayout Spacing="2">
                    <Label Text="{loc:Translate Journal_Eyebrow}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="11"
                           FontAttributes="Bold"
                           CharacterSpacing="1.3"
                           TextColor="{StaticResource InkTertiary}"/>
                    <Label Text="{loc:Translate Journal_Title}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="{StaticResource TypeH1}"
                           TextColor="{StaticResource Ink}"/>
                </VerticalStackLayout>

                <!-- Pet selector chips -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding CalendarVM.Pets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource Line}"
                                        BackgroundColor="{StaticResource Card}"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="7,7,14,7">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Ink}"/>
                                            <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectPetCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                        <!-- Mini avatar -->
                                        <Border WidthRequest="26"
                                                HeightRequest="26"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 13"
                                                BackgroundColor="{StaticResource ViolaTint}"
                                                VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#28FFFFFF"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="🐾"
                                                   FontSize="12"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <Label Text="{Binding Name}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkSecondary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource White}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding AgeDisplay}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="12"
                                               TextColor="{StaticResource InkTertiary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource ViolaLine}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Week calendar -->
                <controls:WeekCalendarView
                    x:Name="Calendar"
                    SelectedDate="{Binding CalendarVM.CurrentSelectedDate, Mode=TwoWay}"
                    Activities="{Binding CalendarVM.WeekActivities}"/>

                <!-- Selected date -->
                <Label Text="{Binding CalendarVM.SelectedDateDisplay}"
                       FontFamily="{StaticResource FontSerif}"
                       FontSize="21"
                       TextColor="{StaticResource Ink}"
                       Margin="2,2,0,0"/>

                <!-- Quick-log tiles -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="9">

                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource Card}"
                            Stroke="{StaticResource ViolaLine}"
                            StrokeThickness="1.5"
                            StrokeDashArray="4,3"
                            StrokeShape="RoundRectangle 16"
                            Padding="13,13,13,11"
                            IsVisible="{Binding CalendarVM.MoodSection.IsAddButtonVisible}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CalendarVM.ShowMoodInputCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="7">
                            <Label Text="😊" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="{loc:Translate Calendar_MoodAdd}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource ViolaDeep}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource Card}"
                            Stroke="{StaticResource ViolaLine}"
                            StrokeThickness="1.5"
                            StrokeDashArray="4,3"
                            StrokeShape="RoundRectangle 16"
                            Padding="13,13,13,11"
                            IsVisible="{Binding CalendarVM.WeightSection.IsAddButtonVisible}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CalendarVM.ShowWeightInputCommand}"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="7">
                            <Label Text="⚖️" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="{loc:Translate Calendar_WeightAdd}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource ViolaDeep}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Mood input -->
                <Border Style="{StaticResource CardSurface}"
                        IsVisible="{Binding CalendarVM.MoodSection.IsInputVisible}">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="{loc:Translate Calendar_HowFeeling}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Ink}"/>

                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">

                            <!-- 1 · Very bad -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource Card}"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="2,12">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="1">
                                        <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}" CommandParameter="1"/>
                                </Border.GestureRecognizers>
                                <Border WidthRequest="34" HeightRequest="34" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 17" BackgroundColor="#F44336"
                                        HorizontalOptions="Center">
                                    <Label Text="😢" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Border>

                            <!-- 2 · Bad -->
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource Card}"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="2,12">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="2">
                                        <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}" CommandParameter="2"/>
                                </Border.GestureRecognizers>
                                <Border WidthRequest="34" HeightRequest="34" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 17" BackgroundColor="#FF9800"
                                        HorizontalOptions="Center">
                                    <Label Text="😟" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Border>

                            <!-- 3 · Neutral -->
                            <Border Grid.Column="2"
                                    BackgroundColor="{StaticResource Card}"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="2,12">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="3">
                                        <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}" CommandParameter="3"/>
                                </Border.GestureRecognizers>
                                <Border WidthRequest="34" HeightRequest="34" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 17" BackgroundColor="#FFC107"
                                        HorizontalOptions="Center">
                                    <Label Text="😐" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Border>

                            <!-- 4 · Good -->
                            <Border Grid.Column="3"
                                    BackgroundColor="{StaticResource Card}"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="2,12">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="4">
                                        <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}" CommandParameter="4"/>
                                </Border.GestureRecognizers>
                                <Border WidthRequest="34" HeightRequest="34" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 17" BackgroundColor="#4CAF50"
                                        HorizontalOptions="Center">
                                    <Label Text="😊" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Border>

                            <!-- 5 · Excellent -->
                            <Border Grid.Column="4"
                                    BackgroundColor="{StaticResource Card}"
                                    Stroke="{StaticResource Line}"
                                    StrokeThickness="1.5"
                                    StrokeShape="RoundRectangle 15"
                                    Padding="2,12">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding CalendarVM.SelectedMoodLevel}" Value="5">
                                        <Setter Property="Stroke" Value="{StaticResource Ink}"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectMoodCommand}" CommandParameter="5"/>
                                </Border.GestureRecognizers>
                                <Border WidthRequest="34" HeightRequest="34" StrokeThickness="0"
                                        StrokeShape="RoundRectangle 17" BackgroundColor="#2D5016"
                                        HorizontalOptions="Center">
                                    <Label Text="😄" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Border>
                        </Grid>

                        <Button Text="{loc:Translate Calendar_ConfirmMood}"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="15"
                                FontAttributes="Bold"
                                HeightRequest="48"
                                CornerRadius="14"
                                BackgroundColor="{StaticResource Viola}"
                                TextColor="{StaticResource White}"
                                Command="{Binding CalendarVM.OnMoodEntryCompleted}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Weight input -->
                <Border Style="{StaticResource CardSurface}"
                        IsVisible="{Binding CalendarVM.WeightSection.IsInputVisible}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{loc:Translate Calendar_Weight}"
                               Style="{StaticResource SectionLabel}"/>
                        <Border BackgroundColor="{StaticResource Card}"
                                Stroke="{StaticResource Line}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 13"
                                Padding="14,4">
                            <Entry Placeholder="{loc:Translate Calendar_WeightPlaceholder}"
                                   Text="{Binding CalendarVM.EnteredWeight}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="16"
                                   Keyboard="Numeric"
                                   Completed="OnWeightEntryCompleted"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Day timeline -->
                <Label Text="{loc:Translate Journal_DayTimeline}"
                       Style="{StaticResource SectionLabel}"
                       Margin="0,4,0,0"/>

                <Border Style="{StaticResource CardSurface}">
                    <VerticalStackLayout Spacing="14">

                        <!-- Mood row -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="38" HeightRequest="38"
                                    BackgroundColor="{StaticResource ViolaTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                    VerticalOptions="Center">
                                <Label Text="😊" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Main_MoodLabel}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="11" FontAttributes="Bold"
                                       CharacterSpacing="0.6"
                                       TextColor="{StaticResource InkTertiary}"/>
                                <Label Text="{Binding CalendarVM.ShownMoodDisplay}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding CalendarVM.HasMood}" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                            <Setter Property="FontAttributes" Value="Italic"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource Line}"/>

                        <!-- Weight row -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="38" HeightRequest="38"
                                    BackgroundColor="{StaticResource SageTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                    VerticalOptions="Center">
                                <Label Text="⚖️" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label Text="{loc:Translate Calendar_Weight}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="11" FontAttributes="Bold"
                                       CharacterSpacing="0.6"
                                       TextColor="{StaticResource InkTertiary}"/>
                                <Label Text="{Binding CalendarVM.ShownWeightDisplay}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding CalendarVM.HasWeight}" Value="False">
                                            <Setter Property="Opacity" Value="0.5"/>
                                            <Setter Property="FontAttributes" Value="Italic"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource Line}"/>

                        <!-- Medications -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border WidthRequest="38" HeightRequest="38"
                                    BackgroundColor="{StaticResource HoneyTint}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                    VerticalOptions="Center">
                                <Label Text="💊" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{loc:Translate Calendar_Medications}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="0.6"
                                   TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Empty state -->
                        <Label Text="{loc:Translate Calendar_NoMedications}"
                               FontFamily="{StaticResource FontSerif}"
                               FontAttributes="Italic"
                               FontSize="13.5"
                               TextColor="{StaticResource InkTertiary}"
                               IsVisible="{Binding CalendarVM.HasNoDoses}"/>

                        <!-- Dose checklist -->
                        <VerticalStackLayout Spacing="9"
                                             BindableLayout.ItemsSource="{Binding CalendarVM.DosesForSelectedDate}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="{StaticResource Cream}"
                                            Stroke="{StaticResource Line}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="12,11">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">

                                            <!-- Time -->
                                            <Label Grid.Column="0"
                                                   Text="{Binding TimeDisplay}"
                                                   FontFamily="{StaticResource FontSans}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource InkSecondary}"
                                                   VerticalOptions="Center"
                                                   WidthRequest="44"/>

                                            <!-- Name + dose + status -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                <Label Text="{Binding MedName}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="13.5"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Ink}"/>
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="{Binding DoseDisplay}"
                                                           FontFamily="{StaticResource FontSans}"
                                                           FontSize="11.5"
                                                           TextColor="{StaticResource InkTertiary}"/>
                                                    <Label Text="·"
                                                           FontSize="11.5"
                                                           TextColor="{StaticResource InkTertiary}"/>
                                                    <Label Text="{Binding StatusText}"
                                                           FontFamily="{StaticResource FontSans}"
                                                           FontSize="11.5"
                                                           TextColor="{StaticResource InkTertiary}"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <!-- Skip (secondary) -->
                                            <Border Grid.Column="2"
                                                    IsVisible="{Binding ShowSkip}"
                                                    Padding="10,5"
                                                    BackgroundColor="{StaticResource PaperDeep}"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 999"
                                                    VerticalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SkipDoseCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="{loc:Translate Calendar_Skip}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="11"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource InkSecondary}"/>
                                            </Border>

                                            <!-- Taken check (primary) -->
                                            <Border Grid.Column="3"
                                                    WidthRequest="34"
                                                    HeightRequest="34"
                                                    BackgroundColor="Transparent"
                                                    Stroke="{StaticResource Line}"
                                                    StrokeThickness="2"
                                                    StrokeShape="RoundRectangle 17"
                                                    VerticalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding CanToggle}" Value="False">
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsSkipped}" Value="True">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsTaken}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="{StaticResource Sage}"/>
                                                        <Setter Property="Stroke" Value="{StaticResource Sage}"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.ToggleDoseTakenCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="{Binding StatusGlyph}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource White}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= TAB BAR ================= -->
        <Border Grid.Row="1"
                Margin="16,0,16,16"
                Padding="7"
                BackgroundColor="{StaticResource Card}"
                Stroke="{StaticResource Line}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                VerticalOptions="End">

            <Border.Shadow>
                <Shadow Brush="#241E2E" Offset="0,10" Radius="24" Opacity="0.16"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*">

                <!-- MAIN -->
                <Grid Grid.Column="0" Padding="0,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMainClicked"/>
                    </Grid.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="🏠" FontSize="20" HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Main}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5" FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- CALENDAR (active) -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource ViolaTint}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 17"
                        Padding="0,8">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="📅" FontSize="20" HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Calendar}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5" FontAttributes="Bold"
                               TextColor="{StaticResource ViolaDeep}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- PETS -->
                <Grid Grid.Column="2" Padding="0,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPetsClicked"/>
                    </Grid.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                        <Label Text="🐾" FontSize="20" HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Nav_Pets}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="10.5" FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </Border>

    </Grid>

</ContentPage>
