<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:loc="clr-namespace:Animal_Diary_App.Helpers"
             xmlns:controls="clr-namespace:Animal_Diary_App.Data.View.Controls"
             xmlns:views="clr-namespace:Animal_Diary_App.Data.View"
             x:Class="Animal_Diary_App.Data.View.CalendarPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#C4E6E3">

    <ContentPage.Resources>
        <ResourceDictionary>

            <helpers:FirstLetterConverter x:Key="FirstLetter"/>

            <!-- Frosted glass card surface -->
            <Style x:Key="GlassCard"
                    TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{StaticResource Glass}"/>
                <Setter Property="Stroke"
                        Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness"
                        Value="1"/>
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 17,14,15,18"/>
                <Setter Property="Padding"
                        Value="14"/>
            </Style>

            <!-- Uppercase section eyebrow -->
            <Style x:Key="SectionLabel"
                    TargetType="Label">
                <Setter Property="FontFamily"
                        Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"
                        Value="11"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="CharacterSpacing"
                        Value="1.3"/>
                <Setter Property="TextColor"
                        Value="{StaticResource InkSecondary}"/>
            </Style>

            <!-- ============================================================ -->
            <!-- Tracker Hub input templates (one per InputKind).              -->
            <!-- Rendered inside the hub panel *under* its title, so they are  -->
            <!-- lean: just the input + a Save affordance. BindingContext is a -->
            <!-- TrackerLeaf. Scale / Boolean / Dose chips save (and collapse) -->
            <!-- on tap; Numeric / Text / Event / Mood commit via a button.    -->
            <!-- ============================================================ -->

            <Style x:Key="TrackChip"
                    TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{StaticResource Glass}"/>
                <Setter Property="Stroke"
                        Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness"
                        Value="1.5"/>
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 12"/>
                <Setter Property="Padding"
                        Value="0,11"/>
            </Style>
            <Style x:Key="TrackField"
                    TargetType="Border">
                <Setter Property="BackgroundColor"
                        Value="{StaticResource Glass}"/>
                <Setter Property="Stroke"
                        Value="{StaticResource GlassLine}"/>
                <Setter Property="StrokeThickness"
                        Value="1"/>
                <Setter Property="StrokeShape"
                        Value="RoundRectangle 13"/>
                <Setter Property="Padding"
                        Value="14,4"/>
            </Style>
            <Style x:Key="LeafSaveButton"
                    TargetType="Button">
                <Setter Property="FontFamily"
                        Value="{StaticResource FontSans}"/>
                <Setter Property="FontSize"
                        Value="15"/>
                <Setter Property="FontAttributes"
                        Value="Bold"/>
                <Setter Property="HeightRequest"
                        Value="48"/>
                <Setter Property="CornerRadius"
                        Value="14"/>
                <Setter Property="BackgroundColor"
                        Value="{StaticResource Teal}"/>
                <Setter Property="TextColor"
                        Value="{StaticResource White}"/>
            </Style>

            <!-- Mood: the bespoke 5-emoji picker + an optional note, saved together -->
            <DataTemplate x:Key="LeafMoodTemplate">
                <VerticalStackLayout Spacing="14">
                    <Grid ColumnDefinitions="*,*,*,*,*"
                            ColumnSpacing="8">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource Glass}"
                                Stroke="{StaticResource GlassLine}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 15,12,13,14"
                                Padding="2,12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding MoodLevelValue}"
                                        Value="1">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Ink}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectMoodCommand}"
                                        CommandParameter="1"/>
                            </Border.GestureRecognizers>
                            <Border WidthRequest="34"
                                    HeightRequest="34"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 17"
                                    BackgroundColor="{StaticResource MUnwell}"
                                    HorizontalOptions="Center">
                                <Label Text="😢"
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                            </Border>
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="{StaticResource Glass}"
                                Stroke="{StaticResource GlassLine}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 12,15,14,13"
                                Padding="2,12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding MoodLevelValue}"
                                        Value="2">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Ink}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectMoodCommand}"
                                        CommandParameter="2"/>
                            </Border.GestureRecognizers>
                            <Border WidthRequest="34"
                                    HeightRequest="34"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 17"
                                    BackgroundColor="{StaticResource MLow}"
                                    HorizontalOptions="Center">
                                <Label Text="😟"
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                            </Border>
                        </Border>

                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource Glass}"
                                Stroke="{StaticResource GlassLine}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 15,12,13,14"
                                Padding="2,12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding MoodLevelValue}"
                                        Value="3">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Ink}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectMoodCommand}"
                                        CommandParameter="3"/>
                            </Border.GestureRecognizers>
                            <Border WidthRequest="34"
                                    HeightRequest="34"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 17"
                                    BackgroundColor="{StaticResource MOkay}"
                                    HorizontalOptions="Center">
                                <Label Text="😐"
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                            </Border>
                        </Border>

                        <Border Grid.Column="3"
                                BackgroundColor="{StaticResource Glass}"
                                Stroke="{StaticResource GlassLine}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 12,15,14,13"
                                Padding="2,12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding MoodLevelValue}"
                                        Value="4">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Ink}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectMoodCommand}"
                                        CommandParameter="4"/>
                            </Border.GestureRecognizers>
                            <Border WidthRequest="34"
                                    HeightRequest="34"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 17"
                                    BackgroundColor="{StaticResource MGood}"
                                    HorizontalOptions="Center">
                                <Label Text="😊"
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                            </Border>
                        </Border>

                        <Border Grid.Column="4"
                                BackgroundColor="{StaticResource Glass}"
                                Stroke="{StaticResource GlassLine}"
                                StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 15,12,13,14"
                                Padding="2,12">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding MoodLevelValue}"
                                        Value="5">
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Ink}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectMoodCommand}"
                                        CommandParameter="5"/>
                            </Border.GestureRecognizers>
                            <Border WidthRequest="34"
                                    HeightRequest="34"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 17"
                                    BackgroundColor="{StaticResource MGreat}"
                                    HorizontalOptions="Center">
                                <Label Text="😄"
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                            </Border>
                        </Border>
                    </Grid>

                    <!-- Optional free-text note saved with the mood -->
                    <Border Style="{StaticResource TrackField}"
                            Padding="12,6">
                        <Editor Text="{Binding MoodNoteText}"
                                Placeholder="Add a note about today… (optional)"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="60"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="14"
                                TextColor="{StaticResource Ink}"
                                PlaceholderColor="{StaticResource InkTertiary}"/>
                    </Border>

                    <Button Text="Save"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource LeafSaveButton}"/>
                </VerticalStackLayout>
            </DataTemplate>

            <!-- Numeric + Volume + Weight (unit label distinguishes them) -->
            <DataTemplate x:Key="LeafNumericTemplate">
                <VerticalStackLayout Spacing="12">
                    <Border Style="{StaticResource TrackField}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry Text="{Binding ValueText}"
                                   Keyboard="Numeric"
                                   Placeholder="—"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="18"
                                   TextColor="{StaticResource Ink}"
                                   PlaceholderColor="{StaticResource InkTertiary}"
                                   Completed="OnTrackingValueCompleted"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Unit}"
                                   IsVisible="{Binding HasUnit}"
                                   FontFamily="{StaticResource FontSans}"
                                   FontSize="14"
                                   TextColor="{StaticResource InkTertiary}"
                                   VerticalOptions="Center"
                                   Margin="6,0,4,0"/>
                        </Grid>
                    </Border>
                    <Button Text="Save"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource LeafSaveButton}"/>
                </VerticalStackLayout>
            </DataTemplate>

            <!-- Scale 1–5 (saves + collapses on tap) -->
            <DataTemplate x:Key="LeafScaleTemplate">
                <Grid ColumnDefinitions="*,*,*,*,*"
                        ColumnSpacing="8">
                    <Border Grid.Column="0"
                            Style="{StaticResource TrackChip}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                    Binding="{Binding ScaleValue}"
                                    Value="1">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke"
                                        Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectScaleCommand}"
                                    CommandParameter="1"/>
                        </Border.GestureRecognizers>
                        <Label Text="1"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource InkSecondary}"
                                HorizontalOptions="Center"/>
                    </Border>
                    <Border Grid.Column="1"
                            Style="{StaticResource TrackChip}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                    Binding="{Binding ScaleValue}"
                                    Value="2">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke"
                                        Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectScaleCommand}"
                                    CommandParameter="2"/>
                        </Border.GestureRecognizers>
                        <Label Text="2"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource InkSecondary}"
                                HorizontalOptions="Center"/>
                    </Border>
                    <Border Grid.Column="2"
                            Style="{StaticResource TrackChip}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                    Binding="{Binding ScaleValue}"
                                    Value="3">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke"
                                        Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectScaleCommand}"
                                    CommandParameter="3"/>
                        </Border.GestureRecognizers>
                        <Label Text="3"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource InkSecondary}"
                                HorizontalOptions="Center"/>
                    </Border>
                    <Border Grid.Column="3"
                            Style="{StaticResource TrackChip}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                    Binding="{Binding ScaleValue}"
                                    Value="4">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke"
                                        Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectScaleCommand}"
                                    CommandParameter="4"/>
                        </Border.GestureRecognizers>
                        <Label Text="4"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource InkSecondary}"
                                HorizontalOptions="Center"/>
                    </Border>
                    <Border Grid.Column="4"
                            Style="{StaticResource TrackChip}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                    Binding="{Binding ScaleValue}"
                                    Value="5">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke"
                                        Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectScaleCommand}"
                                    CommandParameter="5"/>
                        </Border.GestureRecognizers>
                        <Label Text="5"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="{StaticResource InkSecondary}"
                                HorizontalOptions="Center"/>
                    </Border>
                </Grid>
            </DataTemplate>

            <!-- Boolean (yes / no, saves + collapses on tap) -->
            <DataTemplate x:Key="LeafBooleanTemplate">
                <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="9">
                    <Border Grid.Column="0"
                            Style="{StaticResource TrackChip}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                    Binding="{Binding BoolState}"
                                    Value="1">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke"
                                        Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetBoolCommand}"
                                    CommandParameter="yes"/>
                        </Border.GestureRecognizers>
                        <Label Text="Yes"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource InkSecondary}"
                                HorizontalOptions="Center"/>
                    </Border>
                    <Border Grid.Column="1"
                            Style="{StaticResource TrackChip}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                    Binding="{Binding BoolState}"
                                    Value="2">
                                <Setter Property="BackgroundColor"
                                        Value="{StaticResource TealTint}"/>
                                <Setter Property="Stroke"
                                        Value="{StaticResource Teal}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetBoolCommand}"
                                    CommandParameter="no"/>
                        </Border.GestureRecognizers>
                        <Label Text="No"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource InkSecondary}"
                                HorizontalOptions="Center"/>
                    </Border>
                </Grid>
            </DataTemplate>

            <!-- Dose (given / skipped, saves + collapses on tap) -->
            <DataTemplate x:Key="LeafDoseTemplate">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,*"
                            ColumnSpacing="9">
                        <Border Grid.Column="0"
                                Style="{StaticResource TrackChip}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding DoseState}"
                                        Value="1">
                                    <Setter Property="BackgroundColor"
                                            Value="{StaticResource TealTint}"/>
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Teal}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetDoseCommand}"
                                        CommandParameter="given"/>
                            </Border.GestureRecognizers>
                            <Label Text="Given"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource InkSecondary}"
                                    HorizontalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="1"
                                Style="{StaticResource TrackChip}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding DoseState}"
                                        Value="2">
                                    <Setter Property="BackgroundColor"
                                            Value="{StaticResource TealTint}"/>
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Teal}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetDoseCommand}"
                                        CommandParameter="skipped"/>
                            </Border.GestureRecognizers>
                            <Label Text="Skip"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="15"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource InkSecondary}"
                                    HorizontalOptions="Center"/>
                        </Border>
                    </Grid>
                    <Label Text="{Binding Summary}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12"
                           TextColor="{StaticResource InkTertiary}"/>
                </VerticalStackLayout>
            </DataTemplate>

            <!-- Text / Note -->
            <DataTemplate x:Key="LeafTextTemplate">
                <VerticalStackLayout Spacing="12">
                    <Border Style="{StaticResource TrackField}"
                            Padding="12,6">
                        <Editor Text="{Binding NoteText}"
                                Placeholder="Add a note…"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="70"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="14"
                                TextColor="{StaticResource Ink}"
                                PlaceholderColor="{StaticResource InkTertiary}"/>
                    </Border>
                    <Button Text="Save note"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource LeafSaveButton}"/>
                </VerticalStackLayout>
            </DataTemplate>

            <!-- Event (severity + duration + note, e.g. a seizure) -->
            <DataTemplate x:Key="LeafEventTemplate">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Severity"
                           Style="{StaticResource SectionLabel}"/>
                    <Grid ColumnDefinitions="*,*,*,*,*"
                            ColumnSpacing="8">
                        <Border Grid.Column="0"
                                Style="{StaticResource TrackChip}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding SeverityValue}"
                                        Value="1">
                                    <Setter Property="BackgroundColor"
                                            Value="{StaticResource TealTint}"/>
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Teal}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSeverityCommand}"
                                        CommandParameter="1"/>
                            </Border.GestureRecognizers>
                            <Label Text="1"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource InkSecondary}"
                                    HorizontalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="1"
                                Style="{StaticResource TrackChip}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding SeverityValue}"
                                        Value="2">
                                    <Setter Property="BackgroundColor"
                                            Value="{StaticResource TealTint}"/>
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Teal}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSeverityCommand}"
                                        CommandParameter="2"/>
                            </Border.GestureRecognizers>
                            <Label Text="2"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource InkSecondary}"
                                    HorizontalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="2"
                                Style="{StaticResource TrackChip}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding SeverityValue}"
                                        Value="3">
                                    <Setter Property="BackgroundColor"
                                            Value="{StaticResource TealTint}"/>
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Teal}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSeverityCommand}"
                                        CommandParameter="3"/>
                            </Border.GestureRecognizers>
                            <Label Text="3"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource InkSecondary}"
                                    HorizontalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="3"
                                Style="{StaticResource TrackChip}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding SeverityValue}"
                                        Value="4">
                                    <Setter Property="BackgroundColor"
                                            Value="{StaticResource TealTint}"/>
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Teal}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSeverityCommand}"
                                        CommandParameter="4"/>
                            </Border.GestureRecognizers>
                            <Label Text="4"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource InkSecondary}"
                                    HorizontalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="4"
                                Style="{StaticResource TrackChip}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                        Binding="{Binding SeverityValue}"
                                        Value="5">
                                    <Setter Property="BackgroundColor"
                                            Value="{StaticResource TealTint}"/>
                                    <Setter Property="Stroke"
                                            Value="{StaticResource Teal}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectSeverityCommand}"
                                        CommandParameter="5"/>
                            </Border.GestureRecognizers>
                            <Label Text="5"
                                    FontFamily="{StaticResource FontSans}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource InkSecondary}"
                                    HorizontalOptions="Center"/>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource TrackField}">
                        <Entry Text="{Binding DurationText}"
                               Keyboard="Numeric"
                               Placeholder="Duration (minutes)"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="15"
                               TextColor="{StaticResource Ink}"
                               PlaceholderColor="{StaticResource InkTertiary}"/>
                    </Border>
                    <Border Style="{StaticResource TrackField}"
                            Padding="12,6">
                        <Editor Text="{Binding EventNote}"
                                Placeholder="What happened?"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="52"
                                FontFamily="{StaticResource FontSans}"
                                FontSize="14"
                                TextColor="{StaticResource Ink}"
                                PlaceholderColor="{StaticResource InkTertiary}"/>
                    </Border>
                    <Button Text="Log"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource LeafSaveButton}"/>
                </VerticalStackLayout>
            </DataTemplate>

            <!-- Selector: maps a leaf's TemplateKind → input template -->
            <views:LeafInputTemplateSelector x:Key="LeafInputSelector"
                    MoodTemplate="{StaticResource LeafMoodTemplate}"
                    NumericTemplate="{StaticResource LeafNumericTemplate}"
                    ScaleTemplate="{StaticResource LeafScaleTemplate}"
                    BooleanTemplate="{StaticResource LeafBooleanTemplate}"
                    DoseTemplate="{StaticResource LeafDoseTemplate}"
                    TextTemplate="{StaticResource LeafTextTemplate}"
                    EventTemplate="{StaticResource LeafEventTemplate}"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Water background — bottom layer, spans the whole page -->
        <controls:WaterBackground Grid.RowSpan="2"/>

        <!-- ================= JOURNAL ================= -->
        <ScrollView Grid.Row="0"
                x:Name="JournalScroll">

            <VerticalStackLayout Padding="22,26,22,20"
                                 Spacing="18">

                <!-- 1 ── Header ─────────────────────────────────────────── -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0"
                            Spacing="2">
                        <Label Text="{Binding CalendarVM.EyebrowText}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1.3"
                               TextColor="{StaticResource InkSecondary}"/>
                        <Label Text="{loc:Translate Journal_Title}"
                               FontFamily="{StaticResource FontSerif}"
                               FontSize="{StaticResource TypeH1}"
                               TextColor="{StaticResource Ink}"
                               Margin="0,2,0,0"/>
                        <!-- hand-drawn squiggle underline -->
                        <Path Data="M2 5.5 Q 12 1 22 5 T 42 5 T 62 5 T 84 4"
                              Stroke="{StaticResource Teal}"
                              StrokeThickness="2.2"
                              StrokeLineCap="Round"
                              HeightRequest="8"
                              HorizontalOptions="Start"
                              Margin="1,3,0,0"/>
                    </VerticalStackLayout>

                    <!-- jump-to-today -->
                    <Border Grid.Column="1"
                            WidthRequest="38"
                            HeightRequest="38"
                            BackgroundColor="{StaticResource Glass}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 19,18,18,19"
                            VerticalOptions="Start"
                            SemanticProperties.Description="{loc:Translate Journal_JumpToday}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnJumpTodayClicked"/>
                        </Border.GestureRecognizers>
                        <Grid WidthRequest="22"
                                HeightRequest="22"
                              HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Ellipse WidthRequest="20"
                                    HeightRequest="20"
                                     Stroke="{StaticResource InkSecondary}"
                                     StrokeThickness="1.8"
                                     HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                            <Ellipse WidthRequest="7"
                                    HeightRequest="7"
                                     Stroke="{StaticResource InkSecondary}"
                                     StrokeThickness="1.8"
                                     HorizontalOptions="Center"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2 ── Pet chips ─────────────────────────────────────── -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding CalendarVM.Pets}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeThickness="1"
                                        Stroke="{StaticResource GlassLine}"
                                        BackgroundColor="{StaticResource GlassSoft}"
                                        StrokeShape="RoundRectangle 999"
                                        Padding="7,7,14,7">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                Binding="{Binding IsSelected}"
                                                Value="True">
                                            <Setter Property="BackgroundColor"
                                                    Value="{StaticResource Ink}"/>
                                            <Setter Property="Stroke"
                                                    Value="{StaticResource Ink}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CalendarVM.SelectPetCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <HorizontalStackLayout Spacing="8"
                                            VerticalOptions="Center">
                                        <!-- Mini avatar with the pet's initial (serif italic) -->
                                        <Border WidthRequest="26"
                                                HeightRequest="26"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 13"
                                                BackgroundColor="{StaticResource TealTint}"
                                                VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                        Binding="{Binding IsSelected}"
                                                        Value="True">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#28FFFFFF"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Name, Converter={StaticResource FirstLetter}}"
                                                   FontFamily="{StaticResource FontSerifItalic}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource TealDeep}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                            Binding="{Binding IsSelected}"
                                                            Value="True">
                                                        <Setter Property="TextColor"
                                                                Value="{StaticResource White}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>

                                        <Label Text="{Binding Name}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkSecondary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                        Binding="{Binding IsSelected}"
                                                        Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{StaticResource White}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Label Text="{Binding AgeDisplay}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="12"
                                               TextColor="{StaticResource InkTertiary}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                        Binding="{Binding IsSelected}"
                                                        Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{StaticResource GlassLine}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- 3 ── Week calendar (month label, arrows, sketched selection) -->
                <controls:WeekCalendarView
                    x:Name="Calendar"
                    SelectedDate="{Binding CalendarVM.CurrentSelectedDate, Mode=TwoWay}"
                    Activities="{Binding CalendarVM.WeekActivities}"/>

                <!-- 4 ── Date heading + relative label ─────────────────── -->
                <Grid ColumnDefinitions="*,Auto"
                        Margin="2,2,2,0">
                    <Label Grid.Column="0"
                           Text="{Binding CalendarVM.CurrentSelectedDate, StringFormat='{0:ddd, d MMM}'}"
                           FontFamily="{StaticResource FontSerif}"
                           FontSize="21"
                           TextColor="{StaticResource Ink}"
                           VerticalOptions="End"/>
                    <Label Grid.Column="1"
                           Text="{Binding CalendarVM.RelativeDateLabel}"
                           FontFamily="{StaticResource FontHand}"
                           FontSize="18"
                           TextColor="{StaticResource TealDeep}"
                           VerticalOptions="End"/>
                </Grid>

                <!-- 5 ── "Still to do" chip row / all-done / past-day add ─── -->
                <!-- Replaces the old "Today's Tracking" card. Today drives the -->
                <!-- pending chips; past days show a single "add" affordance.    -->

                <!-- (a) Today, with things left: heading + wrapped chips + "+" -->
                <VerticalStackLayout Spacing="9"
                                     IsVisible="{Binding JournalVM.ShowStillToDo}">
                    <Label Text="{Binding JournalVM.Heading}"
                           FontFamily="{StaticResource FontSerifItalic}"
                           FontSize="15"
                           TextColor="{StaticResource InkSecondary}"
                           Margin="2,0,0,0"/>
                    <FlexLayout Wrap="Wrap"
                                AlignItems="Center"
                                BindableLayout.ItemsSource="{Binding JournalVM.Chips}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Rotation="{Binding Tilt}"
                                        Margin="0,0,8,8"
                                        BackgroundColor="{StaticResource GlassSoft}"
                                        Stroke="{StaticResource TealLine}"
                                        StrokeThickness="1.5"
                                        StrokeShape="RoundRectangle 14,11,13,12"
                                        Padding="13,9"
                                        SemanticProperties.Description="{Binding SemanticLabel}">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsMedication}" Value="True">
                                            <Setter Property="Stroke" Value="{StaticResource HoneyWarm}"/>
                                            <Setter Property="BackgroundColor" Value="{StaticResource HoneyWarmTint}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnChipTapped"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="7" VerticalOptions="Center">
                                        <Label Text="{Binding Icon}"
                                               FontSize="14"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding Label}"
                                               IsVisible="{Binding Label, Converter={StaticResource StringToBoolConverter}}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="12.5"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TealDeep}"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsMedication}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource HoneyWarmDeep}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Text="{Binding Detail}"
                                               IsVisible="{Binding HasDetail}"
                                               FontFamily="{StaticResource FontSans}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource InkTertiary}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>

                <!-- (b) Today, all done: paw celebration + quiet add chip -->
                <VerticalStackLayout Spacing="8"
                                     Padding="2,4,0,0"
                                     IsVisible="{Binding JournalVM.ShowAllDone}">
                    <HorizontalStackLayout x:Name="PawRow" Spacing="14">
                        <Label x:Name="Paw1" Text="🐾" FontSize="20" Rotation="-14" Opacity="0"/>
                        <Label x:Name="Paw2" Text="🐾" FontSize="20" Rotation="10" TranslationY="-5" Opacity="0"/>
                        <Label x:Name="Paw3" Text="🐾" FontSize="20" Rotation="-8" Opacity="0"/>
                        <Label x:Name="Paw4" Text="🐾" FontSize="20" Rotation="12" TranslationY="-5" Opacity="0"/>
                    </HorizontalStackLayout>
                    <Label Text="{Binding JournalVM.CelebrationText}"
                           FontFamily="{StaticResource FontHand}"
                           FontSize="20"
                           TextColor="{StaticResource TealDeep}"/>
                    <Border BackgroundColor="{StaticResource GlassSoft}"
                            Stroke="{StaticResource GlassLine}"
                            StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 14,11,13,12"
                            Padding="13,9"
                            HorizontalOptions="Start"
                            Margin="0,4,0,0"
                            SemanticProperties.Description="Add something else">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding JournalVM.OpenAddSheetCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{loc:Translate Journal_ChipAddMore}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="12.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"/>
                    </Border>
                </VerticalStackLayout>

                <!-- (c) A past day: a single "add to this day" chip -->
                <Border IsVisible="{Binding JournalVM.ShowPastAdd}"
                        BackgroundColor="{StaticResource GlassSoft}"
                        Stroke="{StaticResource GlassLine}"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 14,11,13,12"
                        Padding="13,9"
                        HorizontalOptions="Start"
                        SemanticProperties.Description="Add to this day">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding JournalVM.OpenAddSheetCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="{loc:Translate Journal_ChipAddDay}"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12.5"
                           FontAttributes="Bold"
                           TextColor="{StaticResource InkTertiary}"/>
                </Border>
                <!-- 6 ── Day heading (italic serif) ────────────────────── -->
                <Label Text="{Binding CalendarVM.DayHeading}"
                       FontFamily="{StaticResource FontSerifItalic}"
                       FontSize="17"
                       TextColor="{StaticResource Ink}"
                       Margin="2,6,0,0"/>

                <!-- 7 ── Timeline ──────────────────────────────────────── -->
                <VerticalStackLayout x:Name="TimelineSection"
                        Spacing="4">

                    <!-- Mood entry -->
                    <Grid ColumnDefinitions="38,*"
                            ColumnSpacing="13"
                          IsVisible="{Binding CalendarVM.HasMood}">
                        <Grid Grid.Column="0"
                                RowDefinitions="38,*">
                            <Border WidthRequest="38"
                                    HeightRequest="38"
                                    Rotation="-3"
                                    BackgroundColor="{StaticResource TealTint}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 19,18,19,18"
                                    VerticalOptions="Start">
                                <Label Text="😊"
                                        FontSize="17"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                            </Border>
                            <BoxView Grid.Row="1"
                                    WidthRequest="2"
                                     Color="{StaticResource GlassLine}"
                                     HorizontalOptions="Center"
                                    Margin="0,4,0,0"/>
                        </Grid>
                        <Border Grid.Column="1"
                                Style="{StaticResource GlassCard}">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{loc:Translate Journal_MoodTitle}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="13.5"
                                        FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <!-- warm-paper note with washi tape -->
                                <Grid Margin="0,10,0,0">
                                    <Border BackgroundColor="{StaticResource PaperWarm}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 3,8,9,4"
                                            Rotation="-0.6"
                                            Padding="12,12,12,9">
                                        <Border.Shadow>
                                            <Shadow Brush="#0D3A3C"
                                                    Offset="0,2"
                                                    Radius="6"
                                                    Opacity="0.08"/>
                                        </Border.Shadow>
                                        <Label Text="{Binding CalendarVM.MoodNarrative}"
                                               FontFamily="{StaticResource FontSerifItalic}"
                                               FontSize="13.5"
                                               TextColor="{StaticResource NoteInk}"/>
                                    </Border>
                                    <!-- washi tape overlapping the top edge -->
                                    <BoxView WidthRequest="46"
                                            HeightRequest="15"
                                             Color="{StaticResource Washi}"
                                             Rotation="-3"
                                             HorizontalOptions="Start"
                                            VerticalOptions="Start"
                                             Margin="16,-7,0,0"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Weight entry -->
                    <Grid ColumnDefinitions="38,*"
                            ColumnSpacing="13"
                          IsVisible="{Binding CalendarVM.HasWeight}">
                        <Grid Grid.Column="0"
                                RowDefinitions="38,*">
                            <Border WidthRequest="38"
                                    HeightRequest="38"
                                    Rotation="2.5"
                                    BackgroundColor="{StaticResource BlueTint}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18,19,18,19"
                                    VerticalOptions="Start">
                                <Label Text="⚖️"
                                        FontSize="17"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                            </Border>
                            <BoxView Grid.Row="1"
                                    WidthRequest="2"
                                     Color="{StaticResource GlassLine}"
                                     HorizontalOptions="Center"
                                    Margin="0,4,0,0"/>
                        </Grid>
                        <Border Grid.Column="1"
                                Style="{StaticResource GlassCard}">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{loc:Translate Journal_WeighIn}"
                                       FontFamily="{StaticResource FontSans}"
                                       FontSize="13.5"
                                        FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"/>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding CalendarVM.ShownWeightDisplay}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="12.5"
                                           TextColor="{StaticResource InkSecondary}"/>
                                    <Label Text="·"
                                           FontSize="12.5"
                                           TextColor="{StaticResource InkTertiary}"/>
                                    <Label Text="{loc:Translate Journal_WeightScales}"
                                           FontFamily="{StaticResource FontSans}"
                                           FontSize="12.5"
                                           TextColor="{StaticResource InkTertiary}"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Glucose readings (rose accent); value is precise, never restyled -->
                    <VerticalStackLayout Spacing="4"
                                         IsVisible="{Binding JournalVM.HasGlucoseItems}"
                                         BindableLayout.ItemsSource="{Binding JournalVM.GlucoseItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="38,*" ColumnSpacing="13">
                                    <Grid Grid.Column="0" RowDefinitions="38,*">
                                        <Border WidthRequest="38" HeightRequest="38" Rotation="-3"
                                                BackgroundColor="{StaticResource RoseTint}"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 19,18,19,18"
                                                VerticalOptions="Start">
                                            <Label Text="🩸" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <BoxView Grid.Row="1" WidthRequest="2" Color="{StaticResource GlassLine}"
                                                 HorizontalOptions="Center" Margin="0,4,0,0"/>
                                    </Grid>
                                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                                        <VerticalStackLayout Spacing="2">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0" Text="{Binding Title}"
                                                       FontFamily="{StaticResource FontSans}" FontSize="13.5" FontAttributes="Bold"
                                                       TextColor="{StaticResource Ink}"/>
                                                <Label Grid.Column="1" Text="{Binding TimeDisplay}"
                                                       FontFamily="{StaticResource FontSans}" FontSize="11"
                                                       TextColor="{StaticResource InkTertiary}" VerticalOptions="Center"/>
                                            </Grid>
                                            <Label Text="{Binding Sub}"
                                                   FontFamily="{StaticResource FontSans}" FontSize="12.5"
                                                   TextColor="{StaticResource InkSecondary}"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Appetite readings -->
                    <VerticalStackLayout Spacing="4"
                                         IsVisible="{Binding JournalVM.HasAppetiteItems}"
                                         BindableLayout.ItemsSource="{Binding JournalVM.AppetiteItems}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="38,*" ColumnSpacing="13">
                                    <Grid Grid.Column="0" RowDefinitions="38,*">
                                        <Border WidthRequest="38" HeightRequest="38" Rotation="2.5"
                                                BackgroundColor="{StaticResource HoneyWarmTint}"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 18,19,18,19"
                                                VerticalOptions="Start">
                                            <Label Text="🍽️" FontSize="17" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <BoxView Grid.Row="1" WidthRequest="2" Color="{StaticResource GlassLine}"
                                                 HorizontalOptions="Center" Margin="0,4,0,0"/>
                                    </Grid>
                                    <Border Grid.Column="1" Style="{StaticResource GlassCard}">
                                        <VerticalStackLayout Spacing="2">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0" Text="{loc:Translate Journal_Appetite}"
                                                       FontFamily="{StaticResource FontSans}" FontSize="13.5" FontAttributes="Bold"
                                                       TextColor="{StaticResource Ink}"/>
                                                <Label Grid.Column="1" Text="{Binding TimeDisplay}"
                                                       FontFamily="{StaticResource FontSans}" FontSize="11"
                                                       TextColor="{StaticResource InkTertiary}" VerticalOptions="Center"/>
                                            </Grid>
                                            <Label Text="{Binding Sub}"
                                                   FontFamily="{StaticResource FontSans}" FontSize="12.5"
                                                   TextColor="{StaticResource InkSecondary}"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Medication doses -->
                    <VerticalStackLayout Spacing="4"
                                         BindableLayout.ItemsSource="{Binding CalendarVM.DosesForSelectedDate}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="38,*"
                                        ColumnSpacing="13">
                                    <Grid Grid.Column="0"
                                            RowDefinitions="38,*">
                                        <Border WidthRequest="38"
                                                HeightRequest="38"
                                                Rotation="{Binding IconRotation}"
                                                BackgroundColor="{StaticResource HoneyWarmTint}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 19,18,19,18"
                                                VerticalOptions="Start">
                                            <Label Text="💊"
                                                    FontSize="17"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center"/>
                                        </Border>
                                        <BoxView Grid.Row="1"
                                                WidthRequest="2"
                                                 Color="{StaticResource GlassLine}"
                                                 HorizontalOptions="Center"
                                                Margin="0,4,0,0"/>
                                    </Grid>

                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource Glass}"
                                            Stroke="{StaticResource GlassLine}"
                                            StrokeThickness="1"
                                            Padding="14,12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="{Binding CardCorner}"/>
                                        </Border.StrokeShape>
                                        <VerticalStackLayout Spacing="2">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0"
                                                       Text="{Binding MedName}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="13.5"
                                                        FontAttributes="Bold"
                                                       TextColor="{StaticResource Ink}"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding TimeDisplay}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="11"
                                                        FontAttributes="Bold"
                                                       TextColor="{StaticResource InkTertiary}"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                            <!-- Read-only summary: give / skip happens in the
                                                 Tracker Hub's Medications group now. -->
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="{Binding DoseDisplay}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource InkSecondary}"/>
                                                <Label Text="·"
                                                       FontSize="12"
                                                       TextColor="{StaticResource InkTertiary}"/>
                                                <Label Text="{Binding StatusText}"
                                                       FontFamily="{StaticResource FontSans}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource InkTertiary}"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Empty state: sleeping-cat doodle -->
                    <VerticalStackLayout IsVisible="{Binding CalendarVM.IsDayEmpty}"
                                         HorizontalOptions="Center"
                                         Spacing="6"
                                         Padding="24,34,24,40">
                        <!-- single-stroke cat: tail + body + head + ears + eyes -->
                        <Path Data="M14 46 q-9 -1 -8 -9 q1 -6 8 -6 M13 40 a21 13 0 1 0 42 0 a21 13 0 1 0 -42 0 M45.5 32 a9.5 9.5 0 1 0 19 0 a9.5 9.5 0 1 0 -19 0 M49 24 l-1.5 -6 5 3.5 M60 23.5 l2 -5.5 3 5 M51 32 q1.8 1.8 3.6 0 M58 32 q1.8 1.8 3.6 0"
                              Stroke="{StaticResource TealDeep}"
                              StrokeThickness="1.8"
                              StrokeLineCap="Round"
                              StrokeLineJoin="Round"
                              Opacity="0.8"
                              WidthRequest="76"
                                HeightRequest="58"
                              HorizontalOptions="Center"/>
                        <Label Text="{Binding CalendarVM.EmptyHeadline}"
                               FontFamily="{StaticResource FontHand}"
                               FontSize="24"
                               TextColor="{StaticResource TealDeep}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="{loc:Translate Journal_EmptySub}"
                               FontFamily="{StaticResource FontSans}"
                               FontSize="12.5"
                                FontAttributes="Bold"
                               TextColor="{StaticResource InkTertiary}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- (The all-care-complete celebration now lives in the chip row
                         area above, driven by JournalVM.ShowAllDone.) -->

                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ================= TAB BAR ================= -->
        <controls:BottomNavigation Grid.Row="1"
                                   ActiveTab="Calendar"/>

        <!-- Confirm micro-interaction: bubbles rising from a tapped action.
             Full-bleed, input-transparent overlay above every layer. -->
        <AbsoluteLayout x:Name="EffectLayer"
                        Grid.RowSpan="2"
                        InputTransparent="True"
                        IsClippedToBounds="False"/>

        <!-- Toast: warm confirmation pill, floats above the tab bar. -->
        <Border x:Name="Toast"
                Grid.RowSpan="2"
                Opacity="0"
                InputTransparent="True"
                BackgroundColor="{StaticResource Ink}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18,15,14,17"
                Rotation="-0.5"
                Padding="14,11"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,92">
            <Border.Shadow>
                <Shadow Brush="#0D3A3C"
                        Offset="0,12"
                        Radius="34"
                        Opacity="0.20"/>
            </Border.Shadow>
            <HorizontalStackLayout Spacing="8"
                    VerticalOptions="Center">
                <Label Text="✓"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="13"
                        FontAttributes="Bold"
                       TextColor="{StaticResource MGreat}"
                       VerticalOptions="Center"/>
                <Label x:Name="ToastLabel"
                       FontFamily="{StaticResource FontSans}"
                       FontSize="13"
                        FontAttributes="Bold"
                       TextColor="{StaticResource White}"
                       VerticalOptions="Center"/>
                <!-- Undo: the safety net for one-tap logging. Reachable by screen
                     reader while the toast is up. -->
                <Border x:Name="UndoButton"
                        IsVisible="False"
                        BackgroundColor="#1FFFFFFF"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 10"
                        Padding="12,6"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Undo">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUndoTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Undo"
                           FontFamily="{StaticResource FontSans}"
                           FontSize="12.5"
                           FontAttributes="Bold"
                           TextColor="#8FE3CD"/>
                </Border>
            </HorizontalStackLayout>
        </Border>

        <!-- Journal input sheets (all share FelovaBottomSheet). Overlays above every
             layer; input-transparent when closed so they never block the Journal. -->
        <views:GlucoseSheetView Grid.RowSpan="2" BindingContext="{Binding GlucoseSheetVM}"/>
        <views:MoodSheetView Grid.RowSpan="2" BindingContext="{Binding MoodSheetVM}"/>
        <views:WeightSheetView Grid.RowSpan="2" BindingContext="{Binding WeightSheetVM}"/>
        <views:AppetiteSheetView Grid.RowSpan="2" BindingContext="{Binding AppetiteSheetVM}"/>
        <views:AddAnythingSheetView Grid.RowSpan="2" BindingContext="{Binding JournalVM}"/>

    </Grid>

</ContentPage>
