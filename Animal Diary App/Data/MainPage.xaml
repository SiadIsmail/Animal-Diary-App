<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Animal_Diary_App.Data.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,20"
            Spacing="20">
            <Grid
                ColumnDefinitions="Auto,*"
                ColumnSpacing="14"
                VerticalOptions="Center">
                <Image
                    Source="animal1.jpg"
                    Aspect="AspectFit"
                    WidthRequest="64"
                    HeightRequest="64"
                    VerticalOptions="Center">
                    <Image.WidthRequest>
                        <OnIdiom x:TypeArguments="x:Double"
                                 Phone="65"
                                 Tablet="75"
                                 Desktop="100"/>
                    </Image.WidthRequest>
                    <Image.HeightRequest>
                        <OnIdiom x:TypeArguments="x:Double"
                                 Phone="65"
                                 Tablet="75"
                                 Desktop="100"/>
                    </Image.HeightRequest>
                </Image>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="4"
                                     VerticalOptions="Center">
                    <Label
                        x:Name="PetNameLabel"
                        Text="Charlinus"
                        FontSize="22"
                        FontAttributes="Bold"
                        LineBreakMode="WordWrap"/>
                    <Label
                        x:Name="PetDetailsLabel"
                        Text="Ratte, extrem feasdasdwasdasdtt"
                        FontSize="15"
                        TextColor="#666666"
                        LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
        <HorizontalStackLayout VerticalOptions="End">
            <Button
                Text="Main"/>
            <Button
                Text="Calendar"
                Clicked="OnCalendarClicked"/>
        </HorizontalStackLayout>
    </ScrollView>

</ContentPage>
